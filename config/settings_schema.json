[
  {
    "name": "theme_info",
    "theme_name": "Pump Portable",
    "theme_version": "2.0.0",
    "theme_author": "Pump Portable",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social share image",
        "info": "Used when a page has no featured image (Open Graph / Twitter)."
      }
    ]
  },
  {
    "name": "Store",
    "settings": [
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold",
        "default": 500,
        "info": "Amount in store currency (e.g. 500 for 500 kr). Used in cart progress bar and trust copy."
      },
      {
        "type": "url",
        "id": "cookie_policy_url",
        "label": "Cookie policy page",
        "info": "Optional link shown in footer legal links and cookie banner."
      },
      {
        "type": "header",
        "content": "Cookie consent"
      },
      {
        "type": "checkbox",
        "id": "enable_cookie_banner",
        "label": "Show cookie consent banner",
        "default": true
      },
      {
        "type": "textarea",
        "id": "cookie_banner_text",
        "label": "Cookie banner text",
        "default": "Vi använder cookies för att ge dig bästa möjliga upplevelse på vår webbplats."
      },
      {
        "type": "text",
        "id": "cookie_banner_button",
        "label": "Accept button label",
        "default": "Acceptera cookies"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#071014",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#F6F7F2",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 8
      }
    ]
  },
  {
    "name": "Newsletter popup",
    "settings": [
      {
        "type": "checkbox",
        "id": "newsletter_popup_enabled",
        "label": "Show newsletter popup",
        "default": true
      },
      {
        "type": "range",
        "id": "newsletter_popup_delay",
        "min": 3,
        "max": 30,
        "step": 1,
        "unit": "s",
        "label": "Delay before popup",
        "default": 25
      },
      {
        "type": "text",
        "id": "newsletter_popup_heading",
        "label": "Heading",
        "default": "Få 10% rabatt på din första order"
      },
      {
        "type": "textarea",
        "id": "newsletter_popup_subheading",
        "label": "Subheading",
        "default": "Anmäl dig till nyhetsbrevet — tips, lanseringar och erbjudanden."
      },
      {
        "type": "text",
        "id": "newsletter_popup_placeholder",
        "label": "Email placeholder",
        "default": "Din e-post"
      },
      {
        "type": "text",
        "id": "newsletter_popup_button",
        "label": "Button label",
        "default": "Prenumerera"
      },
      {
        "type": "text",
        "id": "newsletter_popup_success",
        "label": "Success message",
        "default": "Tack! Kolla inkorgen snart."
      }
    ]
  }
]
