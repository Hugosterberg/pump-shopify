{% comment %}
  Payment method icons from Shopify Payments. Reusable near ATC, cart, footer.

  Params:
  - class_prefix (optional, default: payment-icons)
  - label (optional, default: Betalningsmetoder)
{% endcomment %}

{%- liquid
  assign class_prefix = class_prefix | default: 'payment-icons'
  assign label = label | default: 'Betalningsmetoder'
-%}

{% if shop.enabled_payment_types.size > 0 %}
  <div class="{{ class_prefix }}">
    {% if label != blank %}
      <span class="{{ class_prefix }}__label">{{ label }}</span>
    {% endif %}
    <div class="{{ class_prefix }}__icons" aria-hidden="true">
      {% for type in shop.enabled_payment_types %}
        <span class="{{ class_prefix }}__pill">
          {{ type | payment_type_svg_tag: class: class_prefix | append: '__icon' }}
        </span>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .payment-icons,
  [class*='__payment']:not([class*='__payment__']) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .payment-icons__label,
  [class*='__payment__label'] {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pp-muted, #9aa8a2);
  }

  .payment-icons__icons,
  [class*='__payment__icons'] {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .payment-icons__pill,
  [class*='__payment__pill'] {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 8px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
  }

  .payment-icons__icon,
  [class*='__payment__icon'] {
    height: 20px;
    width: auto;
    display: block;
    opacity: 0.92;
  }
{% endstylesheet %}
