{% comment %}
  Payment method icons from Shopify Payments. Reusable near ATC, cart, footer.

  Params:
  - class_prefix (optional, default: payment-icons)
  - label (optional, default: Betalningsmetoder)
  - inline_row (optional, boolean — fit all icons on one row)
{% endcomment %}

{%- liquid
  assign class_prefix = class_prefix | default: 'payment-icons'
  assign use_inline_row = false
  if inline_row == true
    assign use_inline_row = true
  endif

  assign show_label = true
  assign display_label = label
  if label == ''
    assign show_label = false
  elsif label == blank
    assign display_label = 'Betalningsmetoder'
  endif
-%}

{% if shop.enabled_payment_types.size > 0 %}
  <div class="pp-payment-icons{% if use_inline_row %} pp-payment-icons--inline-row{% endif %} {{ class_prefix }}">
    {% if show_label %}
      <span class="pp-payment-icons__label {{ class_prefix }}__label">{{ display_label }}</span>
    {% endif %}
    <div class="pp-payment-icons__grid {{ class_prefix }}__icons" aria-hidden="true">
      {% for type in shop.enabled_payment_types %}
        <span class="pp-payment-icons__pill {{ class_prefix }}__pill">
          {{ type | payment_type_svg_tag }}
        </span>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .pp-payment-icons {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    width: 100%;
  }

  .pp-payment-icons__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
    color: var(--pp-muted, #9aa8a2);
  }

  .pp-payment-icons__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .pp-payment-icons__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 54px;
    min-height: 36px;
    padding: 6px 10px;
    border-radius: 10px;
    font-size: 0;
    line-height: 0;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 9%, transparent);
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .pp-payment-icons__pill:hover {
    border-color: color-mix(in srgb, var(--pp-accent, #2dd4bf) 30%, transparent);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 6%, transparent);
  }

  .pp-payment-icons__pill svg {
    height: 20px;
    width: auto;
    max-width: 44px;
    display: block;
    opacity: 0.95;
  }

  .pp-payment-icons--inline-row .pp-payment-icons__grid {
    flex-wrap: nowrap;
    justify-content: center;
    gap: clamp(3px, 0.7vw, 6px);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pp-payment-icons--inline-row .pp-payment-icons__grid::-webkit-scrollbar {
    display: none;
  }

  .pp-payment-icons--inline-row .pp-payment-icons__pill {
    flex: 1 1 0;
    min-width: 0;
    max-width: 52px;
    min-height: 28px;
    padding: 3px 4px;
    border-radius: 7px;
  }

  .pp-payment-icons--inline-row .pp-payment-icons__pill svg {
    height: clamp(12px, 2.4vw, 16px);
    max-width: 100%;
    width: auto;
  }
{% endstylesheet %}
