{% comment %}
  Slide-out cart drawer with AJAX add/update via Cart API.
{% endcomment %}

<div
  class="cart-drawer"
  data-cart-drawer
  hidden
  aria-hidden="true"
>
  <div class="cart-drawer__backdrop" data-cart-close tabindex="-1"></div>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="CartDrawerTitle"
    tabindex="-1"
  >
    <header class="cart-drawer__header">
      <h2 id="CartDrawerTitle" class="cart-drawer__title">
        Varukorg
        <span class="cart-drawer__count" data-cart-drawer-count>({{ cart.item_count }})</span>
      </h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="Stäng varukorg">
        {% render 'icon', name: 'x', size: 20 %}
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-drawer-body>
      {% if cart.item_count > 0 %}
        <ul class="cart-drawer__items" role="list" data-cart-drawer-items>
          {% for item in cart.items %}
            <li class="cart-drawer__item" data-cart-line="{{ item.key }}">
              <a class="cart-drawer__image" href="{{ item.url }}">
                {% if item.image %}
                  {{
                    item.image
                    | image_url: width: 160
                    | image_tag: loading: 'lazy', widths: '80, 160', sizes: '72px', alt: item.product.title
                  }}
                {% endif %}
              </a>
              <div class="cart-drawer__details">
                <a class="cart-drawer__name" href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="cart-drawer__variant">{{ item.variant.title }}</p>
                {% endunless %}
                {% liquid
                  assign unit_price = item.final_price
                  if item.quantity > 1
                    assign price_label = unit_price | money | append: ' × ' | append: item.quantity
                  else
                    assign price_label = item.final_line_price | money
                  endif
                %}
                <p class="cart-drawer__price">{{ price_label }}</p>
                <div class="cart-drawer__qty">
                  <label class="visually-hidden" for="CartDrawerQty-{{ forloop.index }}">Antal</label>
                  <button type="button" class="cart-drawer__qty-btn" data-cart-qty-change data-line="{{ item.key }}" data-quantity="{{ item.quantity | minus: 1 }}" aria-label="Minska antal">−</button>
                  <input
                    id="CartDrawerQty-{{ forloop.index }}"
                    class="cart-drawer__qty-input"
                    type="number"
                    min="0"
                    value="{{ item.quantity }}"
                    data-cart-qty-input
                    data-line="{{ item.key }}"
                    aria-label="Antal"
                  >
                  <button type="button" class="cart-drawer__qty-btn" data-cart-qty-change data-line="{{ item.key }}" data-quantity="{{ item.quantity | plus: 1 }}" aria-label="Öka antal">+</button>
                </div>
              </div>
              <button type="button" class="cart-drawer__remove" data-cart-remove data-line="{{ item.key }}" aria-label="Ta bort {{ item.product.title }}">
                {% render 'icon', name: 'x', size: 16 %}
              </button>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        {%- assign featured = all_products['the-perfect-combo-portabel-dusch-vikbar-hink-1'] -%}
        <div class="cart-drawer__empty" data-cart-drawer-empty>
          <span class="cart-drawer__empty-icon" aria-hidden="true">{% render 'icon', name: 'droplets', size: 32 %}</span>
          <p class="cart-drawer__empty-title">Varukorgen är tom</p>
          <p class="cart-drawer__empty-text">Du är ett steg från duschfrihet var du än är.</p>
          {% if featured != blank %}
            <a class="cart-drawer__empty-featured" href="{{ featured.url }}">
              {% if featured.featured_image %}
                {{
                  featured.featured_image
                  | image_url: width: 200
                  | image_tag: loading: 'lazy', widths: '100, 200', sizes: '80px', alt: featured.title
                }}
              {% endif %}
              <span class="cart-drawer__empty-featured-info">
                <strong>{{ featured.title }}</strong>
                <span>{{ featured.price | money }}</span>
              </span>
            </a>
          {% endif %}
          <a class="cart-drawer__continue" href="{{ routes.all_products_collection_url }}">Fortsätt handla</a>
        </div>
      {% endif %}
    </div>

    {% render 'cart-upsell' %}

    <footer class="cart-drawer__footer" data-cart-drawer-footer{% if cart.item_count == 0 %} hidden{% endif %}>
      <div class="cart-drawer__footer-shipping" data-cart-drawer-shipping>
        {% render 'free-shipping-bar', class_prefix: 'cart-drawer__shipping', compact: true %}
      </div>

      <div class="cart-drawer__summary">
        <p class="cart-drawer__subtotal">
          <span>Delsumma</span>
          <strong data-cart-drawer-subtotal>{{ cart.total_price | money }}</strong>
        </p>
        <a class="cart-drawer__checkout pp-btn-primary pp-btn--full" href="{{ routes.root_url }}checkout" data-cart-checkout>
          Gå till kassan
        </a>
      </div>

      <div class="cart-drawer__reassurance">
        <p class="cart-drawer__trust-line">
          {% render 'icon', name: 'lock', size: 12 %}
          Säker checkout · 14 dagars ångerrätt
        </p>
        {% render 'payment-icons', class_prefix: 'cart-drawer__payment', label: '', inline_row: true %}
      </div>

      <div class="cart-drawer__buy-legal">
        {% render 'legal-links', class_prefix: 'cart-drawer__legal', compact: true %}
      </div>

      <a class="cart-drawer__view-cart" href="{{ routes.cart_url }}">Visa varukorg</a>
    </footer>

    <p class="cart-drawer__status visually-hidden" data-cart-live-region aria-live="polite" aria-atomic="true"></p>
    <div class="cart-drawer__spinner" data-cart-spinner aria-hidden="true">
      <span class="pp-spinner"></span>
    </div>
  </aside>
</div>

<template id="CartDrawerEmptyIcon">
  {% render 'icon', name: 'droplets', size: 32 %}
</template>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 250;
  }

  .cart-drawer[hidden] {
    display: none;
  }

  body.cart-drawer-open {
    overflow: hidden;
  }

  .cart-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(7 16 20 / 76%);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .cart-drawer.is-open .cart-drawer__backdrop {
    opacity: 1;
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    width: min(100%, 420px);
    height: 100%;
    background: linear-gradient(180deg, var(--pp-surface-light, #1d2b35) 0%, var(--pp-surface, #14212a) 18%);
    color: var(--pp-text, #f6f7f2);
    border-left: 1px solid var(--pp-border);
    box-shadow: -24px 0 80px rgb(0 0 0 / 45%);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--pp-accent, #2dd4bf), transparent);
    opacity: 0.65;
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
  }

  .cart-drawer__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .cart-drawer__count {
    font-weight: 500;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--pp-muted, #9aa8a2);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .cart-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 12px;
    align-items: start;
    padding: 14px;
    border-radius: var(--pp-radius-md, 14px);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
  }

  .cart-drawer__image {
    display: block;
    border-radius: 10px;
    overflow: hidden;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
  }

  .cart-drawer__image img {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: cover;
  }

  .cart-drawer__name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    text-decoration: none;
    color: inherit;
    text-wrap: balance;
  }

  .cart-drawer__variant,
  .cart-drawer__price {
    margin: 4px 0 0;
    font-size: 0.82rem;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__price {
    color: var(--pp-accent, #2dd4bf);
    font-weight: 600;
  }

  .cart-drawer__qty {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    margin-top: 10px;
    padding: 2px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 12%, transparent);
    background: color-mix(in srgb, var(--pp-bg-deep, #071014) 40%, transparent);
  }

  .cart-drawer__qty-btn {
    width: 34px;
    height: 34px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cart-drawer__qty-btn:hover {
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 12%, transparent);
    color: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer__qty-input {
    width: 36px;
    height: 34px;
    border: none;
    background: transparent;
    color: inherit;
    text-align: center;
    font-size: 0.88rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .cart-drawer__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--pp-muted, #9aa8a2);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
  }

  .cart-drawer__empty {
    text-align: center;
    padding: 32px 12px 40px;
    color: var(--pp-muted, #9aa8a2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .cart-drawer__empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    color: var(--pp-accent, #2dd4bf);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 12%, transparent);
  }

  .cart-drawer__empty-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--pp-text, #f6f7f2);
  }

  .cart-drawer__empty-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    max-width: 260px;
  }

  .cart-drawer__empty-featured {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 280px;
    margin-top: 8px;
    padding: 12px;
    border-radius: 14px;
    text-decoration: none;
    text-align: left;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-accent, #2dd4bf) 25%, transparent);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .cart-drawer__empty-featured:hover {
    border-color: color-mix(in srgb, var(--pp-accent, #2dd4bf) 45%, transparent);
    transform: translateY(-1px);
  }

  .cart-drawer__empty-featured img {
    width: 64px;
    height: 64px;
    border-radius: 10px;
    object-fit: cover;
  }

  .cart-drawer__empty-featured-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .cart-drawer__empty-featured-info strong {
    font-size: 0.88rem;
    color: var(--pp-text, #f6f7f2);
  }

  .cart-drawer__empty-featured-info span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer__trust-line {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 auto;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--pp-muted, #9aa8a2);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 9%, transparent);
  }

  .cart-drawer__trust-line svg {
    color: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer__continue {
    display: inline-flex;
    margin-top: 16px;
    min-height: 44px;
    padding-inline: 20px;
    align-items: center;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-accent-ink, #071014);
    background: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer__footer {
    padding: 0 20px 20px;
    border-top: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0;
    background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--pp-bg-deep, #071014) 35%, transparent));
  }

  .cart-drawer__footer-shipping {
    padding: 14px 0 0;
  }

  .cart-drawer__summary {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 0 14px;
  }

  .cart-drawer__reassurance {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 14px 12px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 7%, transparent);
  }

  .cart-drawer__reassurance .cart-drawer__payment {
    width: 100%;
  }

  .cart-drawer__reassurance .pp-payment-icons {
    gap: 0;
  }

  .cart-drawer__buy-legal {
    padding: 14px 0 4px;
  }

  .cart-drawer__buy-legal .cart-drawer__legal {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--pp-muted, #9aa8a2);
    text-align: center;
  }

  .cart-drawer__buy-legal .cart-drawer__legal span[aria-hidden='true'] {
    display: none;
  }

  .cart-drawer__buy-legal .cart-drawer__legal a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--pp-muted, #9aa8a2) !important;
    text-decoration: none !important;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .cart-drawer__buy-legal .cart-drawer__legal a:hover {
    color: var(--pp-accent, #2dd4bf) !important;
    border-color: color-mix(in srgb, var(--pp-accent, #2dd4bf) 35%, transparent);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 8%, transparent);
  }

  .cart-drawer__footer[hidden] {
    display: none;
  }

  .cart-drawer__subtotal {
    margin: 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    font-size: 1rem;
  }

  .cart-drawer__subtotal strong {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--pp-text, #f6f7f2);
    font-variant-numeric: tabular-nums;
  }

  .cart-drawer__legal {
    margin: 0;
  }

  .cart-drawer__close:hover,
  .cart-drawer__remove:hover {
    color: var(--pp-text, #f6f7f2);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 16%, transparent);
  }

  .cart-drawer__checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    border-radius: var(--pp-radius-pill, 999px);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--pp-accent-ink, #071014);
    background: linear-gradient(135deg, var(--pp-accent, #2dd4bf) 0%, color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 22%, var(--pp-accent, #2dd4bf)) 100%);
    box-shadow:
      var(--pp-shadow-glow),
      inset 0 1px 0 color-mix(in srgb, #fff 25%, transparent);
    transition: transform var(--pp-transition, 0.2s ease), box-shadow var(--pp-transition, 0.2s ease);
  }

  .cart-drawer__checkout:hover {
    transform: translateY(-1px);
  }

  .cart-drawer__view-cart {
    display: block;
    margin-top: 10px;
    padding: 8px 0 0;
    text-align: center;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--pp-muted, #9aa8a2);
    text-decoration: none;
    transition: color var(--pp-transition, 0.2s ease);
  }

  .cart-drawer__view-cart:hover {
    color: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer.is-busy .cart-drawer__spinner {
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer__spinner {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--pp-bg-deep, #071014) 35%, transparent);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    pointer-events: none;
    z-index: 2;
  }

  .cart-drawer.is-busy .cart-drawer__panel {
    pointer-events: none;
  }

  .cart-drawer__checkout {
    margin-top: 4px;
  }

  .cart-drawer__checkout:not(.pp-btn-primary) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    border-radius: var(--pp-radius-pill, 999px);
    font-weight: 700;
    text-decoration: none;
    color: var(--pp-accent-ink, #071014);
    background: linear-gradient(135deg, var(--pp-accent, #2dd4bf) 0%, color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 22%, var(--pp-accent, #2dd4bf)) 100%);
    box-shadow: var(--pp-shadow-glow);
  }

  .cart-drawer.is-busy .cart-drawer__panel {
    opacity: 1;
  }

  .cart-drawer__item.is-updating {
    opacity: 0.55;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-drawer__panel {
      transition: none;
    }
  }

  .cart-drawer .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

<script>
  {%- liquid
    assign combo = all_products['the-perfect-combo-portabel-dusch-vikbar-hink-1']
    assign shower = all_products['portabel-dusch']
    assign bucket = all_products['portabel-hink']
  -%}
  window.PumpCart = {
    moneyFormat: {{ shop.money_format | json }},
    freeShippingThreshold: {{ settings.free_shipping_threshold | default: 999 | times: 100 | json }},
    upsellProducts: {
      combo: {
        handle: {{ combo.handle | json }},
        title: {{ combo.title | json }},
        variantId: {{ combo.selected_or_first_available_variant.id | json }},
        price: {{ combo.selected_or_first_available_variant.price | json }},
        compareAtPrice: {{ combo.compare_at_price | default: 0 | json }},
        image: {{ combo.featured_image | image_url: width: 160 | json }},
        label: 'Komplettera med Perfect Combo',
        badge: 'Bästsäljare'
      },
      shower: {
        handle: {{ shower.handle | json }},
        title: {{ shower.title | json }},
        variantId: {{ shower.selected_or_first_available_variant.id | json }},
        price: {{ shower.selected_or_first_available_variant.price | json }},
        compareAtPrice: {{ shower.compare_at_price | default: 0 | json }},
        image: {{ shower.featured_image | image_url: width: 160 | json }},
        label: 'Komplettera med duschen',
        badge: 'Rekommenderat'
      },
      bucket: {
        handle: {{ bucket.handle | json }},
        title: {{ bucket.title | json }},
        variantId: {{ bucket.selected_or_first_available_variant.id | json }},
        price: {{ bucket.selected_or_first_available_variant.price | json }},
        compareAtPrice: {{ bucket.compare_at_price | default: 0 | json }},
        image: {{ bucket.featured_image | image_url: width: 160 | json }},
        label: 'Komplettera med hinken',
        badge: 'Rekommenderat'
      }
    },
