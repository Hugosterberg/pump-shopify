{% comment %}
  Slide-out cart drawer with AJAX add/update via Cart API.
{% endcomment %}

<div
  class="cart-drawer"
  data-cart-drawer
  hidden
  aria-hidden="true"
>
  <div class="cart-drawer__backdrop" data-cart-close tabindex="-1"></div>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="CartDrawerTitle"
    tabindex="-1"
  >
    <header class="cart-drawer__header">
      <h2 id="CartDrawerTitle" class="cart-drawer__title">
        Varukorg
        <span class="cart-drawer__count" data-cart-drawer-count>({{ cart.item_count }})</span>
      </h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="Stäng varukorg">
        {% render 'icon', name: 'x', size: 20 %}
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-drawer-body>
      {% if cart.item_count > 0 %}
        <ul class="cart-drawer__items" role="list" data-cart-drawer-items>
          {% for item in cart.items %}
            <li class="cart-drawer__item" data-cart-line="{{ item.key }}">
              <a class="cart-drawer__image" href="{{ item.url }}">
                {% if item.image %}
                  {{
                    item.image
                    | image_url: width: 160
                    | image_tag: loading: 'lazy', widths: '80, 160', sizes: '72px', alt: item.product.title
                  }}
                {% endif %}
              </a>
              <div class="cart-drawer__details">
                <a class="cart-drawer__name" href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="cart-drawer__variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="cart-drawer__price">{{ item.final_line_price | money }}</p>
                <div class="cart-drawer__qty">
                  <label class="visually-hidden" for="CartDrawerQty-{{ forloop.index }}">Antal</label>
                  <button type="button" class="cart-drawer__qty-btn" data-cart-qty-change data-line="{{ item.key }}" data-quantity="{{ item.quantity | minus: 1 }}" aria-label="Minska antal">−</button>
                  <input
                    id="CartDrawerQty-{{ forloop.index }}"
                    class="cart-drawer__qty-input"
                    type="number"
                    min="0"
                    value="{{ item.quantity }}"
                    data-cart-qty-input
                    data-line="{{ item.key }}"
                    aria-label="Antal"
                  >
                  <button type="button" class="cart-drawer__qty-btn" data-cart-qty-change data-line="{{ item.key }}" data-quantity="{{ item.quantity | plus: 1 }}" aria-label="Öka antal">+</button>
                </div>
              </div>
              <button type="button" class="cart-drawer__remove" data-cart-remove data-line="{{ item.key }}" aria-label="Ta bort {{ item.product.title }}">
                {% render 'icon', name: 'x', size: 16 %}
              </button>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <div class="cart-drawer__empty" data-cart-drawer-empty>
          <p>Varukorgen är tom.</p>
          <a class="cart-drawer__continue" href="{{ routes.all_products_collection_url }}">Fortsätt handla</a>
        </div>
      {% endif %}
    </div>

    <footer class="cart-drawer__footer" data-cart-drawer-footer{% if cart.item_count == 0 %} hidden{% endif %}>
      <div data-cart-drawer-shipping>
        {% render 'free-shipping-bar', class_prefix: 'cart-drawer__shipping' %}
      </div>
      <p class="cart-drawer__subtotal">
        <span>Delsumma</span>
        <strong data-cart-drawer-subtotal>{{ cart.total_price | money }}</strong>
      </p>
      {% render 'legal-links', class_prefix: 'cart-drawer__legal', compact: true %}
      <a class="cart-drawer__checkout" href="/checkout" data-cart-checkout>
        Gå till kassan
      </a>
      <a class="cart-drawer__view-cart" href="{{ routes.cart_url }}">Visa varukorg</a>
    </footer>

    <p class="cart-drawer__status visually-hidden" data-cart-live-region aria-live="polite" aria-atomic="true"></p>
  </aside>
</div>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 250;
  }

  .cart-drawer[hidden] {
    display: none;
  }

  body.cart-drawer-open {
    overflow: hidden;
  }

  .cart-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(7 16 20 / 76%);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .cart-drawer.is-open .cart-drawer__backdrop {
    opacity: 1;
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    width: min(100%, 420px);
    height: 100%;
    background: linear-gradient(180deg, var(--pp-surface-light, #1d2b35) 0%, var(--pp-surface, #14212a) 18%);
    color: var(--pp-text, #f6f7f2);
    border-left: 1px solid var(--pp-border);
    box-shadow: -24px 0 80px rgb(0 0 0 / 45%);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--pp-accent, #2dd4bf), transparent);
    opacity: 0.65;
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
  }

  .cart-drawer__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .cart-drawer__count {
    font-weight: 500;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--pp-muted, #9aa8a2);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .cart-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 12px;
    align-items: start;
    padding: 12px;
    border-radius: var(--pp-radius-md, 14px);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
  }

  .cart-drawer__image {
    display: block;
    border-radius: 10px;
    overflow: hidden;
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
  }

  .cart-drawer__image img {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: cover;
  }

  .cart-drawer__name {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
  }

  .cart-drawer__variant,
  .cart-drawer__price {
    margin: 4px 0 0;
    font-size: 0.82rem;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__price {
    color: var(--pp-accent, #2dd4bf);
    font-weight: 600;
  }

  .cart-drawer__qty {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 12%, transparent);
  }

  .cart-drawer__qty-btn {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font-size: 1rem;
  }

  .cart-drawer__qty-input {
    width: 40px;
    height: 32px;
    border: none;
    background: transparent;
    color: inherit;
    text-align: center;
    font-size: 0.88rem;
  }

  .cart-drawer__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--pp-muted, #9aa8a2);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 6%, transparent);
  }

  .cart-drawer__empty {
    text-align: center;
    padding: 40px 12px;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__continue {
    display: inline-flex;
    margin-top: 16px;
    min-height: 44px;
    padding-inline: 20px;
    align-items: center;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-accent-ink, #071014);
    background: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer__footer {
    padding: 16px 20px 20px;
    border-top: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart-drawer__footer[hidden] {
    display: none;
  }

  .cart-drawer__subtotal {
    margin: 0;
    display: flex;
    justify-content: space-between;
    font-size: 1rem;
  }

  .cart-drawer__legal {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--pp-muted, #9aa8a2);
  }

  .cart-drawer__legal a {
    color: var(--pp-text, #f6f7f2);
  }

  .cart-drawer__close:hover,
  .cart-drawer__remove:hover {
    color: var(--pp-text, #f6f7f2);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 16%, transparent);
  }

  .cart-drawer__checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    border-radius: var(--pp-radius-pill, 999px);
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-accent-ink, #071014);
    background: linear-gradient(135deg, var(--pp-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 35%, var(--pp-accent, #2dd4bf)));
    box-shadow: var(--pp-shadow-glow);
    transition: transform var(--pp-transition, 0.2s ease), box-shadow var(--pp-transition, 0.2s ease);
  }

  .cart-drawer__checkout:hover {
    transform: translateY(-1px);
  }

  .cart-drawer__view-cart {
    text-align: center;
    font-size: 0.88rem;
    color: var(--pp-muted, #9aa8a2);
    text-decoration: none;
    transition: color var(--pp-transition, 0.2s ease);
  }

  .cart-drawer__view-cart:hover {
    color: var(--pp-accent, #2dd4bf);
  }

  .cart-drawer.is-busy .cart-drawer__panel {
    opacity: 0.92;
    pointer-events: none;
  }

  .cart-drawer .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-drawer__panel {
      transition: none;
    }
  }
{% endstylesheet %}

<script>
  window.PumpCart = {
    moneyFormat: {{ shop.money_format | json }},
    freeShippingThreshold: {{ settings.free_shipping_threshold | default: 999 | times: 100 | json }},
    strings: {
      added: 'Produkten lades till i varukorgen',
      error: 'Kunde inte uppdatera varukorgen. Försök igen.',
      empty: 'Varukorgen är tom.',
      checkout: 'Gå till kassan',
      continue: 'Fortsätt handla',
      subtotal: 'Delsumma',
      remove: 'Ta bort'
    }
  };
</script>
<script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
