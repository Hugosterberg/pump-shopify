{% comment %}
  Country and language selector (Shopify Markets / localization).

  Params:
  - class_prefix (optional)
  - form_id (optional, default: LocalizationForm)
  - compact (optional, boolean — inline selects without submit button label)
  - show_label (optional, default: true)

  Usage:
    {% render 'localization-form', class_prefix: 'site-header__localization', compact: true, form_id: 'HeaderLocalizationForm' %}
{% endcomment %}

{%- liquid
  assign class_prefix = class_prefix | default: 'localization-form'
  assign form_id = form_id | default: 'LocalizationForm'
  assign compact = compact | default: false
  assign show_label = show_label | default: true
  assign show_countries = false
  assign show_languages = false

  if localization.available_countries.size > 1
    assign show_countries = true
  endif
  if localization.available_languages.size > 1
    assign show_languages = true
  endif
-%}

{%- if show_countries or show_languages -%}
  {% form 'localization', class: class_prefix, id: form_id %}
    {%- if show_label and compact == false -%}
      <p class="{{ class_prefix }}__label">Region &amp; språk</p>
    {%- endif -%}
    <div class="{{ class_prefix }}__fields{% if compact %} {{ class_prefix }}__fields--compact{% endif %}">
      {%- if show_countries -%}
        <label class="visually-hidden" for="{{ form_id }}-CountrySelect">Land/region</label>
        <select id="{{ form_id }}-CountrySelect" name="country_code" class="{{ class_prefix }}__select" aria-label="Land och valuta">
          {%- for country in localization.available_countries -%}
            <option
              value="{{ country.iso_code }}"
              {%- if country.iso_code == localization.country.iso_code %}
                selected
              {% endif %}
            >
              {%- if compact -%}
                {{ country.name }} | {{ country.currency.iso_code }} {{ country.currency.symbol }}
              {%- else -%}
                {{ country.name }} ({{ country.currency.iso_code }})
              {%- endif -%}
            </option>
          {%- endfor -%}
        </select>
      {%- endif -%}

      {%- if show_languages -%}
        <label class="visually-hidden" for="{{ form_id }}-LanguageSelect">Språk</label>
        <select id="{{ form_id }}-LanguageSelect" name="locale_code" class="{{ class_prefix }}__select" aria-label="Språk">
          {%- for language in localization.available_languages -%}
            <option
              value="{{ language.iso_code }}"
              {%- if language.iso_code == localization.language.iso_code %}
                selected
              {% endif %}
            >
              {{ language.endonym_name | capitalize }}
            </option>
          {%- endfor -%}
        </select>
      {%- endif -%}

      <button type="submit" class="{{ class_prefix }}__submit{% if compact %} visually-hidden{% endif %}">
        {%- if compact -%}Uppdatera{%- else -%}Uppdatera{%- endif -%}
      </button>
    </div>
  {% endform %}
{%- elsif compact -%}
  <div class="{{ class_prefix }}__fallback" aria-label="Region">
    <span>{{ localization.country.name }} | {{ localization.country.currency.iso_code }}</span>
  </div>
{%- endif -%}

{% stylesheet %}
  .localization-form__fields--compact,
  [class*='__localization__fields--compact'] {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .localization-form__fields--compact select,
  [class*='__localization__fields--compact'] select {
    min-height: 34px;
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--pp-text, #f6f7f2) 12%, transparent);
    background: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
    color: var(--pp-text, #f6f7f2);
    font-size: 0.78rem;
    max-width: 160px;
  }

  .site-header__localization {
    display: none;
  }

  .site-header__localization__fallback {
    font-size: 0.78rem;
    color: var(--hdr-muted, #9aa8a2);
    white-space: nowrap;
  }

  @media screen and (min-width: 990px) {
    .site-header__localization {
      display: block;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('.localization-form__fields--compact select, [class*="__localization__fields--compact"] select').forEach(function (select) {
      select.addEventListener('change', function () {
        const form = select.closest('form');
        if (form) form.requestSubmit();
      });
    });
  })();
{% endjavascript %}
