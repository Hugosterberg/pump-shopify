{% comment %}
  Luminous water line. A single thin glowing wave that drifts slowly,
  edges fading out for an elegant, premium feel. Pure CSS/SVG, no JS.

  Usage: {% render 'wave-divider', color: '#2dd4bf', height: 60 %}
{% endcomment %}

{%- liquid
  assign wave_color = color | default: '#2dd4bf'
  assign wave_height = height | default: 60
-%}

<div
  class="wave-line"
  aria-hidden="true"
  style="--wl-color: {{ wave_color }}; --wl-height: {{ wave_height }}px;"
>
  <svg class="wave-line__svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
    <g class="wave-line__group">
      <path
        class="wave-line__path"
        d="M0 30 C 240 4, 480 56, 720 30 C 960 4, 1200 56, 1440 30"
        fill="none"
      />
      <path
        class="wave-line__path"
        d="M0 30 C 240 4, 480 56, 720 30 C 960 4, 1200 56, 1440 30"
        fill="none"
        transform="translate(1440 0)"
      />
    </g>
  </svg>
</div>

{% stylesheet %}
  .wave-line {
    width: 100%;
    height: var(--wl-height, 60px);
    line-height: 0;
    overflow: hidden;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
  }

  .wave-line__svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .wave-line__group {
    animation: wave-line-drift 16s linear infinite;
  }

  .wave-line__path {
    stroke: var(--wl-color, #2dd4bf);
    stroke-width: 2;
    stroke-linecap: round;
    filter: drop-shadow(0 0 5px color-mix(in srgb, var(--wl-color, #2dd4bf) 75%, transparent));
    opacity: 0.85;
  }

  @keyframes wave-line-drift {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-1440px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wave-line__group {
      animation: none;
    }
  }
{% endstylesheet %}
