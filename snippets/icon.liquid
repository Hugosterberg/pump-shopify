{% comment %}
  Renders an inline line icon by name. Uses currentColor so it inherits
  text color. No external assets, no JavaScript.

  Usage: {% render 'icon', name: 'battery' %}
  Optional: size (px, default 24)
{% endcomment %}

{%- liquid
  assign icon_size = size | default: 24
-%}

<svg
  class="pp-icon pp-icon--{{ name }}"
  width="{{ icon_size }}"
  height="{{ icon_size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case name -%}
    {%- when 'battery' -%}
      <rect x="2" y="8" width="16" height="9" rx="2.5" />
      <path d="M21 11.5v2" />
      <rect x="4.5" y="10.5" width="6" height="4" rx="1" fill="currentColor" stroke="none" />
    {%- when 'bolt' -%}
      <path d="M13 2 4.5 13.5H10l-1 8.5 9.5-12.5H13z" />
    {%- when 'usb' -%}
      <path d="M12 21V6" />
      <path d="m8.5 9.5 3.5-4 3.5 4" />
      <circle cx="12" cy="21" r="1" fill="currentColor" stroke="none" />
      <path d="m8 14 4 2.5" />
      <path d="M16 11.5 12 14" />
    {%- when 'thermometer' -%}
      <path d="M10 13.5V5a2 2 0 1 1 4 0v8.5a4 4 0 1 1-4 0z" />
      <path d="M12 9v6" />
    {%- when 'sliders' -%}
      <line x1="4" y1="8" x2="20" y2="8" />
      <line x1="4" y1="16" x2="20" y2="16" />
      <circle cx="9" cy="8" r="2.4" fill="currentColor" stroke="none" />
      <circle cx="15" cy="16" r="2.4" fill="currentColor" stroke="none" />
    {%- when 'droplet' -%}
      <path d="M12 3s5.5 6 5.5 10a5.5 5.5 0 0 1-11 0C6.5 9 12 3 12 3z" />
    {%- when 'droplet-off' -%}
      <path d="M7.3 10.3C6.8 11.4 6.5 12.3 6.5 13a5.5 5.5 0 0 0 9.4 3.9" />
      <path d="M10 5.5C11 4.2 12 3 12 3s5.5 6 5.5 10c0 .4-.05.8-.13 1.2" />
      <line x1="4" y1="3" x2="20" y2="20" />
    {%- when 'arrow-right' -%}
      <path d="M4 12h15" />
      <path d="m13 6 6 6-6 6" />
    {%- when 'arrow-down' -%}
      <path d="M12 4v15" />
      <path d="m6 13 6 6 6-6" />
    {%- when 'droplets' -%}
      <path d="M8 4s3.5 4 3.5 6.5a3.5 3.5 0 0 1-7 0C4.5 8 8 4 8 4z" />
      <path d="M16 10s3 3.5 3 5.8a3 3 0 0 1-6 0C13 13.5 16 10 16 10z" />
    {%- when 'package' -%}
      <path d="M21 8 12 3 3 8v8l9 5 9-5z" />
      <path d="M3 8l9 5 9-5" />
      <path d="M12 13v8" />
    {%- when 'shield' -%}
      <path d="M12 3 5 6v5c0 4.2 3 7.4 7 8 4-0.6 7-3.8 7-8V6z" />
      <path d="m9 12 2 2 4-4" />
    {%- when 'truck' -%}
      <path d="M3 6h11v9H3z" />
      <path d="M14 9h3.5L21 12v3h-7z" />
      <circle cx="7" cy="18" r="1.6" />
      <circle cx="17" cy="18" r="1.6" />
    {%- when 'leaf' -%}
      <path d="M11 20A7 7 0 0 1 4 13C4 7 11 4 20 4c0 9-3 16-9 16z" />
      <path d="M4 20c4-7 8-9 13-10" />
    {%- when 'check' -%}
      <path d="m5 12 4.5 4.5L19 7" />
    {%- when 'feather' -%}
      <path d="M20 4C11 4 4 11 4 20" />
      <path d="M20 4c0 8-6 13-12 13H4v-1C4 10 12 4 20 4z" />
      <path d="M9 15h6" />
    {%- when 'tent' -%}
      <path d="M12 4 3 20h18z" />
      <path d="M12 4v16" />
      <path d="m12 13-4 7" />
      <path d="m12 13 4 7" />
    {%- when 'umbrella' -%}
      <path d="M3 11c0-5 4-8 9-8s9 3 9 8z" />
      <path d="M12 11v7" />
      <path d="M12 18a2 2 0 0 0 3.2 1.5" />
    {%- when 'anchor' -%}
      <circle cx="12" cy="5" r="2.2" />
      <path d="M12 7.2V20" />
      <path d="M8 11h8" />
      <path d="M5 13a7 7 0 0 0 14 0" />
    {%- when 'van' -%}
      <path d="M2 7h11v8H2z" />
      <path d="M13 9h4l3 3.2V15h-7z" />
      <path d="M2 12h11" />
      <circle cx="7" cy="17.5" r="1.7" />
      <circle cx="16.5" cy="17.5" r="1.7" />
    {%- when 'sauna' -%}
      <path d="M7 14c0-2 2-2 2-4s-2-2-2-4" />
      <path d="M12 14c0-2 2-2 2-4s-2-2-2-4" />
      <path d="M17 14c0-2 2-2 2-4s-2-2-2-4" />
      <path d="M4 19h16" />
    {%- when 'paw' -%}
      <circle cx="6.5" cy="11" r="1.5" fill="currentColor" stroke="none" />
      <circle cx="10" cy="8" r="1.5" fill="currentColor" stroke="none" />
      <circle cx="14" cy="8" r="1.5" fill="currentColor" stroke="none" />
      <circle cx="17.5" cy="11" r="1.5" fill="currentColor" stroke="none" />
      <path d="M8.5 15.5c0-2 1.6-3.5 3.5-3.5s3.5 1.5 3.5 3.5c0 1.7-1.6 2.7-3.5 2.7s-3.5-1-3.5-2.7z" />
    {%- when 'utensils' -%}
      <path d="M7 3v6a2 2 0 0 0 4 0V3" />
      <path d="M9 9v12" />
      <path d="M16.5 3c1.8 1.5 1.8 5.5 0 7l-1 1v10" />
    {%- when 'spray' -%}
      <path d="M10 9h4l1.5 2.5V20a1 1 0 0 1-1 1h-5a1 1 0 0 1-1-1v-8.5z" />
      <path d="M10 9V5h3V3" />
      <path d="M15 4h2M18 3v2M20 4.5h1" />
    {%- when 'mail' -%}
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m3 7 9 6 9-6" />
    {%- when 'card' -%}
      <rect x="2.5" y="5" width="19" height="14" rx="2.5" />
      <path d="M2.5 9.5h19" />
      <path d="M6 14.5h4" />
    {%- when 'lock' -%}
      <rect x="5" y="11" width="14" height="9" rx="2" />
      <path d="M8 11V8a4 4 0 0 1 8 0v3" />
    {%- when 'sparkles' -%}
      <path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z" />
      <path d="M18 14l.7 1.8L20.5 16.5l-1.8.7L18 19l-.7-1.8L15.5 16.5l1.8-.7z" />
    {%- when 'daydream' -%}
      <path d="M8 11a3.2 3.2 0 0 1 .3-1.4A3 3 0 0 1 14 8.4 2.6 2.6 0 0 1 17.8 11 2.7 2.7 0 0 1 17 16.2H9.5A3 3 0 0 1 8 11z" />
      <circle cx="6.5" cy="18.5" r="1.1" fill="currentColor" stroke="none" />
      <circle cx="4.2" cy="21" r="0.7" fill="currentColor" stroke="none" />
    {%- when 'submerge' -%}
      <path d="M12 3v8" />
      <path d="m8.5 7.5 3.5 3.5 3.5-3.5" />
      <path d="M4 16c1.6-1.4 3.4-1.4 5 0s3.4 1.4 5 0 3.4-1.4 5 0" />
      <path d="M4 19.5c1.6-1.4 3.4-1.4 5 0s3.4 1.4 5 0 3.4-1.4 5 0" />
    {%- when 'shower' -%}
      <path d="M12 3v3" />
      <path d="M6.5 6h11l-1.5 3.6h-8z" />
      <path d="M9 13.5v1.8" />
      <path d="M12 15v2.4" />
      <path d="M15 13.5v1.8" />
    {%- else -%}
      <circle cx="12" cy="12" r="8" />
  {%- endcase -%}
</svg>
