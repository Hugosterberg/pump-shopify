<script>
  (function () {
    var root = document.getElementById('pp-reviews-{{ section.id }}');
    if (!root) return;

    var viewport = root.querySelector('[data-pp-jdgm-viewport]');
    var sources = root.querySelector('[data-pp-jdgm-sources]');
    var prevBtn = root.querySelector('[data-pp-jdgm-prev]');
    var nextBtn = root.querySelector('[data-pp-jdgm-next]');
    var track = root.querySelector('[data-pp-jdgm-track]');
    var emptyEl = root.querySelector('[data-pp-jdgm-empty]');
    if (!viewport || !prevBtn || !nextBtn || !track) return;

    var rail = null;
    var loading = false;
    var built = false;
    var REVIEW_SEL = [
      '.jdgm-rev',
      '.jdgm-carousel__item',
      '.jdgm-revs-carousel__item',
      '.jdgm-rev-card',
      '[data-review-id]',
      '.jdgm-all-reviews__review'
    ].join(',');

    function sleep(ms) {
      return new Promise(function (resolve) { setTimeout(resolve, ms); });
    }

    function reviewKey(el) {
      return (
        el.getAttribute('data-review-id') ||
        el.getAttribute('data-review-uuid') ||
        el.id ||
        (
          ((el.querySelector('.jdgm-rev__author, .jdgm-carousel__author, .jdgm-rev__author-wrapper') || {}).textContent || '') +
          '|' +
          ((el.querySelector('.jdgm-rev__timestamp') || {}).textContent || '') +
          '|' +
          ((el.querySelector('.jdgm-rev__body, .jdgm-carousel__content, .jdgm-rev__content, .jdgm-rev__title') || {}).textContent || '').slice(0, 90)
        )
      ).trim();
    }

    function polishIcon(icon) {
      if (!icon || icon.dataset.ppPolished === '1') return;
      var bg = (icon.getAttribute('style') || '') + ' ' + (window.getComputedStyle(icon).backgroundImage || '');
      var img = icon.querySelector('img');
      var src = img ? img.currentSrc || img.src || '' : '';
      var real = /gravatar|googleusercontent|fbcdn|cdn\.shopify|cloudinary|judge\.me\/(?:.*\/)?(?:uploads|media|profiles)/i.test(
        bg + ' ' + src
      );
      if (!real) {
        icon.classList.add('jdgm-rev__icon--blank');
        icon.style.setProperty('background-image', 'none', 'important');
        icon.querySelectorAll('svg, i, img').forEach(function (n) { n.remove(); });
      }
      icon.dataset.ppPolished = '1';
    }

    function reviewBodyText(el) {
      var body =
        el.querySelector('.jdgm-rev__body') ||
        el.querySelector('.jdgm-carousel__content') ||
        el.querySelector('.jdgm-rev__content');
      if (!body) return '';
      // Prefer body text, strip author/rating leftovers if content wrapper was used
      var clone = body.cloneNode(true);
      clone.querySelectorAll(
        '.jdgm-rev__author, .jdgm-rev__rating, .jdgm-rev__icon, .jdgm-rev__timestamp, .jdgm-rev__pics, .jdgm-rev__pic-link, .jdgm-star, .jdgm-rev__buyer-badge, .jdgm-rev__prod-title'
      ).forEach(function (n) { n.remove(); });
      return (clone.textContent || '').replace(/\s+/g, ' ').trim();
    }

    function isCompleteReview(el) {
      var body = reviewBodyText(el);
      if (body.length >= 8) return true;
      // Title-only reviews are rare but valid
      var title = ((el.querySelector('.jdgm-rev__title') || {}).textContent || '').replace(/\s+/g, ' ').trim();
      return title.length >= 8;
    }

    function decorateCard(rev) {
      if (!rev || rev.dataset.ppDecorated === '1') return;
      rev.classList.add('jdgm-rev');
      rev.style.setProperty('opacity', '1', 'important');
      rev.style.setProperty('visibility', 'visible', 'important');
      rev.style.setProperty('height', 'auto', 'important');
      rev.style.setProperty('min-height', '0', 'important');
      rev.style.removeProperty('display');
      // Strip decorative quote, loaders, and leftover chrome
      rev.querySelectorAll(
        '.pp-jdgm-quote, .pp-jdgm-sheen, .jdgm-spinner, .jdgm-loader, [class*="spinner"], [class*="loader"], [class*="loading"]'
      ).forEach(function (n) {
        // Never strip the review body / content itself
        if (n.classList && (n.classList.contains('jdgm-rev__body') || n.classList.contains('jdgm-rev__content'))) return;
        n.remove();
      });
      // Lone quote glyphs Judge.me / old builds leave in the corner
      rev.querySelectorAll('span, i, em, b, strong').forEach(function (el) {
        if (el.children.length) return;
        var t = (el.textContent || '').trim();
        if (t === '"' || t === '\u201C' || t === '\u201D' || t === '\u2018' || t === '\u2019' || t === "'") {
          el.remove();
        }
      });
      // Empty titles create a tall gap above the body
      rev.querySelectorAll('.jdgm-rev__title').forEach(function (title) {
        if (!(title.textContent || '').trim()) title.remove();
      });
      // Force body visible (Judge.me sometimes leaves opacity:0)
      rev.querySelectorAll('.jdgm-rev__body, .jdgm-rev__content, .jdgm-carousel__content, .jdgm-rev__rating, .jdgm-rev__title').forEach(function (el) {
        el.style.setProperty('opacity', '1', 'important');
        el.style.setProperty('visibility', 'visible', 'important');
      });
      polishIcon(rev.querySelector('.jdgm-rev__icon'));
      compactPhotos(rev);
      rev.dataset.ppDecorated = '1';
    }

    function resolveImgSrc(img) {
      if (!img) return '';
      var src =
        img.currentSrc ||
        img.getAttribute('src') ||
        img.getAttribute('data-src') ||
        img.getAttribute('data-lazy-src') ||
        img.getAttribute('data-original') ||
        '';
      if (!src || src.indexOf('data:image') === 0) {
        var srcset = img.getAttribute('srcset') || img.getAttribute('data-srcset') || '';
        if (srcset) {
          src = srcset.split(',')[0].trim().split(/\s+/)[0] || src;
        }
      }
      if (!src || src === '#' || src.indexOf('data:image') === 0) return '';
      return src;
    }

    function collectReviewImages(rev) {
      var seen = {};
      var out = [];
      var nodes = rev.querySelectorAll(
        '.jdgm-rev__pics img, .jdgm-rev__media img, .jdgm-rev__pictures img, .jdgm-rev__pic-link img, .jdgm-rev__pic-img, a.jdgm-rev__pic-link img'
      );
      Array.prototype.forEach.call(nodes, function (img) {
        // Skip author avatars
        if (img.closest('.jdgm-rev__icon, .jdgm-rev__author-wrapper')) return;
        var src = resolveImgSrc(img);
        if (!src || seen[src]) return;
        seen[src] = true;
        out.push({ img: img, src: src });
      });
      // Fallback: any linked image that looks like Judge.me media
      if (!out.length) {
        Array.prototype.forEach.call(rev.querySelectorAll('a[href*="judge.me"] img, a[href*="judgeme"] img'), function (img) {
          if (img.closest('.jdgm-rev__icon')) return;
          var src = resolveImgSrc(img);
          if (!src || seen[src]) return;
          seen[src] = true;
          out.push({ img: img, src: src });
        });
      }
      return out;
    }

    function compactPhotos(rev) {
      if (rev.dataset.ppThumbs === '1') return;

      var images = collectReviewImages(rev);
      // Remove empty photo containers / broken placeholders
      rev.querySelectorAll('.jdgm-rev__pics, .jdgm-rev__media, .jdgm-rev__pictures, .jdgm-rev__pic-line').forEach(function (el) {
        if (!el.querySelector('img[src], img[data-src], img[srcset], img[data-srcset]')) {
          el.remove();
        }
      });

      if (!images.length) {
        rev.dataset.ppThumbs = '1';
        return;
      }

      var strip = document.createElement('div');
      strip.className = 'pp-jdgm-thumbs';
      strip.dataset.ppThumbs = '1';
      var maxShow = 3;
      images.forEach(function (item, index) {
        if (index >= maxShow) return;
        var wrap = document.createElement('a');
        wrap.className = 'pp-jdgm-thumb';
        wrap.href = item.src;
        wrap.target = '_blank';
        wrap.rel = 'noopener noreferrer';
        var clone = document.createElement('img');
        clone.src = item.src;
        clone.alt = item.img.getAttribute('alt') || 'Recensionsbild';
        clone.loading = 'lazy';
        clone.decoding = 'async';
        wrap.appendChild(clone);
        strip.appendChild(wrap);
      });

      if (images.length > maxShow) {
        var more = document.createElement('span');
        more.className = 'pp-jdgm-thumb-more';
        more.textContent = '+' + (images.length - maxShow);
        strip.appendChild(more);
      }

      // Drop original photo nodes so we don't show duplicates / placeholders
      rev.querySelectorAll('.jdgm-rev__pics, .jdgm-rev__media, .jdgm-rev__pictures, .jdgm-rev__pic-line').forEach(function (el) {
        el.remove();
      });
      rev.querySelectorAll('a.jdgm-rev__pic-link').forEach(function (el) {
        if (!el.closest('.pp-jdgm-thumbs')) el.remove();
      });

      rev.appendChild(strip);
      rev.classList.add('pp-jdgm-has-photos');
      rev.dataset.ppThumbs = '1';
    }

    function getScroller() {
      return rail || viewport;
    }

    function cardStep(scroller) {
      var card = scroller.querySelector('.jdgm-rev');
      if (!card) return Math.min(scroller.clientWidth * 0.9, 360);
      var style = window.getComputedStyle(scroller);
      var gap = parseFloat(style.columnGap || style.gap || '18') || 18;
      return card.getBoundingClientRect().width + gap;
    }

    function scrollByDir(dir) {
      var scroller = getScroller();
      if (!scroller) return;
      var step = cardStep(scroller);
      var max = Math.max(0, scroller.scrollWidth - scroller.clientWidth);
      if (max < 8) return;
      if (dir > 0 && scroller.scrollLeft >= max - 6) {
        scroller.scrollTo({ left: 0, behavior: 'smooth' });
        return;
      }
      if (dir < 0 && scroller.scrollLeft <= 6) {
        scroller.scrollTo({ left: max, behavior: 'smooth' });
        return;
      }
      scroller.scrollBy({ left: dir * step, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', function () { scrollByDir(-1); });
    nextBtn.addEventListener('click', function () { scrollByDir(1); });

    function hydrateLazyImages(scope) {
      if (!scope) return;
      scope.querySelectorAll('img').forEach(function (img) {
        var src = resolveImgSrc(img);
        if (src && (!img.getAttribute('src') || img.getAttribute('src').indexOf('data:image') === 0)) {
          img.setAttribute('src', src);
        }
      });
    }

    function collectFromScope(scope, map) {
      if (!scope) return;
      hydrateLazyImages(scope);
      scope.querySelectorAll(REVIEW_SEL).forEach(function (rev) {
        if (rev.closest('.pp-jdgm-carousel__rail')) return;
        // Skip nested wrappers that aren't actual review cards
        if (rev.querySelector(REVIEW_SEL) && !rev.classList.contains('jdgm-rev') && !rev.hasAttribute('data-review-id')) {
          return;
        }
        if (!isCompleteReview(rev)) return;
        var key = reviewKey(rev);
        if (!key || key === '|' || key === '||') return;
        var clone = rev.cloneNode(true);
        var bodyLen = reviewBodyText(clone).length;
        // Prefer the clone with more body text if we already have a stub
        if (map.has(key)) {
          var existingLen = reviewBodyText(map.get(key)).length;
          if (bodyLen <= existingLen) return;
        }
        map.set(key, clone);
      });
    }

    function buildRail(map) {
      if (!map.size) return false;
      if (rail) rail.remove();
      rail = document.createElement('div');
      rail.className = 'pp-jdgm-carousel__rail';
      rail.setAttribute('data-pp-jdgm-rail', '');
      map.forEach(function (node) {
        if (!isCompleteReview(node)) return;
        decorateCard(node);
        // Final guard: drop cards that still have no readable copy
        if (!isCompleteReview(node)) return;
        rail.appendChild(node);
      });
      if (!rail.children.length) {
        rail.remove();
        rail = null;
        return false;
      }
      track.appendChild(rail);
      root.classList.add('is-ready');
      built = true;
      if (emptyEl) emptyEl.hidden = true;
      return true;
    }

    function findNextPageButton(scope) {
      var area = scope || sources || root;
      var current = area.querySelector('.jdgm-paginate__page.jdgm-curt, .jdgm-paginate__page.is-active, .jdgm-paginate__page[aria-current="page"]');
      if (current && current.nextElementSibling && current.nextElementSibling.classList.contains('jdgm-paginate__page')) {
        return current.nextElementSibling;
      }
      return (
        area.querySelector('.jdgm-paginate__next-page:not(.jdgm-disabled):not([disabled])') ||
        area.querySelector('a.jdgm-paginate__load-more, button.jdgm-paginate__load-more, .jdgm-link--load-more')
      );
    }

    async function waitForFirstReviews() {
      for (var i = 0; i < 50; i++) {
        var host = sources || root;
        if (host.querySelector(REVIEW_SEL)) return true;
        await sleep(160);
      }
      return false;
    }

    async function paginateSources(map) {
      if (!sources) return;
      var widgets = sources.querySelectorAll('.jdgm-widget, .jdgm-review-widget, .jdgm-rev-widg');
      var list = widgets.length ? Array.prototype.slice.call(widgets) : [sources];

      for (var w = 0; w < list.length; w++) {
        var widget = list[w];
        for (var i = 0; i < 12; i++) {
          var before = map.size;
          collectFromScope(widget, map);
          var next = findNextPageButton(widget);
          if (!next) break;
          try { next.click(); } catch (e) {}
          await sleep(380);
          for (var t = 0; t < 10; t++) {
            collectFromScope(widget, map);
            if (map.size > before) break;
            await sleep(100);
          }
          if (map.size === before) break;
        }
      }
    }

    async function loadAllPages() {
      if (loading || built) return;
      loading = true;
      var map = new Map();

      var ready = await waitForFirstReviews();
      if (ready) {
        // Give Judge.me a beat to attach review photos after text cards
        await sleep(450);
        hydrateLazyImages(sources || root);
        collectFromScope(sources || root, map);
        await paginateSources(map);
        hydrateLazyImages(sources || root);
        collectFromScope(sources || root, map);
      }

      if (map.size > 0) {
        buildRail(map);
      } else if (emptyEl) {
        emptyEl.hidden = false;
      }

      loading = false;
    }

    // Judge.me often hydrates after its own script boots
    loadAllPages();
    window.setTimeout(function () { if (!built) loadAllPages(); }, 1200);
    window.setTimeout(function () { if (!built) loadAllPages(); }, 3000);
    window.addEventListener('load', function () {
      if (!built) loadAllPages();
    });

    if (sources) {
      var observer = new MutationObserver(function () {
        if (built) return;
        if (loading) return;
        requestAnimationFrame(function () {
          if (!built && !loading) loadAllPages();
        });
      });
      observer.observe(sources, { childList: true, subtree: true });
    }
  })();
</script>

