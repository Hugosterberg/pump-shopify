{%- liquid
  assign review_scope = section.settings.review_scope | default: 'all_shop'
  assign review_product = section.settings.product
  if review_product == blank and section.settings.product_handle != blank
    assign review_product = all_products[section.settings.product_handle]
  endif

  assign shop_rating = shop.metafields.judgeme.all_reviews_rating
  assign shop_count = shop.metafields.judgeme.all_reviews_count
  assign featured_carousel = shop.metafields.judgeme.featured_carousel

  assign rating_value = blank
  assign rating_count = blank
  assign rating_scale = 5
  assign summary_label = blank

  if review_scope == 'all_shop'
    if shop_rating != blank
      assign rating_value = shop_rating.value | default: shop_rating
    endif
    if shop_count != blank
      assign rating_count = shop_count.value | default: shop_count
    endif
    assign summary_label = section.settings.all_products_label | default: 'från alla våra produkter'
  elsif review_product != blank
    if review_product.metafields.reviews.rating.value != blank
      assign rating_value = review_product.metafields.reviews.rating.value.rating
      assign rating_scale = review_product.metafields.reviews.rating.value.scale_max | default: 5
    endif
    if review_product.metafields.reviews.rating_count != blank
      assign rating_count = review_product.metafields.reviews.rating_count.value | default: review_product.metafields.reviews.rating_count
    endif
    assign summary_label = review_product.title
  endif

  if rating_value != blank
    assign rating_display = rating_value | times: 1.0 | round: 1
    assign rating_rounded = rating_value | round
  else
    assign rating_display = blank
    assign rating_rounded = 5
  endif

  assign product_ids_csv = ''
  assign source_products = ''
  if review_scope == 'all_shop'
    if section.settings.products != blank and section.settings.products.size > 0
      assign source_products = section.settings.products
    endif
  elsif review_product != blank
    assign product_ids_csv = review_product.id | append: ''
  endif
-%}

<div
  id="pp-reviews-{{ section.id }}"
  class="pp-jdgm-carousel full-width"
  data-pp-jdgm-carousel
  data-review-scope="{{ review_scope }}"
  style="
    --jc-bg: {{ section.settings.background_color }};
    --jc-surface: {{ section.settings.surface_color }};
    --jc-text: {{ section.settings.text_color }};
    --jc-muted: {{ section.settings.muted_text_color }};
    --jc-accent: {{ section.settings.accent_color }};
  "
>
  <div class="pp-jdgm-carousel__inner">
    {% if section.settings.heading != blank or section.settings.eyebrow != blank %}
      <header class="pp-jdgm-carousel__header">
        {% if section.settings.eyebrow != blank %}
          <p class="pp-jdgm-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="pp-jdgm-carousel__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="pp-jdgm-carousel__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if rating_display != blank or rating_count != blank %}
      <div class="pp-jdgm-carousel__summary" aria-label="Sammanfattning av omdömen">
        {% if rating_display != blank %}
          <div class="pp-jdgm-carousel__score">
            <span class="pp-jdgm-carousel__score-number">{{ rating_display }}</span>
            <div class="pp-jdgm-carousel__stars" role="img" aria-label="{{ rating_display }} av {{ rating_scale }} stjärnor">
              {% for i in (1..5) %}
                <span class="pp-jdgm-carousel__star{% if i > rating_rounded %} pp-jdgm-carousel__star--empty{% endif %}" aria-hidden="true">★</span>
              {% endfor %}
            </div>
          </div>
        {% endif %}
        {% if rating_count != blank %}
          <p class="pp-jdgm-carousel__count">
            Baserat på <strong>{{ rating_count }}</strong>
            {% if rating_count == 1 %}omdöme{% else %}omdömen{% endif %}
            {% if summary_label != blank %}
              {{ summary_label }}
            {% endif %}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="pp-jdgm-carousel__stage">
      <button
        type="button"
        class="pp-jdgm-carousel__nav pp-jdgm-carousel__nav--prev"
        data-pp-jdgm-prev
        aria-label="Föregående omdömen"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="pp-jdgm-carousel__viewport" data-pp-jdgm-viewport>
        {%- comment -%}
          Always seed with real product review widgets (DOM). Featured carousel alone
          often won't hydrate cards here, and Judge.me's public API now requires auth.
        {%- endcomment -%}
        <div
          class="pp-jdgm-carousel__sources"
          data-pp-jdgm-sources
          aria-hidden="true"
        >
          {% if review_scope == 'all_shop' %}
            {% if review_product != blank and review_product.metafields.judgeme.widget != blank %}
              <div
                class="jdgm-widget jdgm-review-widget"
                id="judgeme_product_reviews_{{ section.id }}_{{ review_product.id }}"
                data-id="{{ review_product.id }}"
                data-product-title="{{ review_product.title | escape }}"
              >
                {{ review_product.metafields.judgeme.widget }}
              </div>
            {% endif %}

            {% if source_products != blank %}
              {% for p in source_products %}
                {% if review_product != blank and p.id == review_product.id %}{% continue %}{% endif %}
                {% if p.metafields.judgeme.widget != blank %}
                  <div
                    class="jdgm-widget jdgm-review-widget"
                    id="judgeme_product_reviews_{{ section.id }}_{{ p.id }}"
                    data-id="{{ p.id }}"
                    data-product-title="{{ p.title | escape }}"
                  >
                    {{ p.metafields.judgeme.widget }}
                  </div>
                {% endif %}
              {% endfor %}
            {% else %}
              {% for p in collections.all.products limit: 24 %}
                {% if review_product != blank and p.id == review_product.id %}{% continue %}{% endif %}
                {% if p.metafields.judgeme.widget != blank %}
                  <div
                    class="jdgm-widget jdgm-review-widget"
                    id="judgeme_product_reviews_{{ section.id }}_{{ p.id }}"
                    data-id="{{ p.id }}"
                    data-product-title="{{ p.title | escape }}"
                  >
                    {{ p.metafields.judgeme.widget }}
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
          {% elsif review_product != blank and review_product.metafields.judgeme.widget != blank %}
            <div
              class="jdgm-widget jdgm-review-widget"
              id="judgeme_product_reviews_{{ section.id }}"
              data-id="{{ review_product.id }}"
              data-product-title="{{ review_product.title | escape }}"
            >
              {{ review_product.metafields.judgeme.widget }}
            </div>
          {% endif %}

          {% if featured_carousel != blank %}
            <div class="jdgm-widget pp-jdgm-featured-source" data-pp-jdgm-featured>
              {{ featured_carousel }}
            </div>
          {% endif %}
        </div>

        <div
          class="pp-jdgm-carousel__track"
          data-pp-jdgm-track
          data-id="{{ review_product.id | default: '' }}"
        ></div>

        {% if request.design_mode %}
          <p class="pp-jdgm-carousel__empty" data-pp-jdgm-empty hidden>
            Inga omdömen hittades ännu. Kontrollera att Judge.me Core är aktiverat och att produkterna har omdömen.
          </p>
        {% endif %}
      </div>

      <button
        type="button"
        class="pp-jdgm-carousel__nav pp-jdgm-carousel__nav--next"
        data-pp-jdgm-next
        aria-label="Nästa omdömen"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  .pp-jdgm-carousel {
    --jc-ease: cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    isolation: isolate;
    padding-block: clamp(36px, 5vw, 52px);
    padding-inline: var(--page-margin, 20px);
    background:
      radial-gradient(58% 48% at 50% -8%, color-mix(in srgb, var(--jc-accent, #2dd4bf) 22%, transparent), transparent 68%),
      radial-gradient(42% 36% at 92% 88%, color-mix(in srgb, #38bdf8 12%, transparent), transparent 72%),
      radial-gradient(36% 30% at 8% 70%, color-mix(in srgb, var(--jc-accent, #2dd4bf) 8%, transparent), transparent 70%),
      linear-gradient(180deg, #05090c 0%, var(--jc-bg, #071014) 42%, #060b10 100%);
    color: var(--jc-text, #f6f7f2);
    overflow: hidden;
  }

  .pp-jdgm-carousel::before {
    content: '';
    position: absolute;
    inset: -20% -10%;
    background:
      conic-gradient(from 210deg at 50% 40%, transparent 0deg, color-mix(in srgb, var(--jc-accent, #2dd4bf) 7%, transparent) 55deg, transparent 110deg, color-mix(in srgb, #38bdf8 6%, transparent) 180deg, transparent 250deg);
    animation: pp-jdgm-aurora 18s linear infinite;
    pointer-events: none;
    z-index: 0;
    opacity: 0.7;
  }

  .pp-jdgm-carousel::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.035) 1px, transparent 0);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 75% 65% at 50% 35%, #000 10%, transparent 78%);
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  @keyframes pp-jdgm-aurora {
    to { transform: rotate(360deg); }
  }

  .pp-jdgm-carousel__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .pp-jdgm-carousel__header {
    text-align: center;
    margin-bottom: 14px;
  }

  .pp-jdgm-carousel__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 8px;
    font-size: 0.76rem;
    font-weight: 650;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--jc-accent, #2dd4bf);
    text-shadow: 0 0 24px color-mix(in srgb, var(--jc-accent, #2dd4bf) 35%, transparent);
  }

  .pp-jdgm-carousel__eyebrow::before,
  .pp-jdgm-carousel__eyebrow::after {
    content: '';
    width: 36px;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--jc-accent, #2dd4bf) 80%, #fff));
  }

  .pp-jdgm-carousel__eyebrow::after {
    background: linear-gradient(90deg, color-mix(in srgb, var(--jc-accent, #2dd4bf) 80%, #fff), transparent);
  }

  .pp-jdgm-carousel__heading {
    margin: 0 0 6px;
    font-size: clamp(1.45rem, 3.2vw, 2rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    font-weight: 750;
    background: linear-gradient(180deg, #ffffff 20%, color-mix(in srgb, var(--jc-text, #f6f7f2) 78%, var(--jc-accent, #2dd4bf)));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .pp-jdgm-carousel__subheading {
    margin: 0 auto;
    max-width: 38rem;
    color: var(--jc-muted, #9aa8a2);
    line-height: 1.5;
    font-size: 0.92rem;
  }

  .pp-jdgm-carousel__summary {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin: 0 auto 16px;
    padding: 12px 20px 11px;
    max-width: 26rem;
    border-radius: 18px;
    background:
      linear-gradient(145deg, rgba(255,255,255,0.07), transparent 42%),
      linear-gradient(165deg, color-mix(in srgb, var(--jc-accent, #2dd4bf) 18%, #121c24), #0c141a 70%);
    border: 1px solid color-mix(in srgb, var(--jc-accent, #2dd4bf) 34%, transparent);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.1) inset,
      0 0 0 1px rgba(0, 0, 0, 0.35) inset,
      0 24px 60px -28px color-mix(in srgb, var(--jc-accent, #2dd4bf) 55%, #000),
      0 0 80px -40px color-mix(in srgb, var(--jc-accent, #2dd4bf) 50%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    overflow: hidden;
  }

  .pp-jdgm-carousel__summary::before {
    content: '';
    position: absolute;
    inset: -40% auto auto 50%;
    width: 160px;
    height: 160px;
    transform: translateX(-50%);
    background: radial-gradient(circle, color-mix(in srgb, var(--jc-accent, #2dd4bf) 35%, transparent), transparent 68%);
    pointer-events: none;
  }

  .pp-jdgm-carousel__score {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pp-jdgm-carousel__score-number {
    font-size: clamp(1.65rem, 3.5vw, 2rem);
    font-weight: 820;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(180deg, #fff, color-mix(in srgb, #fff 70%, var(--jc-accent, #2dd4bf)));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .pp-jdgm-carousel__stars {
    display: flex;
    gap: 2px;
    font-size: 1rem;
    color: var(--jc-accent, #2dd4bf);
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--jc-accent, #2dd4bf) 45%, transparent));
  }

  .pp-jdgm-carousel__star {
    display: inline-block;
    animation: pp-jdgm-star-pop 0.55s var(--jc-ease) both;
  }

  .pp-jdgm-carousel__star:nth-child(2) { animation-delay: 0.05s; }
  .pp-jdgm-carousel__star:nth-child(3) { animation-delay: 0.1s; }
  .pp-jdgm-carousel__star:nth-child(4) { animation-delay: 0.15s; }
  .pp-jdgm-carousel__star:nth-child(5) { animation-delay: 0.2s; }

  @keyframes pp-jdgm-star-pop {
    from { opacity: 0; transform: scale(0.6) translateY(4px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .pp-jdgm-carousel__star--empty {
    color: color-mix(in srgb, var(--jc-text, #f6f7f2) 22%, transparent);
    filter: none;
  }

  .pp-jdgm-carousel__count {
    position: relative;
    margin: 0;
    font-size: 0.8rem;
    color: var(--jc-muted, #9aa8a2);
    text-align: center;
  }

  .pp-jdgm-carousel__count strong {
    color: var(--jc-text, #f6f7f2);
    font-weight: 700;
  }

  .pp-jdgm-carousel__stage {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
  }

  .pp-jdgm-carousel__nav {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--jc-accent, #2dd4bf) 45%, transparent);
    background:
      linear-gradient(160deg, rgba(255,255,255,0.08), transparent 45%),
      linear-gradient(165deg, color-mix(in srgb, var(--jc-accent, #2dd4bf) 18%, #121a22), #0a1015);
    color: var(--jc-text, #f6f7f2);
    cursor: pointer;
    box-shadow: 0 10px 28px -16px rgba(0,0,0,0.85);
    transition: transform 0.25s var(--jc-ease), border-color 0.2s ease, box-shadow 0.25s ease, color 0.2s ease;
  }

  .pp-jdgm-carousel__nav svg {
    width: 18px;
    height: 18px;
  }

  .pp-jdgm-carousel__nav:hover {
    transform: translateY(-3px) scale(1.04);
    color: #fff;
    border-color: var(--jc-accent, #2dd4bf);
    box-shadow:
      0 14px 32px -14px color-mix(in srgb, var(--jc-accent, #2dd4bf) 70%, #000),
      0 0 0 4px color-mix(in srgb, var(--jc-accent, #2dd4bf) 12%, transparent);
  }

  .pp-jdgm-carousel__nav:active {
    transform: translateY(-1px) scale(0.98);
  }

  .pp-jdgm-carousel__viewport {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    min-height: 0;
    padding-block: 6px 10px;
    mask-image: linear-gradient(90deg, transparent, #000 2.5%, #000 97.5%, transparent);
  }

  /* Keep sources off-screen but renderable so Judge.me can hydrate widgets */
  .pp-jdgm-carousel__sources {
    position: absolute;
    left: -10000px;
    top: 0;
    width: 720px;
    height: 600px;
    overflow: auto;
    opacity: 0.01;
    pointer-events: none;
  }

  .pp-jdgm-carousel.is-ready .pp-jdgm-carousel__sources {
    display: none !important;
  }

  .pp-jdgm-carousel__track {
    position: relative;
    min-height: 1px;
  }

  .pp-jdgm-carousel__rail {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 14px;
    margin: 0;
    padding: 4px 4px 18px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .pp-jdgm-carousel__rail::-webkit-scrollbar {
    display: none;
  }

  .pp-jdgm-carousel .jdgm-rev-widg__header,
  .pp-jdgm-carousel .jdgm-row-stars,
  .pp-jdgm-carousel .jdgm-histogram,
  .pp-jdgm-carousel .jdgm-write-rev-link,
  .pp-jdgm-carousel .jdgm-rev-widg__summary,
  .pp-jdgm-carousel .jdgm-sort-dropdown-wrapper,
  .pp-jdgm-carousel .jdgm-rev-widg__sort-wrapper,
  .pp-jdgm-carousel .jdgm-form,
  .pp-jdgm-carousel .jdgm-rev-widg__title,
  .pp-jdgm-carousel .jdgm-carousel__header,
  .pp-jdgm-carousel .jdgm-carousel__title,
  .pp-jdgm-carousel .jdgm-all-reviews-rating,
  .pp-jdgm-carousel .jdgm-carousel-title,
  .pp-jdgm-carousel .jdgm-gallery,
  .pp-jdgm-carousel .jdgm-link--all-reviews {
    display: none !important;
  }

  .pp-jdgm-carousel .jdgm-paginate {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
    opacity: 0 !important;
    pointer-events: auto !important;
  }

  .pp-jdgm-carousel .jdgm-rev-widg__body,
  .pp-jdgm-carousel .jdgm-rev-widg__reviews,
  .pp-jdgm-carousel .jdgm-carousel__item-wrapper,
  .pp-jdgm-carousel .jdgm-carousel__items {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    gap: 20px !important;
    margin: 0 !important;
    padding: 4px 2px 18px !important;
  }

  .pp-jdgm-carousel .jdgm-rev,
  .pp-jdgm-carousel__rail .jdgm-rev,
  .pp-jdgm-carousel .jdgm-carousel__item,
  .pp-jdgm-carousel__rail .jdgm-carousel__item {
    --bubble-ink: #0d1f1a;
    --bubble-muted: #61756e;
    flex: 0 0 min(100%, 300px) !important;
    width: min(100%, 300px) !important;
    max-width: min(100%, 300px) !important;
    min-height: 0;
    height: auto !important;
    scroll-snap-align: start;
    position: relative;
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
    margin: 0 0 8px !important;
    padding: 12px 14px 14px !important;
    opacity: 1 !important;
    visibility: visible !important;
    border: 1px solid rgba(255, 255, 255, 0.72) !important;
    border-radius: 22px 22px 22px 16px !important;
    background:
      linear-gradient(145deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.72) 28%, transparent 55%),
      linear-gradient(168deg, #ffffff 0%, #f5faf8 48%, #e7f3ef 100%) !important;
    color: var(--bubble-ink) !important;
    box-shadow:
      0 1.5px 0 rgba(255, 255, 255, 0.95) inset,
      0 0 0 1px rgba(13, 148, 136, 0.06) inset,
      0 28px 56px -30px rgba(0, 0, 0, 0.82),
      0 12px 28px -18px rgba(45, 212, 191, 0.4);
    transition:
      transform 0.35s var(--jc-ease),
      box-shadow 0.35s ease;
    animation: pp-jdgm-bubble-in-a 0.65s var(--jc-ease) both;
    will-change: transform;
  }

  .pp-jdgm-carousel .jdgm-rev:nth-child(even),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(even),
  .pp-jdgm-carousel .jdgm-carousel__item:nth-child(even),
  .pp-jdgm-carousel__rail .jdgm-carousel__item:nth-child(even) {
    animation-name: pp-jdgm-bubble-in-b;
  }

  .pp-jdgm-carousel .jdgm-rev:nth-child(2),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(2) { animation-delay: 0.07s; }
  .pp-jdgm-carousel .jdgm-rev:nth-child(3),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(3) { animation-delay: 0.14s; }
  .pp-jdgm-carousel .jdgm-rev:nth-child(4),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(4) { animation-delay: 0.21s; }
  .pp-jdgm-carousel .jdgm-rev:nth-child(5),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(5) { animation-delay: 0.28s; }

  @keyframes pp-jdgm-bubble-in-a {
    from { opacity: 0; transform: translateY(18px) rotate(-1.2deg) scale(0.96); }
    to { opacity: 1; transform: translateY(0) rotate(-0.4deg) scale(1); }
  }

  @keyframes pp-jdgm-bubble-in-b {
    from { opacity: 0; transform: translateY(18px) rotate(1.2deg) scale(0.96); }
    to { opacity: 1; transform: translateY(0) rotate(0.45deg) scale(1); }
  }

  .pp-jdgm-carousel .jdgm-rev:nth-child(odd),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(odd) {
    transform: rotate(-0.4deg);
  }

  .pp-jdgm-carousel .jdgm-rev:nth-child(even),
  .pp-jdgm-carousel__rail .jdgm-rev:nth-child(even) {
