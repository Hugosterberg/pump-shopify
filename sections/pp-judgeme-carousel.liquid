{
  "name": "Judge.me carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Omdömen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Det här säger våra kunder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Verifierade omdömen från Judge.me"
    },
    {
      "type": "select",
      "id": "review_scope",
      "label": "Review source",
      "options": [
        { "value": "all_shop", "label": "All products (store-wide)" },
        { "value": "single_product", "label": "Single product" }
      ],
      "default": "all_shop",
      "info": "All products uses Judge.me shop rating + featured carousel, then merges reviews from your catalog via Judge.me’s public widget API."
    },
    {
      "type": "text",
      "id": "all_products_label",
      "label": "Store-wide summary label",
      "default": "från alla våra produkter"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products to pull reviews from",
      "limit": 6,
      "info": "Recommended: 3–6 products. Leave empty to use up to 6 products from the All collection."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Single product (when scope = Single)",
      "info": "Only used when Review source is Single product."
    },
    {
      "type": "text",
      "id": "product_handle",
      "label": "Fallback product handle",
      "default": "portabel-dusch"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show “See all reviews” button",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Se alla omdömen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link",
      "info": "Paste your Judge.me Reviews store URL (https://judge.me/reviews/stores/…) or a Shopify page. Leave empty to use /pages/recensioner, /pages/reviews, or the portable shower product."
    },
    {
      "type": "text",
      "id": "cta_hint",
      "label": "CTA hint",
      "default": "Verifierade omdömen via Judge.me"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Judge.me carousel"
    }
  ]
}
