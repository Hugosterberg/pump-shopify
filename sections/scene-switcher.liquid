{% comment %}
  Scene switcher — the product stays put while the background crossfades
  between environments (camping, boat, sauna...). Shows portability as a
  feeling. Pure CSS crossfade with a per-section keyframe computed from the
  number of scenes.
{% endcomment %}

{%- liquid
  assign scene_count = section.blocks.size
  assign slot = section.settings.seconds_per_scene
  assign total = slot | times: scene_count
  assign visible = 100 | divided_by: scene_count
  assign hold_end = visible | minus: 5
  assign has_product = false
  if section.settings.product_image != blank
    assign has_product = true
  endif
-%}

{% if scene_count > 0 %}
  <style>
    @keyframes scene-cycle-{{ section.id }} {
      0% { opacity: 0; }
      5% { opacity: 1; }
      {{ hold_end }}% { opacity: 1; }
      {{ visible }}% { opacity: 0; }
      100% { opacity: 0; }
    }
  </style>
{% endif %}

<div
  class="scenes full-width{% unless has_product %} scenes--text-only{% endunless %}"
  style="
    --scn-text: {{ section.settings.text_color }};
    --scn-accent: {{ section.settings.accent_color }};
    --scn-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --scn-min-height: {{ section.settings.min_height }}px;
  "
>
  <div class="scenes__stage">
    {% for block in section.blocks %}
      <div
        class="scenes__bg"
        {{ block.shopify_attributes }}
        style="
          {% if block.settings.image != blank %}background-image: url({{ block.settings.image | image_url: width: 1800 }});{% endif %}
          animation-name: scene-cycle-{{ section.id }};
          animation-duration: {{ total }}s;
          animation-delay: -{{ forloop.index0 | times: slot }}s;
        "
      ></div>
    {% endfor %}

    <div class="scenes__overlay" aria-hidden="true"></div>

    {% if section.settings.product_image != blank %}
      {{
        section.settings.product_image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          widths: '300, 500, 700, 900',
          sizes: '(min-width: 750px) 30vw, 60vw',
          class: 'scenes__product',
          alt: section.settings.heading
      }}
    {% endif %}

    <div class="scenes__content">
      {% if section.settings.eyebrow != blank %}
        <p class="scenes__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="scenes__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="scenes__labels" aria-hidden="true">
          {% for block in section.blocks %}
            <span
              class="scenes__label"
              style="
                animation-name: scene-cycle-{{ section.id }};
                animation-duration: {{ total }}s;
                animation-delay: -{{ forloop.index0 | times: slot }}s;
              "
            >{{ block.settings.label }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .scenes {
    padding-inline: var(--page-margin, 20px);
    padding-block: 12px 22px;
    background-color: #060c11;
  }

  .scenes__stage {
    position: relative;
    max-width: min(40rem, 100%);
    margin-inline: auto;
    min-height: var(--scn-min-height, 260px);
    border-radius: 24px;
    overflow: hidden;
    isolation: isolate;
  }

  .scenes__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: opacity;
  }

  .scenes__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(6, 12, 17, calc(var(--scn-overlay, 0.45) * 0.7)) 0%,
      rgba(6, 12, 17, var(--scn-overlay, 0.45)) 100%
    );
  }

  .scenes__product {
    position: absolute;
    z-index: 1;
    left: 50%;
    bottom: 72px;
    transform: translateX(-50%);
    max-width: min(42%, 240px);
    height: auto;
    filter: drop-shadow(0 24px 34px rgba(0, 0, 0, 0.55));
  }

  .scenes__content {
    position: absolute;
    z-index: 2;
    left: 0;
    bottom: 0;
    right: 0;
    padding: 22px 24px;
    text-align: left;
    color: var(--scn-text, #f6f7f2);
  }

  .scenes__eyebrow {
    margin: 0 0 8px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--scn-accent, #2dd4bf);
  }

  .scenes__heading {
    margin: 0;
    font-size: clamp(1.6rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

  .scenes__labels {
    position: relative;
    min-height: 2.6em;
    margin-top: 10px;
  }

  .scenes__label {
    position: absolute;
    left: 0;
    top: 0;
    max-width: 100%;
    font-size: clamp(1.1rem, 3vw, 1.6rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--scn-accent, #2dd4bf);
    opacity: 0;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    text-wrap: balance;
  }

  /* No product image: hug the copy instead of forcing a tall empty stage */
  .scenes--text-only .scenes__stage {
    min-height: 0;
  }

  .scenes--text-only .scenes__content {
    position: relative;
    padding: 28px 24px 24px;
  }

  .scenes--text-only .scenes__labels {
    min-height: 1.5em;
    margin-top: 8px;
  }

  @media screen and (max-width: 749px) {
    .scenes {
      padding-block: 8px 12px;
    }

    .scenes__stage {
      min-height: var(--scn-min-height, 220px);
      border-radius: 18px;
    }

    .scenes--text-only .scenes__stage {
      min-height: 0;
    }

    .scenes--text-only .scenes__content {
      padding: 20px 16px 18px;
    }

    .scenes__product {
      bottom: auto;
      top: 28%;
      max-width: min(48%, 180px);
    }

    .scenes__content {
      padding: 16px 16px 18px;
    }

    .scenes__heading {
      font-size: clamp(1.35rem, 6vw, 1.75rem);
    }

    .scenes__label {
      font-size: clamp(0.95rem, 2.8vw, 1.3rem);
    }
  }

  @media screen and (min-width: 750px) {
    .scenes {
      padding-block: 16px 28px;
    }

    .scenes__product {
      bottom: 88px;
      max-width: min(36%, 260px);
    }

    .scenes__content {
      padding: 28px 32px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scenes__bg,
    .scenes__label {
      animation: none;
    }

    .scenes__bg:first-child,
    .scenes__label:first-child {
      opacity: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Scene switcher",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Överallt" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "En dusch. Oändligt många platser." },
    { "type": "image_picker", "id": "product_image", "label": "Product image (transparent PNG)" },
    {
      "type": "range",
      "id": "seconds_per_scene",
      "label": "Seconds per scene",
      "min": 2,
      "max": 7,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 200,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 240
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "scene",
      "name": "Scene",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "label", "label": "Label", "default": "för camping" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Scene switcher",
      "blocks": [
        { "type": "scene", "settings": { "label": "för camping" } },
        { "type": "scene", "settings": { "label": "för båten" } },
        { "type": "scene", "settings": { "label": "för bastun" } },
        { "type": "scene", "settings": { "label": "för stranden" } }
      ]
    }
  ]
}
{% endschema %}
