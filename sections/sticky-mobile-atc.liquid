{% liquid
  assign sticky_product = section.settings.product
  if sticky_product == blank and product != blank
    assign sticky_product = product
  endif

  assign target_id = 'product-showcase'
  if request.page_type == 'product'
    assign target_id = 'main-product'
  elsif section.settings.target_id != blank
    assign target_id = section.settings.target_id
  endif

  assign sticky_variant = sticky_product.selected_or_first_available_variant
%}

{% if sticky_product != blank %}
  <div
    class="sticky-mobile-atc full-width"
    style="
      --satc-bg: {{ section.settings.background_color }};
      --satc-text: {{ section.settings.text_color }};
      --satc-accent: {{ section.settings.accent_color }};
      --satc-accent-ink: {{ section.settings.accent_text_color }};
    "
    data-sticky-atc
    data-target-id="{{ target_id }}"
    data-on-product-page="{% if request.page_type == 'product' %}true{% else %}false{% endif %}"
  >
    <div class="sticky-mobile-atc__inner">
      {% if sticky_product.featured_image %}
        <a class="sticky-mobile-atc__thumb" href="#{{ target_id }}" aria-hidden="true" tabindex="-1">
          {{
            sticky_product.featured_image
            | image_url: width: 120
            | image_tag: loading: 'lazy', widths: '56, 120', sizes: '48px', alt: ''
          }}
        </a>
      {% endif %}
      <div class="sticky-mobile-atc__info">
        <span class="sticky-mobile-atc__title">{{ sticky_product.title }}</span>
        <div class="sticky-mobile-atc__meta">
          <span class="sticky-mobile-atc__price" data-sticky-price>{{ sticky_variant.price | money }}</span>
          {% if sticky_variant.compare_at_price > sticky_variant.price %}
            <s class="sticky-mobile-atc__compare" data-sticky-compare>{{ sticky_variant.compare_at_price | money }}</s>
          {% else %}
            <s class="sticky-mobile-atc__compare" data-sticky-compare hidden></s>
          {% endif %}
        </div>
        {% render 'trust-near-atc', class_prefix: 'sticky-mobile-atc__trust', compact: true, dense: true %}
      </div>
      {%- liquid
        assign sticky_atc_label = 'products.add_to_cart' | t
        if section.settings.button_label != blank
          assign sticky_atc_label = section.settings.button_label
        endif
      -%}
      {% if request.page_type == 'product' %}
        <button
          type="button"
          class="sticky-mobile-atc__btn pp-btn-primary pp-btn-sm"
          data-sticky-atc-submit
          data-default-label="{{ sticky_atc_label | escape }}"
          data-sold-out-label="{{ 'products.sold_out' | t | escape }}"
          data-adding-label="{{ 'products.adding' | t | escape }}"
        >
          {{ sticky_atc_label }}
        </button>
      {% else %}
        <a class="sticky-mobile-atc__btn pp-btn-primary pp-btn-sm" href="#{{ target_id }}">
          {{ sticky_atc_label }}
        </a>
      {% endif %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .sticky-mobile-atc {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    padding: 12px var(--page-margin, 16px);
    padding-bottom: max(12px, env(safe-area-inset-bottom));
    background-color: color-mix(in srgb, var(--satc-bg, #071014) 92%, transparent);
    backdrop-filter: blur(12px);
    border-top: 1px solid color-mix(in srgb, var(--satc-text, #f6f7f2) 10%, transparent);
    transform: translateY(100%);
    transition: transform 0.25s ease;
    --pp-accent: var(--satc-accent, #2dd4bf);
    --pp-accent-ink: var(--satc-accent-ink, #071014);
  }

  .sticky-mobile-atc.is-visible {
    transform: translateY(0);
    box-shadow: 0 -12px 40px -20px rgb(0 0 0 / 55%);
  }

  .sticky-mobile-atc__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sticky-mobile-atc__thumb {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--satc-text, #f6f7f2) 12%, transparent);
    box-shadow: 0 4px 12px -6px rgb(0 0 0 / 50%);
  }

  .sticky-mobile-atc__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sticky-mobile-atc__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    overflow: hidden;
  }

  .sticky-mobile-atc .pp-trust-atc--compact {
    gap: 3px;
    margin-top: 2px;
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .sticky-mobile-atc .pp-trust-atc__pill {
    font-size: 0.58rem;
    min-height: 0;
    padding: 2px 6px 2px 4px;
    gap: 4px;
    border-radius: 999px;
  }

  .sticky-mobile-atc .pp-trust-atc__pill-icon {
    width: 18px;
    height: 18px;
  }

  .sticky-mobile-atc .pp-trust-atc__pill-icon svg {
    width: 10px;
    height: 10px;
  }

  .sticky-mobile-atc__meta {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .sticky-mobile-atc__compare {
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--satc-text, #f6f7f2) 55%, transparent);
  }

  .sticky-mobile-atc__title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--satc-text, #f6f7f2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-mobile-atc__price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--satc-accent, #2dd4bf);
  }

  .sticky-mobile-atc__btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .sticky-mobile-atc {
      display: block;
    }

    .sticky-mobile-atc .pp-trust-atc--compact {
      display: none;
    }

    .sticky-mobile-atc__btn {
      padding-inline: 18px;
      font-size: 0.84rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-mobile-atc {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const bar = document.querySelector('[data-sticky-atc]');
    if (!bar) return;

    const targetId = bar.dataset.targetId || 'product-showcase';
    const target = document.getElementById(targetId);
    if (!target) return;

    const priceEl = bar.querySelector('[data-sticky-price]');
    const compareEl = bar.querySelector('[data-sticky-compare]');
    const submitBtn = bar.querySelector('[data-sticky-atc-submit]');

    const observer = new IntersectionObserver(
      ([entry]) => {
        bar.classList.toggle('is-visible', !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: '0px 0px -80px 0px' }
    );

    observer.observe(target);

    const bodyObserver = new IntersectionObserver(
      ([entry]) => {
        document.body.classList.toggle('has-sticky-atc', !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: '0px 0px -80px 0px' }
    );
    bodyObserver.observe(target);

    document.addEventListener('pump:variant-change', (event) => {
      if (!event.detail) return;
      if (priceEl && event.detail.formattedPrice) {
        priceEl.textContent = event.detail.formattedPrice;
      }
      if (compareEl) {
        if (event.detail.formattedComparePrice) {
          compareEl.hidden = false;
          compareEl.textContent = event.detail.formattedComparePrice;
        } else {
          compareEl.hidden = true;
        }
      }
      if (submitBtn) {
        submitBtn.disabled = !event.detail.available;
        submitBtn.textContent = event.detail.available
          ? submitBtn.dataset.defaultLabel || {{ 'products.add_to_cart' | t | json }}
          : submitBtn.dataset.soldOutLabel || {{ 'products.sold_out' | t | json }};
        submitBtn.classList.remove('is-loading');
      }
    });

    document.addEventListener('pump:cart-settled', () => {
      if (!submitBtn) return;
      submitBtn.classList.remove('is-loading');
      submitBtn.disabled = false;
      submitBtn.textContent = submitBtn.dataset.defaultLabel || {{ 'products.add_to_cart' | t | json }};
    });

    if (submitBtn) {
      submitBtn.addEventListener('click', () => {
        const form = document.querySelector('.main-product__form, .product-showcase .ajax-cart-form');
        if (form) {
          if (!submitBtn.dataset.defaultLabel) {
            submitBtn.dataset.defaultLabel = submitBtn.textContent.trim();
          }
          submitBtn.disabled = true;
          submitBtn.classList.add('is-loading');
          submitBtn.textContent = submitBtn.dataset.addingLabel || {{ 'products.adding' | t | json }};

          if (typeof form.requestSubmit === 'function') {
            form.requestSubmit();
          } else {
            form.submit();
          }
          return;
        }

        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Sticky mobile ATC",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "text",
      "id": "target_id",
      "label": "Scroll target ID",
      "info": "HTML id without #. Leave empty for auto (product-showcase on homepage, main-product on product pages)."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#071014"
    }
  ],
  "presets": [
    {
      "name": "Sticky mobile ATC"
    }
  ]
}
{% endschema %}
