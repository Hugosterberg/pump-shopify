{% comment %}
  Policy / info content — a clean, premium layout for legal/info pages
  (returns, shipping, terms). Built from editable blocks so the merchant
  can keep it in sync with the official Shopify policy pages.
{% endcomment %}

<div
  class="legal-page policy full-width pp-accent-line"
  style="
    --legal-bg: {{ section.settings.background_color }};
    --legal-surface: {{ section.settings.surface_color }};
    --legal-text: {{ section.settings.text_color }};
    --legal-muted: {{ section.settings.muted_text_color }};
    --legal-accent: {{ section.settings.accent_color }};
    --pol-bg: {{ section.settings.background_color }};
    --pol-surface: {{ section.settings.surface_color }};
    --pol-text: {{ section.settings.text_color }};
    --pol-muted: {{ section.settings.muted_text_color }};
    --pol-accent: {{ section.settings.accent_color }};
  "
>
  <div class="legal-page__inner policy__inner">
    <header class="legal-page__header policy__header">
      {% if section.settings.eyebrow != blank %}
        <p class="legal-page__eyebrow policy__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="legal-page__title policy__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.intro != blank %}
        <div class="legal-page__intro policy__intro pp-legal-prose rte">{{ section.settings.intro }}</div>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="policy__blocks">
        {% for block in section.blocks %}
          <section class="policy__block" {{ block.shopify_attributes }}>
            {% if block.settings.title != blank %}
              <h2 class="policy__block-title">
                <span class="policy__block-bar" aria-hidden="true"></span>
                {{ block.settings.title }}
              </h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="policy__block-body pp-legal-prose rte">{{ block.settings.body }}</div>
            {% endif %}
          </section>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.contact_note != blank %}
      <div class="legal-page__contact policy__contact pp-legal-prose rte">{{ section.settings.contact_note }}</div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .policy__blocks {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 28px);
  }

  .policy__block {
    padding: clamp(24px, 4vw, 32px);
    border-radius: 20px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--pol-text, #f6f7f2) 4%, var(--pol-surface, #14212a)),
      var(--pol-surface, #14212a)
    );
    border: 1px solid color-mix(in srgb, var(--pol-text, #f6f7f2) 9%, transparent);
    box-shadow: var(--pp-shadow-soft);
  }

  .policy__block-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 18px;
    font-size: clamp(1.12rem, 2.4vw, 1.28rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--pol-text, #f6f7f2);
  }

  .policy__block-bar {
    flex-shrink: 0;
    width: 4px;
    height: 1.15em;
    border-radius: 2px;
    background-color: var(--pol-accent, #2dd4bf);
  }

  .policy__block-body {
    color: var(--pol-muted, #9aa8a2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Policy content",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kundservice" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Returer & avbokningar" },
    { "type": "richtext", "id": "intro", "label": "Intro" },
    {
      "type": "richtext",
      "id": "contact_note",
      "label": "Contact note (highlighted box)",
      "default": "<p>Frågor om en retur eller avbokning? Mejla oss på <a href=\"mailto:info@pumpportable.com\">info@pumpportable.com</a> så hjälper vi dig.</p>"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Content block",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Rubrik" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Text...</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Policy content"
    }
  ]
}
{% endschema %}
