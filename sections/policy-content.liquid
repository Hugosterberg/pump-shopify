{% comment %}
  Policy / info content — a clean, premium layout for legal/info pages
  (returns, shipping, terms). Built from editable blocks so the merchant
  can keep it in sync with the official Shopify policy pages.
{% endcomment %}

<div
  class="policy full-width"
  style="
    --pol-bg: {{ section.settings.background_color }};
    --pol-surface: {{ section.settings.surface_color }};
    --pol-text: {{ section.settings.text_color }};
    --pol-muted: {{ section.settings.muted_text_color }};
    --pol-accent: {{ section.settings.accent_color }};
  "
>
  <div class="policy__inner">
    <header class="policy__header">
      {% if section.settings.eyebrow != blank %}
        <p class="policy__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="policy__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.intro != blank %}
        <div class="policy__intro rte">{{ section.settings.intro }}</div>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="policy__blocks">
        {% for block in section.blocks %}
          <section class="policy__block" {{ block.shopify_attributes }}>
            {% if block.settings.title != blank %}
              <h2 class="policy__block-title">
                <span class="policy__block-bar" aria-hidden="true"></span>
                {{ block.settings.title }}
              </h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="policy__block-body rte">{{ block.settings.body }}</div>
            {% endif %}
          </section>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.contact_note != blank %}
      <div class="policy__contact rte">{{ section.settings.contact_note }}</div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .policy {
    padding-block: 56px 80px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pol-bg, #071014);
    color: var(--pol-text, #f6f7f2);
  }

  .policy__inner {
    max-width: 760px;
    margin-inline: auto;
  }

  .policy__header {
    margin-bottom: 28px;
  }

  .policy__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pol-accent, #2dd4bf);
  }

  .policy__heading {
    margin: 0;
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .policy__intro {
    margin-top: 18px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--pol-muted, #9aa8a2);
  }

  .policy__blocks {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .policy__block {
    padding: 24px;
    border-radius: 16px;
    background-color: var(--pol-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--pol-text, #f6f7f2) 8%, transparent);
  }

  .policy__block-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 12px;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .policy__block-bar {
    width: 4px;
    height: 1.1em;
    border-radius: 2px;
    background-color: var(--pol-accent, #2dd4bf);
  }

  .policy__block-body {
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--pol-muted, #9aa8a2);
  }

  .policy__block-body > :first-child {
    margin-top: 0;
  }

  .policy__block-body > :last-child {
    margin-bottom: 0;
  }

  .policy__block-body ul,
  .policy__block-body ol {
    margin: 0;
    padding-left: 1.25em;
  }

  .policy__block-body a {
    color: var(--pol-accent, #2dd4bf);
  }

  .policy__contact {
    margin-top: 32px;
    padding: 20px 22px;
    border-radius: 14px;
    background-color: color-mix(in srgb, var(--pol-accent, #2dd4bf) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--pol-accent, #2dd4bf) 28%, transparent);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .policy__contact a {
    color: var(--pol-accent, #2dd4bf);
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .policy {
      padding-block: 80px 110px;
    }

    .policy__block {
      padding: 28px 30px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Policy content",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kundservice" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Returer & avbokningar" },
    { "type": "richtext", "id": "intro", "label": "Intro" },
    {
      "type": "richtext",
      "id": "contact_note",
      "label": "Contact note (highlighted box)",
      "default": "<p>Frågor om en retur eller avbokning? Mejla oss på <a href=\"mailto:info@pumpportable.com\">info@pumpportable.com</a> så hjälper vi dig.</p>"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Content block",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Rubrik" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Text...</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Policy content"
    }
  ]
}
{% endschema %}
