<div
  class="comparison-section full-width"
  style="
    --cmp-bg: {{ section.settings.background_color }};
    --cmp-surface: {{ section.settings.surface_color }};
    --cmp-text: {{ section.settings.text_color }};
    --cmp-muted: {{ section.settings.muted_text_color }};
    --cmp-accent: {{ section.settings.accent_color }};
    --cmp-negative: {{ section.settings.negative_color }};
    --cmp-positive: {{ section.settings.positive_color }};
  "
>
  <div class="comparison-section__inner">
    {% if section.settings.heading != blank %}
      <header class="comparison-section__header">
        {% if section.settings.eyebrow != blank %}
          <p class="comparison-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="comparison-section__heading">{{ section.settings.heading }}</h2>
      </header>
    {% endif %}

    <div class="comparison-section__table-wrap">
      <table class="comparison-section__table">
        <thead>
          <tr>
            <th scope="col" class="comparison-section__th comparison-section__th--feature">
              {{ section.settings.feature_column_label | default: 'Funktion' }}
            </th>
            <th scope="col" class="comparison-section__th comparison-section__th--us">
              {{ section.settings.us_column_label | default: 'The Portable Shower' }}
            </th>
            <th scope="col" class="comparison-section__th comparison-section__th--them">
              {{ section.settings.them_column_label | default: 'Vanlig lösning' }}
            </th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr class="comparison-section__row" {{ block.shopify_attributes }}>
              <th scope="row" class="comparison-section__feature">{{ block.settings.feature }}</th>
              <td class="comparison-section__cell comparison-section__cell--us">
                {% if block.settings.us_has %}
                  <span class="comparison-section__yes" aria-label="Ja">✓</span>
                {% else %}
                  <span class="comparison-section__no" aria-label="Nej">✕</span>
                {% endif %}
                {% if block.settings.us_note != blank %}
                  <span class="comparison-section__note">{{ block.settings.us_note }}</span>
                {% endif %}
              </td>
              <td class="comparison-section__cell comparison-section__cell--them">
                {% if block.settings.them_has %}
                  <span class="comparison-section__yes comparison-section__yes--muted" aria-label="Ja">✓</span>
                {% else %}
                  <span class="comparison-section__no" aria-label="Nej">✕</span>
                {% endif %}
                {% if block.settings.them_note != blank %}
                  <span class="comparison-section__note">{{ block.settings.them_note }}</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% stylesheet %}
  .comparison-section {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--cmp-bg, #101820);
    color: var(--cmp-text, #f6f7f2);
  }

  .comparison-section__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .comparison-section__header {
    text-align: center;
    margin-bottom: 24px;
  }

  .comparison-section__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cmp-accent, #2dd4bf);
  }

  .comparison-section__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .comparison-section__table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 8%, transparent);
    background-color: var(--cmp-surface, #14212a);
    -webkit-overflow-scrolling: touch;
  }

  .comparison-section__table {
    width: 100%;
    min-width: 480px;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .comparison-section__th,
  .comparison-section__feature,
  .comparison-section__cell {
    padding: 16px 18px;
    text-align: left;
    border-bottom: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 6%, transparent);
  }

  .comparison-section__th {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--cmp-muted, #9aa8a2);
    background-color: color-mix(in srgb, var(--cmp-bg, #101820) 50%, var(--cmp-surface, #14212a));
    vertical-align: middle;
  }

  .comparison-section__th--us,
  .comparison-section__th--them {
    text-align: center;
  }

  .comparison-section__th--us {
    color: #ffffff;
    font-weight: 700;
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 20%, var(--cmp-surface, #14212a));
    border-top: 3px solid var(--cmp-positive, #22c55e);
    border-inline: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
    box-shadow: 0 -12px 30px -14px color-mix(in srgb, var(--cmp-positive, #22c55e) 95%, transparent);
  }

  .comparison-section__feature {
    font-weight: 500;
    color: var(--cmp-text, #f6f7f2);
    width: 40%;
    vertical-align: middle;
  }

  .comparison-section__cell {
    position: relative;
    text-align: center;
    vertical-align: middle;
  }

  .comparison-section__cell--us {
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 9%, transparent);
    border-inline: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
  }

  .comparison-section__row:last-child .comparison-section__cell--us {
    border-bottom: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
  }

  .comparison-section__row:hover .comparison-section__feature,
  .comparison-section__row:hover .comparison-section__cell--them {
    background-color: color-mix(in srgb, var(--cmp-text, #f6f7f2) 4%, transparent);
  }

  .comparison-section__row:hover .comparison-section__cell--us {
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 16%, transparent);
  }

  .comparison-section__yes,
  .comparison-section__no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
  }

  .comparison-section__yes {
    color: #04210f;
    background-color: var(--cmp-positive, #22c55e);
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--cmp-positive, #22c55e) 90%, #000);
  }

  .comparison-section__yes--muted {
    color: var(--cmp-muted, #9aa8a2);
    background-color: color-mix(in srgb, var(--cmp-muted, #9aa8a2) 18%, transparent);
    box-shadow: none;
  }

  .comparison-section__no {
    color: var(--cmp-negative, #f87171);
    background-color: color-mix(in srgb, var(--cmp-negative, #f87171) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--cmp-negative, #f87171) 45%, transparent);
  }

  .comparison-section__note {
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 5px;
    margin: 0;
    font-size: 0.68rem;
    line-height: 1.3;
    color: var(--cmp-muted, #9aa8a2);
  }

  .comparison-section__row:last-child .comparison-section__feature,
  .comparison-section__row:last-child .comparison-section__cell {
    border-bottom: none;
  }

  @media screen and (min-width: 750px) {
    .comparison-section {
      padding-block: 68px;
    }

    .comparison-section__th,
    .comparison-section__feature,
    .comparison-section__cell {
      padding: 18px 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Comparison",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Jämförelse"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Portable Shower vs vanliga lösningar"
    },
    {
      "type": "text",
      "id": "feature_column_label",
      "label": "Feature column label",
      "default": "Funktion"
    },
    {
      "type": "text",
      "id": "us_column_label",
      "label": "Your product column label",
      "default": "The Portable Shower"
    },
    {
      "type": "text",
      "id": "them_column_label",
      "label": "Alternative column label",
      "default": "Vanlig lösning"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "negative_color",
      "label": "Negative (X) color",
      "default": "#F87171"
    },
    {
      "type": "color",
      "id": "positive_color",
      "label": "Positive (check) color",
      "default": "#22C55E"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature", "default": "Portabel & laddningsbar" },
        { "type": "checkbox", "id": "us_has", "label": "The Portable Shower has this", "default": true },
        { "type": "text", "id": "us_note", "label": "The Portable Shower note" },
        { "type": "checkbox", "id": "them_has", "label": "Alternative has this", "default": false },
        { "type": "text", "id": "them_note", "label": "Alternative note" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison",
      "blocks": [
        { "type": "row", "settings": { "feature": "Portabel & laddningsbar", "us_has": true, "them_has": false } },
        { "type": "row", "settings": { "feature": "Digital temperaturdisplay", "us_has": true, "them_has": false } },
        { "type": "row", "settings": { "feature": "Upp till 150 min batteritid", "us_has": true, "them_has": false, "them_note": "Kräver eluttag" } },
        { "type": "row", "settings": { "feature": "Ingen installation", "us_has": true, "them_has": false } },
        { "type": "row", "settings": { "feature": "Väger ca 1 kg", "us_has": true, "them_has": false } }
      ]
    }
  ]
}
{% endschema %}
