{%- assign cmp_anchor = section.settings.anchor_id | default: 'jamforelse' | handle -%}
<div
  id="{{ cmp_anchor }}"
  class="comparison-section full-width"
  data-comparison
  data-anchor="{{ cmp_anchor }}"
  style="
    --cmp-bg: {{ section.settings.background_color }};
    --cmp-surface: {{ section.settings.surface_color }};
    --cmp-text: {{ section.settings.text_color }};
    --cmp-muted: {{ section.settings.muted_text_color }};
    --cmp-accent: {{ section.settings.accent_color }};
    --cmp-negative: {{ section.settings.negative_color }};
    --cmp-positive: {{ section.settings.positive_color }};
    --cmp-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  {%- liquid
    assign common_count = 0
    assign competitor_count = 0
    for block in section.blocks
      assign row_set = block.settings.comparison_set | default: 'common'
      if row_set == 'competitors'
        assign competitor_count = competitor_count | plus: 1
      else
        assign common_count = common_count | plus: 1
      endif
    endfor
    assign can_flip = false
    if common_count > 0 and competitor_count > 0
      assign can_flip = true
    endif

    assign word_competitors = section.settings.flip_word_competitors | default: 'kända konkurrenter'
    assign word_common = section.settings.flip_word_common | default: 'vanliga lösningar'
    assign heading_prefix = section.settings.heading | default: 'Duschkit från pump vs'
  -%}

  <div class="comparison-section__inner">
    {% if section.blocks.size > 0 %}
      <div class="comparison-flip{% if can_flip %} comparison-flip--enabled{% endif %}">
        {% if can_flip %}
          <input
            type="checkbox"
            id="cmp-flip-{{ section.id }}"
            class="comparison-flip__toggle"
            data-comparison-toggle
            aria-label="Byt jämförelse till {{ word_common | escape }} eller {{ word_competitors | escape }}"
          >
        {% endif %}

        <header class="comparison-section__header">
          {% if section.settings.eyebrow != blank %}
            <p class="comparison-section__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h2 class="comparison-section__heading">
            {% render 'brand-mark-text', text: heading_prefix %}
            {% if can_flip %}
              <label class="comparison-flip__headword" for="cmp-flip-{{ section.id }}" title="Byt jämförelse">
                <span class="comparison-flip__word comparison-flip__word--front">{{ word_competitors }}</span>
                <span class="comparison-flip__word comparison-flip__word--back" aria-hidden="true">{{ word_common }}</span>
                <span class="comparison-flip__cue" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 8h13l-3-3M20 16H7l3 3" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </label>
            {% else %}
              <span class="comparison-flip__word-static">{% if competitor_count > 0 %}{{ word_competitors }}{% else %}{{ word_common }}{% endif %}</span>
            {% endif %}
          </h2>

          {% if section.settings.show_share_link %}
            <button
              type="button"
              class="comparison-share"
              data-comparison-share
              data-label-default="{{ section.settings.share_label | default: 'Kopiera länk till jämförelsen' | escape }}"
              data-label-copied="{{ section.settings.share_label_copied | default: 'Länk kopierad!' | escape }}"
            >
              <span class="comparison-share__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M15 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="comparison-share__text">{{ section.settings.share_label | default: 'Kopiera länk till jämförelsen' }}</span>
            </button>
          {% endif %}
        </header>

        <div class="comparison-flip__stage">
          <div class="comparison-flip__card">
            {% assign faces = 'competitors,common' | split: ',' %}
            {% for face in faces %}
              {%- liquid
                if face == 'competitors'
                  assign set_key = 'competitors'
                  assign set_count = competitor_count
                  assign them_label = section.settings.them2_column_label | default: 'Kända konkurrenter'
                  if can_flip
                    assign face_class = 'comparison-flip__face--front'
                  else
                    assign face_class = 'comparison-flip__face--solo'
                  endif
                else
                  assign set_key = 'common'
                  assign set_count = common_count
                  assign them_label = section.settings.them_column_label | default: 'Vanlig lösning'
                  if can_flip
                    assign face_class = 'comparison-flip__face--back'
                  else
                    assign face_class = 'comparison-flip__face--solo'
                  endif
                endif
              -%}

              {% if set_count > 0 %}
                <div class="comparison-flip__face {{ face_class }}" data-panel="{{ set_key }}">
                  <div class="comparison-section__table-wrap">
                    <table class="comparison-section__table">
                      <thead>
                        <tr>
                          <th scope="col" class="comparison-section__th comparison-section__th--feature">
                            <span class="comparison-section__th-full">{{ section.settings.feature_column_label | default: 'Funktion' }}</span>
                            <span class="comparison-section__th-short" aria-hidden="true">{{ section.settings.feature_column_label_short | default: 'Funktion' }}</span>
                          </th>
                          <th scope="col" class="comparison-section__th comparison-section__th--us">
                            <span class="comparison-section__th-full">{{ section.settings.us_column_label | default: 'The Portable Shower' }}</span>
                            <span class="comparison-section__th-short" aria-hidden="true">{{ section.settings.us_column_label_short | default: 'pump' }}</span>
                          </th>
                          <th scope="col" class="comparison-section__th comparison-section__th--them">
                            <span class="comparison-section__th-full">{{ them_label }}</span>
                            <span class="comparison-section__th-short" aria-hidden="true">
                              {%- if set_key == 'competitors' -%}
                                {{ section.settings.them2_column_label_short | default: 'Andra' }}
                              {%- else -%}
                                {{ section.settings.them_column_label_short | default: 'Vanliga' }}
                              {%- endif -%}
                            </span>
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for block in section.blocks %}
                          {%- assign row_set = block.settings.comparison_set | default: 'common' -%}
                          {% if row_set == set_key %}
                            <tr class="comparison-section__row" {{ block.shopify_attributes }}>
                              <th scope="row" class="comparison-section__feature">{{ block.settings.feature }}</th>
                              <td class="comparison-section__cell comparison-section__cell--us">
                                {% if block.settings.us_note != blank %}
                                  <span class="comparison-section__value">{{ block.settings.us_note }}</span>
                                {% else %}
                                  <span class="comparison-section__mark">
                                    {% if block.settings.us_has %}
                                      <span class="comparison-section__yes" aria-label="Ja">✓</span>
                                    {% else %}
                                      <span class="comparison-section__no" aria-label="Nej">✕</span>
                                    {% endif %}
                                  </span>
                                {% endif %}
                              </td>
                              <td class="comparison-section__cell comparison-section__cell--them">
                                {% if block.settings.them_note != blank %}
                                  <span class="comparison-section__value comparison-section__value--muted">{{ block.settings.them_note }}</span>
                                {% else %}
                                  <span class="comparison-section__mark">
                                    {% if block.settings.them_has %}
                                      <span class="comparison-section__yes comparison-section__yes--muted" aria-label="Ja">✓</span>
                                    {% else %}
                                      <span class="comparison-section__no" aria-label="Nej">✕</span>
                                    {% endif %}
                                  </span>
                                {% endif %}
                              </td>
                            </tr>
                          {% endif %}
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if section.settings.show_cta and section.settings.cta_label != blank %}
      {% liquid
        assign cta_url = section.settings.cta_link
        if cta_url == blank
          assign cta_url = '#product-showcase'
        endif
      %}
      <div class="comparison-section__cta">
        <a class="comparison-section__cta-btn" href="{{ cta_url }}">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .comparison-section {
    scroll-margin-top: calc(var(--header-height, 64px) + 20px);
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--cmp-bg, #101820);
    color: var(--cmp-text, #f6f7f2);
  }

  .comparison-section__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .comparison-section__cta {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .comparison-section__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding-inline: 28px;
    border-radius: var(--pp-radius-pill, 999px);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--cmp-accent-ink, #071014);
    background: linear-gradient(135deg, var(--cmp-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 28%, var(--cmp-accent, #2dd4bf)));
    box-shadow: var(--pp-shadow-glow);
    transition: transform 0.2s ease;
  }

  .comparison-section__cta-btn:hover {
    transform: translateY(-2px);
  }

  .comparison-section__header {
    text-align: center;
    margin-bottom: 24px;
  }

  .comparison-section__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cmp-accent, #2dd4bf);
  }

  .comparison-section__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .comparison-share {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 100%;
    margin-top: 16px;
    min-height: 44px;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--cmp-accent, #2dd4bf) 28%, transparent);
    background:
      linear-gradient(145deg, rgba(255,255,255,0.06), transparent 50%),
      color-mix(in srgb, var(--cmp-surface, #14212a) 70%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    color: color-mix(in srgb, var(--cmp-text, #f6f7f2) 88%, transparent);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.01em;
    cursor: pointer;
    box-shadow: 0 10px 28px -20px rgba(0, 0, 0, 0.7);
    transition:
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease,
      box-shadow 0.22s ease;
  }

  .comparison-share:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--cmp-accent, #2dd4bf) 55%, transparent);
    background:
      linear-gradient(145deg, rgba(255,255,255,0.1), transparent 50%),
      color-mix(in srgb, var(--cmp-surface, #14212a) 85%, transparent);
    color: var(--cmp-text, #f6f7f2);
    box-shadow: 0 14px 32px -16px color-mix(in srgb, var(--cmp-accent, #2dd4bf) 70%, transparent);
  }

  .comparison-share.is-copied {
    border-color: var(--cmp-accent, #2dd4bf);
    background: color-mix(in srgb, var(--cmp-accent, #2dd4bf) 18%, transparent);
    color: var(--cmp-accent, #2dd4bf);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--cmp-accent, #2dd4bf) 12%, transparent);
  }

  .comparison-share__icon {
    display: inline-flex;
    color: var(--cmp-accent, #2dd4bf);
    width: 15px;
    height: 15px;
  }

  .comparison-share__icon svg {
    width: 100%;
    height: 100%;
  }

  /* Flip toggle */
  .comparison-flip__toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Inline interactive heading word that flips the whole comparison.
     Sits right after "vs" and blends into the heading. */
  .comparison-flip__headword {
    position: relative;
    display: inline-grid;
    grid-auto-flow: column;
    align-items: baseline;
    vertical-align: baseline;
    cursor: pointer;
    color: var(--cmp-accent, #2dd4bf);
    padding: 0.04em 0.12em;
    border-radius: 0.32em;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 0.25s ease;
  }

  /* dotted underline affordance */
  .comparison-flip__headword::after {
    content: '';
    position: absolute;
    left: 0.12em;
    right: 1.5em;
    bottom: 0.02em;
    border-bottom: 2px dashed color-mix(in srgb, var(--cmp-accent, #2dd4bf) 55%, transparent);
    transition: opacity 0.25s ease;
  }

  .comparison-flip__headword:hover {
    background-color: color-mix(in srgb, var(--cmp-accent, #2dd4bf) 12%, transparent);
  }

  .comparison-flip__word {
    grid-row: 1;
    grid-column: 1;
    transition: opacity 0.4s ease, transform 0.4s ease, filter 0.4s ease;
  }

  .comparison-flip__word--back {
    opacity: 0;
    transform: translateY(0.45em) rotateX(-90deg);
    filter: blur(4px);
  }

  .comparison-flip__word--front {
    opacity: 1;
    transform: none;
    filter: none;
  }

  /* little ⇄ cue */
  .comparison-flip__cue {
    grid-row: 1;
    grid-column: 2;
    align-self: center;
    width: 0.72em;
    height: 0.72em;
    margin-left: 0.34em;
    color: color-mix(in srgb, var(--cmp-accent, #2dd4bf) 75%, var(--cmp-text, #f6f7f2));
    transition: transform 0.7s cubic-bezier(0.45, 0.05, 0.2, 1);
  }

  .comparison-flip__cue svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .comparison-flip__toggle:checked ~ .comparison-section__header .comparison-flip__word--front {
    opacity: 0;
    transform: translateY(-0.45em) rotateX(90deg);
    filter: blur(4px);
  }

  .comparison-flip__toggle:checked ~ .comparison-section__header .comparison-flip__word--back {
    opacity: 1;
    transform: none;
    filter: none;
  }

  .comparison-flip__toggle:checked ~ .comparison-section__header .comparison-flip__cue {
    transform: rotate(180deg);
  }

  .comparison-flip__toggle:focus-visible ~ .comparison-section__header .comparison-flip__headword {
    outline: 2px solid var(--cmp-accent, #2dd4bf);
    outline-offset: 3px;
  }

  /* 3D flip card — the active face stays in normal flow so the stage
     height follows it (no empty space under a shorter table). The
     inactive face is absolutely overlaid for the flip. */
  .comparison-flip__stage {
    perspective: 2200px;
  }

  .comparison-flip__card {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.45, 0.05, 0.2, 1);
  }

  .comparison-flip__toggle:checked ~ .comparison-flip__stage .comparison-flip__card {
    transform: rotateY(180deg);
  }

  .comparison-flip__face {
    width: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  /* Front face defines height by default; back face overlays it. */
  .comparison-flip__face--front {
    position: relative;
  }

  .comparison-flip__face--back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
  }

  /* When flipped, the back face takes over the flow so the stage
     resizes to the back table's height. */
  .comparison-flip__toggle:checked ~ .comparison-flip__stage .comparison-flip__face--front {
    position: absolute;
    inset: 0;
  }

  .comparison-flip__toggle:checked ~ .comparison-flip__stage .comparison-flip__face--back {
    position: relative;
  }

  /* Non-flip fallback (only one comparison set present) */
  .comparison-flip:not(.comparison-flip--enabled) .comparison-flip__face {
    position: relative;
    inset: auto;
    transform: none;
  }

  .comparison-flip:not(.comparison-flip--enabled) .comparison-flip__card {
    transform: none;
  }

  .comparison-section__table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 8%, transparent);
    background-color: var(--cmp-surface, #14212a);
    -webkit-overflow-scrolling: touch;
  }

  .comparison-section__table {
    width: 100%;
    min-width: 480px;
    table-layout: fixed;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .comparison-section__th--feature {
    width: 44%;
  }

  .comparison-section__th--us,
  .comparison-section__th--them {
    width: 28%;
  }

  .comparison-section__th,
  .comparison-section__feature,
  .comparison-section__cell {
    padding: 9px 16px;
    text-align: left;
    border-bottom: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 8%, transparent);
  }

  .comparison-section__th--feature,
  .comparison-section__feature {
    border-right: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 8%, transparent);
  }

  .comparison-section__th--them,
  .comparison-section__cell--them {
    border-left: 1px solid color-mix(in srgb, var(--cmp-text, #f6f7f2) 8%, transparent);
  }

  .comparison-section__th {
    font-weight: 600;
    font-size: clamp(0.72rem, 2.5vw, 0.8rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--cmp-muted, #9aa8a2);
    background-color: color-mix(in srgb, var(--cmp-bg, #101820) 50%, var(--cmp-surface, #14212a));
    vertical-align: middle;
  }

  .comparison-section__th-short {
    display: none;
  }

  .comparison-section__th--us,
  .comparison-section__th--them {
    text-align: center;
  }

  .comparison-section__th--us {
    color: #ffffff;
    font-weight: 700;
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 20%, var(--cmp-surface, #14212a));
    border-top: 3px solid var(--cmp-positive, #22c55e);
    border-inline: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
    box-shadow: 0 -12px 30px -14px color-mix(in srgb, var(--cmp-positive, #22c55e) 95%, transparent);
  }

  .comparison-section__feature {
    font-weight: 500;
    font-size: clamp(0.78rem, 2.2vw, 0.92rem);
    line-height: 1.35;
    color: var(--cmp-text, #f6f7f2);
    vertical-align: middle;
    text-wrap: pretty;
    hyphens: auto;
  }

  .comparison-section__cell {
    text-align: center;
    vertical-align: middle;
  }

  .comparison-section__mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
  }

  .comparison-section__value {
    display: block;
    text-align: center;
    font-size: clamp(0.72rem, 2.1vw, 0.86rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--cmp-text, #f6f7f2);
    overflow-wrap: break-word;
    text-wrap: balance;
    hyphens: auto;
  }

  .comparison-section__value--muted {
    font-weight: 500;
    color: var(--cmp-muted, #9aa8a2);
  }

  .comparison-section__cell--us {
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 9%, transparent);
    border-inline: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
  }

  .comparison-section__row:last-child .comparison-section__cell--us {
    border-bottom: 1px solid color-mix(in srgb, var(--cmp-positive, #22c55e) 35%, transparent);
  }

  .comparison-section__row:hover .comparison-section__feature,
  .comparison-section__row:hover .comparison-section__cell--them {
    background-color: color-mix(in srgb, var(--cmp-text, #f6f7f2) 4%, transparent);
  }

  .comparison-section__row:hover .comparison-section__cell--us {
    background-color: color-mix(in srgb, var(--cmp-positive, #22c55e) 16%, transparent);
  }

  .comparison-section__yes,
  .comparison-section__no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
  }

  .comparison-section__yes {
    color: #04210f;
    background-color: var(--cmp-positive, #22c55e);
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--cmp-positive, #22c55e) 90%, #000);
  }

  .comparison-section__yes--muted {
    color: var(--cmp-muted, #9aa8a2);
    background-color: color-mix(in srgb, var(--cmp-muted, #9aa8a2) 18%, transparent);
    box-shadow: none;
  }

  .comparison-section__no {
    color: var(--cmp-negative, #f87171);
    background-color: color-mix(in srgb, var(--cmp-negative, #f87171) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--cmp-negative, #f87171) 45%, transparent);
  }

  .comparison-section__row:last-child .comparison-section__feature,
  .comparison-section__row:last-child .comparison-section__cell {
    border-bottom: none;
  }

  /* Phones: pack the full table into one screen when possible. */
  @media screen and (max-width: 749px) {
    .comparison-section {
      padding-block: 28px 32px;
      padding-inline: 12px;
    }

    .comparison-section__header {
      margin-bottom: 10px;
    }

    .comparison-section__eyebrow {
      margin-bottom: 6px;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
    }

    .comparison-section__heading {
      font-size: clamp(1.05rem, 5.2vw, 1.35rem);
      line-height: 1.2;
    }

    .comparison-share {
      margin-top: 8px;
      min-height: 34px;
      padding: 6px 10px;
      gap: 6px;
      font-size: 0.7rem;
      border-radius: 10px;
    }

    .comparison-share__icon {
      width: 14px;
      height: 14px;
    }

    .comparison-section__cta {
      margin-top: 14px;
    }

    .comparison-section__cta-btn {
      min-height: 42px;
      padding-inline: 20px;
      font-size: 0.84rem;
    }

    .comparison-section__table-wrap {
      border-radius: 12px;
    }

    .comparison-section__table {
      min-width: 0;
      font-size: 0.72rem;
    }

    .comparison-section__th-full {
      display: none;
    }

    .comparison-section__th-short {
      display: inline;
    }

    .comparison-section__th,
    .comparison-section__feature,
    .comparison-section__cell {
      padding: 5px 6px;
    }

    .comparison-section__th--feature {
      width: 42%;
    }

    .comparison-section__th--us,
    .comparison-section__th--them {
      width: 29%;
    }

    .comparison-section__th {
      font-size: 0.58rem;
      letter-spacing: 0.04em;
      line-height: 1.15;
      padding-block: 7px;
      text-wrap: balance;
    }

    .comparison-section__feature {
      font-size: 0.68rem;
      line-height: 1.2;
      font-weight: 500;
    }

    .comparison-section__value {
      font-size: 0.66rem;
      line-height: 1.2;
    }

    .comparison-section__yes,
    .comparison-section__no {
      width: 16px;
      height: 16px;
      font-size: 0.6rem;
    }
  }

  /* Small iPhones (SE / mini): denser still so ~14 rows fit in one view. */
  @media screen and (max-width: 430px) {
    .comparison-section {
      padding-block: 22px 26px;
      padding-inline: 10px;
    }

    .comparison-section__eyebrow {
      display: none;
    }

    .comparison-section__heading {
      font-size: 1.02rem;
    }

    .comparison-share__text {
      display: none;
    }

    .comparison-share {
      min-width: 34px;
      min-height: 34px;
      padding: 7px;
      border-radius: 999px;
    }

    .comparison-section__th,
    .comparison-section__feature,
    .comparison-section__cell {
      padding: 3px 5px;
    }

    .comparison-section__th {
      padding-block: 6px;
      font-size: 0.55rem;
    }

    .comparison-section__feature {
      font-size: 0.62rem;
      line-height: 1.15;
    }

    .comparison-section__value {
      font-size: 0.6rem;
      line-height: 1.15;
    }

    .comparison-section__yes,
    .comparison-section__no {
      width: 14px;
      height: 14px;
      font-size: 0.55rem;
    }

    .comparison-section__cta {
      margin-top: 12px;
    }

    .comparison-section__cta-btn {
      min-height: 40px;
      font-size: 0.8rem;
    }
  }

  @media screen and (min-width: 750px) {
    .comparison-section {
      padding-block: 68px;
    }

    .comparison-section__th-short {
      display: none;
    }

    .comparison-section__th,
    .comparison-section__feature,
    .comparison-section__cell {
      padding: 11px 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .comparison-flip__card,
    .comparison-flip__cue,
    .comparison-flip__word {
      transition: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('{{ cmp_anchor }}');
    if (!root) return;

    var toggle = root.querySelector('[data-comparison-toggle]');
    var share = root.querySelector('[data-comparison-share]');
    var anchor = root.getAttribute('data-anchor') || '{{ cmp_anchor }}';
    var PARAM = 'cmp';
    var SECTION_PARAM = 'section';
    var VAL_COMMON = 'vanliga';
    var VAL_COMP = 'konkurrenter';

    function getParams() {
      try {
        return new URLSearchParams(window.location.search);
      } catch (e) {
        return null;
      }
    }

    function shouldOpenComparison(params) {
      var hash = (window.location.hash || '').replace(/^#/, '');
      if (hash === anchor) return true;
      if (!params) return false;
      // Facebook/in-app browsers often strip #hash but keep query params.
      if (params.get(SECTION_PARAM) === anchor) return true;
      if (params.get(PARAM) === VAL_COMMON || params.get(PARAM) === VAL_COMP) return true;
      return false;
    }

    function applySideFromUrl(params) {
      if (!toggle || !params) return;
      if (params.get(PARAM) === VAL_COMMON) {
        toggle.checked = true;
      } else if (params.get(PARAM) === VAL_COMP) {
        toggle.checked = false;
      }
    }

    function headerOffset() {
      var header =
        document.querySelector('sticky-header') ||
        document.querySelector('[data-header]') ||
        document.querySelector('header.header') ||
        document.querySelector('#shopify-section-header') ||
        document.querySelector('header');
      var h = header ? header.getBoundingClientRect().height : 0;
      if (!h) {
        try {
          h = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 64;
        } catch (e) {
          h = 64;
        }
      }
      return h + 16;
    }

    function scrollToComparison(behavior) {
      var top = root.getBoundingClientRect().top + window.pageYOffset - headerOffset();
      window.scrollTo({
        top: Math.max(0, top),
        behavior: behavior || 'auto'
      });
    }

    function ensureHash() {
      if ((window.location.hash || '').replace(/^#/, '') === anchor) return;
      try {
        var url = new URL(window.location.href);
        url.hash = anchor;
        history.replaceState(null, '', url.toString());
      } catch (e) {}
    }

    var params = getParams();
    applySideFromUrl(params);

    if (shouldOpenComparison(params)) {
      try {
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      } catch (e) {}

      ensureHash();

      var attempts = [0, 50, 150, 350, 700, 1200, 2000];
      attempts.forEach(function (delay) {
        window.setTimeout(function () {
          scrollToComparison('auto');
        }, delay);
      });

      window.addEventListener(
        'load',
        function () {
          scrollToComparison('auto');
          window.setTimeout(function () {
            scrollToComparison('auto');
          }, 300);
        },
        { once: true }
      );
    }

    function buildLink() {
      var url = new URL(window.location.origin + window.location.pathname);
      var side = toggle && toggle.checked ? VAL_COMMON : VAL_COMP;
      url.searchParams.set(PARAM, side);
      // Query param survives Facebook / messengers; hash is a bonus for browsers that keep it.
      url.searchParams.set(SECTION_PARAM, anchor);
      url.hash = anchor;
      return url.toString();
    }

    if (share) {
      var defaultLabel = share.getAttribute('data-label-default');
      var copiedLabel = share.getAttribute('data-label-copied');
      var textEl = share.querySelector('.comparison-share__text');
      var resetTimer;

      share.addEventListener('click', function () {
        var link = buildLink();

        function done() {
          share.classList.add('is-copied');
          if (textEl && copiedLabel) textEl.textContent = copiedLabel;
          window.clearTimeout(resetTimer);
          resetTimer = window.setTimeout(function () {
            share.classList.remove('is-copied');
            if (textEl && defaultLabel) textEl.textContent = defaultLabel;
          }, 2200);
        }

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(link).then(done).catch(fallback);
        } else {
          fallback();
        }

        function fallback() {
          var ta = document.createElement('textarea');
          ta.value = link;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          done();
        }
      });
    }
  })();
</script>

