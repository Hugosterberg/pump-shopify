{% comment %}
  Brand promise band. Each word of the slogan stacks on its own line with
  the initial letter highlighted, so the PUMP acronym reads top to bottom.
  Optional aurora background. Sets the tone that PUMP is a brand of portable
  utilities, not a single product.
{% endcomment %}

<div
  class="brand-promise full-width"
  style="
    --bp-bg: {{ section.settings.background_color }};
    --bp-text: {{ section.settings.text_color }};
    --bp-muted: {{ section.settings.muted_text_color }};
    --bp-accent: {{ section.settings.accent_color }};
  "
>
  {% if section.settings.show_aurora %}
    {% render 'aurora', color: section.settings.accent_color %}
  {% endif %}

  <div class="brand-promise__layout">
    {% if section.blocks.size > 0 %}
      <div class="brand-promise__gallery brand-promise__gallery--left">
        {% for block in section.blocks %}
          {%- liquid
            assign side = block.settings.side
            if side == blank or side == 'auto'
              assign parity = forloop.index0 | modulo: 2
              if parity == 0
                assign side = 'left'
              else
                assign side = 'right'
              endif
            endif
          -%}
          {% if side == 'left' %}{% render 'brand-shot', block: block %}{% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="brand-promise__inner">
      {% if section.settings.kicker != blank %}
        <p class="brand-promise__kicker">{{ section.settings.kicker }}</p>
      {% endif %}
      {% if section.settings.promise != blank %}
        {% assign promise_words = section.settings.promise | split: ' ' %}
        <h2 class="brand-promise__text">
          {% for word in promise_words %}
            {% assign initial = word | slice: 0 %}
            {% assign remainder = word | slice: 1, 60 %}
            <span class="brand-promise__line" style="--line-index: {{ forloop.index0 }};">
              <span class="brand-promise__initial">{{ initial }}</span>{{ remainder }}
            </span>
          {% endfor %}
        </h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="brand-promise__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="brand-promise__gallery brand-promise__gallery--right">
        {% for block in section.blocks %}
          {%- liquid
            assign side = block.settings.side
            if side == blank or side == 'auto'
              assign parity = forloop.index0 | modulo: 2
              if parity == 0
                assign side = 'left'
              else
                assign side = 'right'
              endif
            endif
          -%}
          {% if side == 'right' %}{% render 'brand-shot', block: block %}{% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .brand-promise {
    position: relative;
    overflow: hidden;
    padding-block: 36px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--bp-bg, #060c11);
    color: var(--bp-text, #f6f7f2);
    text-align: center;
  }

  .brand-promise__layout {
    position: relative;
    z-index: 1;
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
    justify-items: center;
  }

  .brand-promise__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 72ch;
    margin-inline: auto;
    text-align: center;
  }

  /* ---- In-action framed galleries ---- */
  .brand-promise__gallery {
    display: flex;
    gap: 16px;
    width: 100%;
    max-width: 520px;
  }

  .brand-promise__shot {
    position: relative;
    margin: 0;
    flex: 0 0 auto;
    width: clamp(116px, 38vw, 170px);
    padding: 6px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--bp-text, #f6f7f2) 12%, transparent);
    background: color-mix(in srgb, var(--bp-text, #f6f7f2) 5%, transparent);
    box-shadow:
      0 18px 40px -24px rgba(0, 0, 0, 0.85),
      inset 0 0 0 1px color-mix(in srgb, var(--bp-accent, #2dd4bf) 8%, transparent);
    transition:
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.32s ease,
      border-color 0.32s ease;
  }

  .brand-promise__shot-img,
  .brand-promise__shot-ph {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 11px;
  }

  .brand-promise__shot-ph {
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--bp-text, #f6f7f2) 6%, transparent);
  }

  .brand-promise__shot-svg {
    width: 46%;
    height: 46%;
    opacity: 0.35;
    fill: var(--bp-muted, #9aa8a2);
  }

  .brand-promise__shot-cap {
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 6px;
    padding: 6px 9px;
    border-radius: 10px;
    background: color-mix(in srgb, #000000 55%, transparent);
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.25;
    text-transform: none;
    letter-spacing: 0;
    color: var(--bp-text, #f6f7f2);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .brand-promise__shot:hover .brand-promise__shot-cap {
    opacity: 1;
    transform: none;
  }

  /* Playful, organic tilt per side */
  .brand-promise__gallery--left .brand-promise__shot:nth-child(odd) {
    transform: rotate(-4deg);
  }

  @media (max-width: 767px) {
    .brand-promise__gallery--left .brand-promise__shot,
    .brand-promise__gallery--right .brand-promise__shot {
      transform: none !important;
    }
  }

  .brand-promise__gallery--left .brand-promise__shot:nth-child(even) {
    transform: rotate(2deg);
  }

  .brand-promise__gallery--right .brand-promise__shot:nth-child(odd) {
    transform: rotate(4deg);
  }

  .brand-promise__gallery--right .brand-promise__shot:nth-child(even) {
    transform: rotate(-2deg);
  }

  .brand-promise__shot:hover {
    transform: rotate(0deg) translateY(-6px) scale(1.04);
    z-index: 3;
    border-color: color-mix(in srgb, var(--bp-accent, #2dd4bf) 45%, transparent);
    box-shadow:
      0 28px 54px -22px rgba(0, 0, 0, 0.9),
      inset 0 0 0 1px color-mix(in srgb, var(--bp-accent, #2dd4bf) 30%, transparent);
  }

  /* Mobile / tablet: pair of shots fills the row and stays centered */
  @media (max-width: 989px) {
    .brand-promise__gallery {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      max-width: min(520px, 100%);
      margin-inline: auto;
      justify-items: stretch;
      overflow: visible;
      padding-block: 6px;
    }

    .brand-promise__shot {
      width: 100%;
      max-width: none;
      flex: none;
    }
  }

  .brand-promise__kicker {
    margin: 0 0 14px;
    font-family: var(--font-brand);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    color: var(--bp-accent, #2dd4bf);
  }

  .brand-promise__text {
    margin: 0;
    width: max-content;
    max-width: 100%;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    align-self: center;
    gap: 0;
    font-family: var(--font-brand);
    font-size: clamp(1.5rem, 5vw, 2.6rem);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    text-align: left;
    color: var(--bp-text, #f6f7f2);
  }

  .brand-promise__line {
    display: inline-block;
  }

  .brand-promise__initial {
    color: var(--bp-accent, #2dd4bf);
    text-shadow: 0 0 8px color-mix(in srgb, var(--bp-accent, #2dd4bf) 30%, transparent);
  }

  .brand-promise__sub {
    margin: 14px auto 0;
    max-width: 36ch;
    width: 100%;
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: center;
    text-wrap: pretty;
    color: var(--bp-muted, #9aa8a2);
  }

  @media (prefers-reduced-motion: no-preference) {
    .brand-promise__line {
      opacity: 0;
      transform: translateY(16px);
      animation: bp-line 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: calc(var(--line-index, 0) * 0.14s);
    }

    .brand-promise__initial {
      animation: bp-glow 3.2s ease-in-out infinite;
      animation-delay: calc(0.9s + var(--line-index, 0) * 0.8s);
    }
  }

  @keyframes bp-line {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes bp-glow {
    0% {
      color: var(--bp-accent, #2dd4bf);
      text-shadow: 0 0 8px color-mix(in srgb, var(--bp-accent, #2dd4bf) 30%, transparent);
    }
    8% {
      color: color-mix(in srgb, var(--bp-accent, #2dd4bf) 60%, #fff);
      text-shadow:
        0 0 14px color-mix(in srgb, var(--bp-accent, #2dd4bf) 90%, #fff),
        0 0 34px color-mix(in srgb, var(--bp-accent, #2dd4bf) 80%, transparent);
    }
    25%,
    100% {
      color: var(--bp-accent, #2dd4bf);
      text-shadow: 0 0 8px color-mix(in srgb, var(--bp-accent, #2dd4bf) 30%, transparent);
    }
  }

  @media screen and (min-width: 750px) {
    .brand-promise {
      padding-block: 48px;
    }

    .brand-promise__sub {
      max-width: 48ch;
    }
  }

  @media screen and (min-width: 990px) {
    .brand-promise__layout {
      grid-template-columns: 1fr auto 1fr;
      gap: 28px;
    }

    .brand-promise__gallery {
      flex-direction: column;
      width: auto;
      gap: 20px;
    }

    .brand-promise__gallery--left {
      align-items: flex-end;
    }

    .brand-promise__gallery--right {
      align-items: flex-start;
    }

    .brand-promise__shot {
      width: clamp(150px, 13vw, 190px);
    }

    /* Scattered, overlapping clusters — spread on width, overlap on height
       so the section stays compact instead of a tall vertical stack. */
    .brand-promise__gallery--left .brand-promise__shot:nth-child(1) {
      transform: rotate(-5deg) translateX(-16%);
    }

    .brand-promise__gallery--left .brand-promise__shot:nth-child(2) {
      transform: rotate(3deg) translateX(22%);
      margin-top: -38px;
    }

    .brand-promise__gallery--right .brand-promise__shot:nth-child(1) {
      transform: rotate(5deg) translateX(16%);
    }

    .brand-promise__gallery--right .brand-promise__shot:nth-child(2) {
      transform: rotate(-3deg) translateX(-22%);
      margin-top: -38px;
    }

    /* Keep the straighten-on-hover behaviour above the offset transforms. */
    .brand-promise__gallery .brand-promise__shot:hover {
      transform: rotate(0deg) translateY(-6px) scale(1.04);
    }
  }

  @media screen and (min-width: 1200px) {
    .brand-promise__sub {
      text-wrap: balance;
      max-width: 52ch;
    }
  }

  /* Touch devices have no hover: keep captions visible so the labels read. */
  @media (hover: none) {
    .brand-promise__shot-cap {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-promise__shot {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand promise",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "shot",
      "name": "In-action image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "Shown on hover. Optional."
        },
        {
          "type": "select",
          "id": "side",
          "label": "Side",
          "default": "auto",
          "options": [
            { "value": "auto", "label": "Auto (alternate)" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_aurora",
      "label": "Show animated aurora background",
      "default": true
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "pump"
    },
    {
      "type": "text",
      "id": "promise",
      "label": "Promise",
      "default": "Portable Utilities Made Perfect"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Smarta, portabla lösningar som följer med överallt, idag duschen, snart mycket mer..."
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#060C11" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "presets": [
    {
      "name": "Brand promise",
      "blocks": [
        { "type": "shot", "settings": { "side": "left", "caption": "Bastu" } },
        { "type": "shot", "settings": { "side": "left", "caption": "Camping" } },
        { "type": "shot", "settings": { "side": "right", "caption": "Stranden" } },
        { "type": "shot", "settings": { "side": "right", "caption": "Husbil" } }
      ]
    }
  ]
}
{% endschema %}

