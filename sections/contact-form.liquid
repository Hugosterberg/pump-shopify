{% comment %}
  Contact form — uses Shopify's native {% form 'contact' %}.
  Submissions are emailed to the store's Sender email
  (Admin → Settings → Notifications → Sender email).
  Set that to info@pumpportable.com to receive messages there.
{% endcomment %}

<div
  class="contact-section full-width"
  style="
    --ct-bg: {{ section.settings.background_color }};
    --ct-surface: {{ section.settings.surface_color }};
    --ct-text: {{ section.settings.text_color }};
    --ct-muted: {{ section.settings.muted_text_color }};
    --ct-accent: {{ section.settings.accent_color }};
  "
>
  <div class="contact-section__inner">
    <div class="contact-section__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="contact-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="contact-section__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.body != blank %}
        <div class="contact-section__body rte">{{ section.settings.body }}</div>
      {% endif %}

      <ul class="contact-section__details" role="list">
        {% if section.settings.email != blank %}
          <li>
            <span class="contact-section__detail-label">E-post</span>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </li>
        {% endif %}
        {% if section.settings.phone != blank %}
          <li>
            <span class="contact-section__detail-label">Telefon</span>
            <a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a>
          </li>
        {% endif %}
        {% if section.settings.instagram_url != blank %}
          <li>
            <span class="contact-section__detail-label">Instagram</span>
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">@pumpportable_</a>
          </li>
        {% endif %}
      </ul>
    </div>

    <div class="contact-section__form-wrap">
      {% form 'contact', class: 'contact-form' %}
        {% if form.posted_successfully? %}
          <p class="contact-form__success" tabindex="-1" autofocus>
            {{ section.settings.success_message | default: 'Tack! Ditt meddelande har skickats. Vi återkommer så snart vi kan.' }}
          </p>
        {% elsif form.errors %}
          <div class="contact-form__error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="contact-form__field">
          <label for="ContactName">{{ section.settings.name_label | default: 'Namn' }}</label>
          <input
            type="text"
            id="ContactName"
            name="contact[name]"
            autocomplete="name"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          >
        </div>

        <div class="contact-form__field">
          <label for="ContactEmail">{{ section.settings.email_label | default: 'E-post' }} *</label>
          <input
            type="email"
            id="ContactEmail"
            name="contact[email]"
            spellcheck="false"
            autocapitalize="off"
            autocomplete="email"
            required
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          >
        </div>

        <div class="contact-form__field">
          <label for="ContactPhone">{{ section.settings.phone_label | default: 'Telefon (valfritt)' }}</label>
          <input
            type="tel"
            id="ContactPhone"
            name="contact[phone]"
            autocomplete="tel"
            value="{% if form.phone %}{{ form.phone }}{% endif %}"
          >
        </div>

        <div class="contact-form__field">
          <label for="ContactBody">{{ section.settings.message_label | default: 'Meddelande' }} *</label>
          <textarea id="ContactBody" name="contact[body]" rows="6" required>
            {%- if form.body -%}{{ form.body }}{%- endif -%}
          </textarea>
        </div>

        <button type="submit" class="contact-form__submit">
          {{ section.settings.submit_label | default: 'Skicka meddelande' }}
        </button>
      {% endform %}
    </div>
  </div>
</div>

{% stylesheet %}
  .contact-section {
    padding-block: 56px 80px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--ct-bg, #071014);
    color: var(--ct-text, #f6f7f2);
  }

  .contact-section__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .contact-section__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ct-accent, #2dd4bf);
  }

  .contact-section__heading {
    margin: 0 0 16px;
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .contact-section__body {
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ct-muted, #9aa8a2);
  }

  .contact-section__details {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-section__details li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-section__detail-label {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ct-muted, #9aa8a2);
  }

  .contact-section__details a {
    color: var(--ct-text, #f6f7f2);
    text-decoration: none;
    font-weight: 600;
  }

  .contact-section__details a:hover {
    color: var(--ct-accent, #2dd4bf);
  }

  .contact-form {
    background-color: var(--ct-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--ct-text, #f6f7f2) 8%, transparent);
    border-radius: 18px;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-form__field label {
    font-size: 0.88rem;
    font-weight: 600;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--ct-text, #f6f7f2) 16%, transparent);
    background-color: color-mix(in srgb, var(--ct-bg, #071014) 60%, transparent);
    color: var(--ct-text, #f6f7f2);
    font-size: 1rem;
    font-family: inherit;
  }

  .contact-form__field textarea {
    resize: vertical;
  }

  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: 2px solid var(--ct-accent, #2dd4bf);
    outline-offset: 1px;
    border-color: transparent;
  }

  .contact-form__submit {
    align-self: flex-start;
    min-height: 52px;
    padding-inline: 30px;
    border: none;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    color: #06231f;
    background-color: var(--ct-accent, #2dd4bf);
  }

  .contact-form__submit:hover {
    filter: brightness(1.05);
  }

  .contact-form__success {
    margin: 0;
    padding: 14px 16px;
    border-radius: 12px;
    background-color: color-mix(in srgb, var(--ct-accent, #2dd4bf) 18%, transparent);
    color: var(--ct-text, #f6f7f2);
    font-weight: 600;
  }

  .contact-form__error {
    margin: 0;
    padding: 14px 16px;
    border-radius: 12px;
    background-color: color-mix(in srgb, #f87171 22%, transparent);
    color: var(--ct-text, #f6f7f2);
  }

  @media screen and (min-width: 750px) {
    .contact-section {
      padding-block: 80px 110px;
    }

    .contact-section__inner {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: start;
    }

    .contact-form {
      padding: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Submissions are sent to your store's Sender email (Settings → Notifications → Sender email). Set it to info@pumpportable.com and verify your domain to receive messages there."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kontakta oss"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Säg hej!"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Intro text",
      "default": "<p>Har du en idé, vill samarbeta eller bara säga hej? Hör gärna av dig, vi svarar så snart vi kan.</p>"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email (shown)",
      "default": "info@pumpportable.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone (shown, optional)"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "header",
      "content": "Form labels"
    },
    { "type": "text", "id": "name_label", "label": "Name label", "default": "Namn" },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "E-post" },
    { "type": "text", "id": "phone_label", "label": "Phone label", "default": "Telefon (valfritt)" },
    { "type": "text", "id": "message_label", "label": "Message label", "default": "Meddelande" },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Skicka meddelande" },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success message",
      "default": "Tack! Ditt meddelande har skickats. Vi återkommer så snart vi kan."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
