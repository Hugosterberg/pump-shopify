        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#071014"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Optional. A small monochrome icon works best."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "USB-C laddning"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Premium hero",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "USB-C laddning" } },
        { "type": "trust_badge", "settings": { "label": "~150 min batteritid" } },
        { "type": "trust_badge", "settings": { "label": "Väger ca 1 kg" } }
      ]
    }
  ]
}
{% endschema %}

