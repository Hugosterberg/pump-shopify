{% comment %}
  Shopify policy pages (privacy, terms, refund, shipping).
  Uses the global policy object from /policies/* routes.
{% endcomment %}

<div
  class="legal-page full-width pp-accent-line"
  style="
    --legal-bg: {{ section.settings.background_color }};
    --legal-surface: {{ section.settings.surface_color }};
    --legal-text: {{ section.settings.text_color }};
    --legal-muted: {{ section.settings.muted_text_color }};
    --legal-accent: {{ section.settings.accent_color }};
  "
>
  <div class="legal-page__inner">
    <header class="legal-page__header">
      {% if section.settings.eyebrow != blank %}
        <p class="legal-page__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="legal-page__title">{{ policy.title }}</h1>
      {% if section.settings.intro != blank %}
        <div class="legal-page__intro pp-legal-prose rte">{{ section.settings.intro }}</div>
      {% endif %}
    </header>

    <div class="legal-page__panel">
      <div class="legal-page__content pp-legal-prose rte">
        {{ policy.body }}
      </div>
    </div>

    {% if section.settings.contact_note != blank %}
      <div class="legal-page__contact pp-legal-prose rte">{{ section.settings.contact_note }}</div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Policy page",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Juridisk information"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro (optional)",
      "info": "Shown under the policy title before the main policy text."
    },
    {
      "type": "richtext",
      "id": "contact_note",
      "label": "Contact note",
      "default": "<p>Har du frågor? Mejla oss på <a href=\"mailto:info@pumpportable.com\">info@pumpportable.com</a> så hjälper vi dig.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ]
}
{% endschema %}
