{% comment %}
  Feature highlights — a spec pill strip + detailed feature columns.
  Mirrors the live site's "Why a portable shower?" section.
  Block types:
    - spec    → rendered as a pill in the top strip
    - feature → rendered as a column card below
{% endcomment %}

<div
  class="feature-highlights full-width"
  style="
    --fh-bg: {{ section.settings.background_color }};
    --fh-surface: {{ section.settings.surface_color }};
    --fh-text: {{ section.settings.text_color }};
    --fh-muted: {{ section.settings.muted_text_color }};
    --fh-accent: {{ section.settings.accent_color }};
  "
>
  <div class="feature-highlights__inner">
    {% if section.settings.heading != blank %}
      <header class="feature-highlights__header">
        {% if section.settings.eyebrow != blank %}
          <p class="feature-highlights__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="feature-highlights__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="feature-highlights__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% assign spec_blocks = section.blocks | where: 'type', 'spec' %}
    {% if spec_blocks.size > 0 %}
      <ul class="feature-highlights__specs" role="list">
        {% for block in spec_blocks %}
          <li class="feature-highlights__spec" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank and block.settings.icon != 'none' %}
              <span class="feature-highlights__spec-icon">{% render 'icon', name: block.settings.icon, size: 16 %}</span>
            {% else %}
              <span class="feature-highlights__spec-dot" aria-hidden="true"></span>
            {% endif %}
            {{ block.settings.label }}
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    {% assign feature_blocks = section.blocks | where: 'type', 'feature' %}
    {% if feature_blocks.size > 0 %}
      <ul class="feature-highlights__grid" role="list">
        {% for block in feature_blocks %}
          <li class="feature-highlights__card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="feature-highlights__media">
                {{
                  block.settings.image
                  | image_url: width: 700
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 500, 700',
                    sizes: '(min-width: 750px) 33vw, 100vw',
                    alt: block.settings.title
                }}
              </div>
            {% endif %}
            <div class="feature-highlights__card-body">
              {% if block.settings.icon != blank and block.settings.icon != 'none' %}
                <span class="feature-highlights__icon-badge">{% render 'icon', name: block.settings.icon, size: 24 %}</span>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="feature-highlights__card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="feature-highlights__card-text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .feature-highlights {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--fh-bg, #071014);
    color: var(--fh-text, #f6f7f2);
  }

  .feature-highlights__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .feature-highlights__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 32px;
  }

  .feature-highlights__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fh-accent, #2dd4bf);
  }

  .feature-highlights__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .feature-highlights__subheading {
    margin: 0;
    color: var(--fh-muted, #9aa8a2);
    line-height: 1.6;
  }

  .feature-highlights__specs {
    list-style: none;
    margin: 0 0 48px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .feature-highlights__spec {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 600;
    background-color: var(--fh-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--fh-accent, #2dd4bf) 30%, transparent);
    transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }

  .feature-highlights__spec:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--fh-accent, #2dd4bf) 65%, transparent);
    background-color: color-mix(in srgb, var(--fh-accent, #2dd4bf) 10%, var(--fh-surface, #111c24));
  }

  .feature-highlights__spec-icon {
    display: inline-flex;
    color: var(--fh-accent, #2dd4bf);
  }

  .feature-highlights__spec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--fh-accent, #2dd4bf);
  }

  .feature-highlights__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .feature-highlights__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    background-color: var(--fh-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--fh-text, #f6f7f2) 8%, transparent);
    transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
  }

  .feature-highlights__card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(140deg, color-mix(in srgb, var(--fh-accent, #2dd4bf) 55%, transparent), transparent 45%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.22s ease;
    pointer-events: none;
  }

  .feature-highlights__card:hover {
    transform: translateY(-5px);
    border-color: transparent;
    box-shadow: 0 18px 40px -22px color-mix(in srgb, var(--fh-accent, #2dd4bf) 80%, #000);
  }

  .feature-highlights__card:hover::before {
    opacity: 1;
  }

  .feature-highlights__icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    color: var(--fh-accent, #2dd4bf);
    background-color: color-mix(in srgb, var(--fh-accent, #2dd4bf) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--fh-accent, #2dd4bf) 30%, transparent);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .feature-highlights__card:hover .feature-highlights__icon-badge {
    transform: scale(1.06);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--fh-accent, #2dd4bf) 12%, transparent);
  }

  .feature-highlights__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .feature-highlights__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feature-highlights__card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feature-highlights__card-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .feature-highlights__card-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--fh-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .feature-highlights {
      padding-block: 68px;
    }

    .feature-highlights__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) and (min-width: 750px) {
      .feature-highlights__card {
        animation: fh-reveal linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 28%;
      }

      .feature-highlights__spec {
        animation: fh-reveal linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 22%;
      }
    }
  }

  @keyframes fh-reveal {
    from {
      opacity: 0;
      transform: translateY(26px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-highlights__spec,
    .feature-highlights__card,
    .feature-highlights__icon-badge {
      transition: none;
    }

    .feature-highlights__spec:hover,
    .feature-highlights__card:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature highlights",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Funktioner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Varför en portabel dusch från PUMP?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec pill",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None (dot)" },
            { "value": "battery", "label": "Battery" },
            { "value": "bolt", "label": "Bolt / fast charge" },
            { "value": "usb", "label": "USB-C" },
            { "value": "thermometer", "label": "Thermometer / display" },
            { "value": "sliders", "label": "Sliders / pressure" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "droplets", "label": "Droplets / nozzles" },
            { "value": "shield", "label": "Shield / warranty" },
            { "value": "truck", "label": "Truck / shipping" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "feather", "label": "Feather / lightweight" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Lång batteritid" }
      ]
    },
    {
      "type": "feature",
      "name": "Feature column",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "battery", "label": "Battery" },
            { "value": "bolt", "label": "Bolt / fast charge" },
            { "value": "usb", "label": "USB-C" },
            { "value": "thermometer", "label": "Thermometer / display" },
            { "value": "sliders", "label": "Sliders / pressure" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "droplets", "label": "Droplets / nozzles" },
            { "value": "package", "label": "Package / portable" },
            { "value": "shield", "label": "Shield / warranty" },
            { "value": "truck", "label": "Truck / shipping" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "feather", "label": "Feather / lightweight" }
          ],
          "default": "feather"
        },
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Smart & portabel design" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Duschen väger ca 1 kg och är enkel att ta med överallt." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Feature highlights",
      "blocks": [
        { "type": "spec", "settings": { "icon": "battery", "label": "Lång batteritid" } },
        { "type": "spec", "settings": { "icon": "bolt", "label": "Snabbladdning via USB-C" } },
        { "type": "spec", "settings": { "icon": "thermometer", "label": "Digital display för temperatur & batteri" } },
        { "type": "spec", "settings": { "icon": "sliders", "label": "Justerbart tryck" } },
        { "type": "spec", "settings": { "icon": "droplets", "label": "2 olika munstycken" } },
        { "type": "feature", "settings": { "icon": "feather", "title": "Smart & portabel design", "text": "Duschen väger ca 1 kg och är enkel att ta med överallt. Fäst den med sugpropp på en vägg, häng upp den i en krok eller håll den i handen, perfekt för camping, bastu eller friluftsliv." } },
        { "type": "feature", "settings": { "icon": "thermometer", "title": "Batteritid & display", "text": "Upp till 150 minuters drift per laddning. Den inbyggda displayen visar både vattentemperatur och batterinivå för total överblick. Laddas smidigt med USB-C." } },
        { "type": "feature", "settings": { "icon": "sliders", "title": "Justerbart tryck & flexibla munstycken", "text": "Slå enkelt av/på vattnet genom duschmunstyckena eller justera trycket efter dina behov." } }
      ]
    }
  ]
}
{% endschema %}
