<div
  class="faq-section full-width"
  style="
    --faq-bg: {{ section.settings.background_color }};
    --faq-surface: {{ section.settings.surface_color }};
    --faq-text: {{ section.settings.text_color }};
    --faq-muted: {{ section.settings.muted_text_color }};
    --faq-accent: {{ section.settings.accent_color }};
  "
>
  <div class="faq-section__inner">
    {% if section.settings.heading != blank %}
      <header class="faq-section__header">
        {% if section.settings.eyebrow != blank %}
          <p class="faq-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="faq-section__heading">{{ section.settings.heading }}</h2>
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="faq-section__list">
        {% assign current_category = '' %}
        {% for block in section.blocks %}
          {% if block.settings.category != blank and block.settings.category != current_category %}
            {% assign current_category = block.settings.category %}
            <h3 class="faq-section__category">{{ block.settings.category }}</h3>
          {% endif %}
          <details class="faq-section__item" {{ block.shopify_attributes }}>
            <summary class="faq-section__question">
              <span>{{ block.settings.question }}</span>
              <span class="faq-section__icon" aria-hidden="true"></span>
            </summary>
            {% if block.settings.answer != blank %}
              <div class="faq-section__answer">
                {{ block.settings.answer }}
              </div>
            {% endif %}
          </details>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.show_cta %}
      <div class="faq-section__cta">
        <div class="faq-section__cta-copy">
          {% if section.settings.cta_heading != blank %}
            <p class="faq-section__cta-heading">{{ section.settings.cta_heading }}</p>
          {% endif %}
          {% if section.settings.cta_text != blank %}
            <p class="faq-section__cta-text">{{ section.settings.cta_text }}</p>
          {% endif %}
        </div>

        {% if section.settings.cta_button_label != blank %}
          <a class="faq-section__cta-btn" href="{{ section.settings.cta_button_link | default: '#product-showcase' }}">
            {{ section.settings.cta_button_label }}
            <span class="faq-section__cta-btn-icon" aria-hidden="true">→</span>
          </a>
        {% endif %}

        <div class="faq-section__cta-trust">
          {% render 'trust-near-atc', class_prefix: 'faq-section__trust', show_payment_icons: false, compact: true %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

{%- if section.blocks.size > 0 -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank and block.settings.answer != blank -%}
            {
              "@type": "Question",
              "name": {{ block.settings.question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ block.settings.answer | strip_html | json }}
              }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

{% stylesheet %}
  .faq-section {
    padding-block: 36px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--faq-bg, #071014);
    color: var(--faq-text, #f6f7f2);
  }

  .faq-section__inner {
    max-width: 680px;
    margin-inline: auto;
  }

  .faq-section__header {
    text-align: center;
    margin-bottom: 16px;
  }

  .faq-section__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faq-accent, #2dd4bf);
  }

  .faq-section__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .faq-section__list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .faq-section__category {
    margin: 16px 0 2px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faq-accent, #2dd4bf);
  }

  .faq-section__category:first-child {
    margin-top: 0;
  }

  .faq-section__item {
    border-radius: 14px;
    background-color: var(--faq-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--faq-text, #f6f7f2) 8%, transparent);
    overflow: hidden;
    transition: border-color 0.18s ease;
  }

  .faq-section__item:hover {
    border-color: color-mix(in srgb, var(--faq-accent, #2dd4bf) 35%, transparent);
  }

  .faq-section__item[open] {
    border-color: color-mix(in srgb, var(--faq-accent, #2dd4bf) 45%, transparent);
    background-color: color-mix(in srgb, var(--faq-accent, #2dd4bf) 6%, var(--faq-surface, #14212a));
  }

  .faq-section__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 9px 16px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-section__item[open] .faq-section__question {
    padding-bottom: 8px;
  }

  .faq-section__question::-webkit-details-marker {
    display: none;
  }

  .faq-section__icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    position: relative;
  }

  .faq-section__icon::before,
  .faq-section__icon::after {
    content: '';
    position: absolute;
    background-color: var(--faq-accent, #2dd4bf);
    border-radius: 1px;
    transition: transform 0.2s ease;
  }

  .faq-section__icon::before {
    top: 50%;
    left: 2px;
    right: 2px;
    height: 2px;
    margin-top: -1px;
  }

  .faq-section__icon::after {
    left: 50%;
    top: 2px;
    bottom: 2px;
    width: 2px;
    margin-left: -1px;
  }

  .faq-section__item[open] .faq-section__icon::after {
    transform: rotate(90deg);
    opacity: 0;
  }

  .faq-section__answer {
    padding: 0 16px 14px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--faq-muted, #9aa8a2);
  }

  .faq-section__answer > * {
    margin: 0;
  }

  .faq-section__cta {
    margin-top: 28px;
    padding: clamp(26px, 5vw, 34px);
    border-radius: var(--pp-radius-lg, 20px);
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--faq-accent, #2dd4bf) 8%, var(--faq-surface, #14212a)) 0%,
      var(--faq-surface, #14212a) 100%
    );
    border: 1px solid color-mix(in srgb, var(--faq-accent, #2dd4bf) 22%, transparent);
    box-shadow: var(--pp-shadow-soft);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .faq-section__cta-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    max-width: 36rem;
  }

  .faq-section__cta-heading {
    margin: 0;
    font-size: clamp(1.05rem, 2.8vw, 1.2rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--faq-text, #f6f7f2);
    text-wrap: balance;
  }

  .faq-section__cta-text {
    margin: 0;
    font-size: clamp(0.88rem, 2.3vw, 0.94rem);
    line-height: 1.55;
    color: var(--faq-muted, #9aa8a2);
    text-wrap: pretty;
    max-width: 34ch;
  }

  .faq-section__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 52px;
    padding-inline: 30px;
    border-radius: 999px;
    font-weight: 600;
    font-size: clamp(0.92rem, 2.4vw, 0.98rem);
    text-decoration: none;
    color: var(--faq-accent-ink, #071014);
    background: linear-gradient(135deg, var(--faq-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 30%, var(--faq-accent, #2dd4bf)));
    box-shadow: var(--pp-shadow-glow);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .faq-section__cta-btn-icon {
    display: inline-flex;
    transition: transform 0.18s ease;
  }

  .faq-section__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -16px color-mix(in srgb, var(--faq-accent, #2dd4bf) 85%, #000);
  }

  .faq-section__cta-btn:hover .faq-section__cta-btn-icon {
    transform: translateX(3px);
  }

  .faq-section__cta-trust {
    width: 100%;
    padding-top: 18px;
    border-top: 1px solid color-mix(in srgb, var(--faq-text, #f6f7f2) 8%, transparent);
  }

  .faq-section__cta-trust .pp-trust-atc--compact {
    width: 100%;
    margin: 0;
    gap: 8px;
  }

  .faq-section__cta-trust .pp-trust-atc__pill {
    width: 100%;
    justify-content: flex-start;
    text-align: left;
  }

  @media screen and (min-width: 560px) {
    .faq-section__cta-trust .pp-trust-atc--compact {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .faq-section__cta-trust .pp-trust-atc__pill {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 92px;
      padding: 14px 12px;
      border-radius: 16px;
      text-align: center;
    }

    .faq-section__cta-trust .pp-trust-atc__pill-icon {
      width: 36px;
      height: 36px;
    }

    .faq-section__cta-trust .pp-trust-atc__pill-text {
      text-align: center;
      font-size: 0.78rem;
      line-height: 1.3;
    }
  }

  @media screen and (min-width: 750px) {
    .faq-section {
      padding-block: 48px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-section__icon::before,
    .faq-section__icon::after,
    .faq-section__cta-btn,
    .faq-section__cta-btn-icon {
      transition: none;
    }

    .faq-section__cta-btn:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Vanliga frågor"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "header",
      "content": "CTA after FAQ"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA box after questions",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Fortfarande osäker?"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Köp tryggt med 14 dagars ångerrätt, 1 års garanti och fri frakt över 999 kr."
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "CTA button label",
      "default": "Till köpboxen"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "category",
          "label": "Category (groups questions with the same name)"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Hur länge räcker batteriet?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Med full laddning får du ~150 minuters drift, beroende på flödesinställning.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Hur länge räcker batteriet?",
            "answer": "<p>Med full laddning får du ~150 minuters drift, beroende på flödesinställning.</p>"
          }
        },
        {
