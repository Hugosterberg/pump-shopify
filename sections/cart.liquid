{% comment %}
  Cart page — preserves Shopify cart form, updates and checkout.
{% endcomment %}

<div class="main-cart full-width">
  <div class="main-cart__inner">
    <h1 class="main-cart__title">{{ 'cart.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <form class="main-cart__form" action="{{ routes.cart_url }}" method="post">
        <ul class="main-cart__items" role="list">
          {% for item in cart.items %}
            <li class="main-cart__item">
              <a class="main-cart__image" href="{{ item.url }}">
                {% if item.image %}
                  {{
                    item.image
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', widths: '100, 200', sizes: '100px', alt: item.product.title
                  }}
                {% endif %}
              </a>
              <div class="main-cart__details">
                <a class="main-cart__name" href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="main-cart__variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="main-cart__price">{{ item.final_line_price | money }}</p>
                <a class="main-cart__remove" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
              </div>
              <div class="main-cart__qty">
                <label class="visually-hidden" for="Cart-Qty-{{ item.index }}">Antal</label>
                <input
                  id="Cart-Qty-{{ item.index }}"
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                >
              </div>
            </li>
          {% endfor %}
        </ul>

        <div class="main-cart__footer">
          <button class="main-cart__update" type="submit" name="update">
            {{ 'cart.update' | t }}
          </button>
          <div class="main-cart__summary">
            <p class="main-cart__subtotal">
              <span>Delsumma</span>
              <strong>{{ cart.total_price | money }}</strong>
            </p>
            <button class="main-cart__checkout" type="submit" name="checkout">
              {{ 'cart.checkout' | t }}
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="main-cart__empty">
        <p>Varukorgen är tom.</p>
        <a class="main-cart__continue" href="{{ routes.all_products_collection_url }}">Fortsätt handla</a>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .main-cart {
    padding-block: 48px 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pp-bg-deep, #071014);
    color: var(--pp-text, #f6f7f2);
    min-height: 50vh;
  }

  .main-cart__inner {
    max-width: 720px;
    margin-inline: auto;
  }

  .main-cart__title {
    margin: 0 0 32px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    letter-spacing: -0.02em;
  }

  .main-cart__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .main-cart__item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 20px;
    border-radius: 16px;
    background-color: var(--pp-surface, #14212a);
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
  }

  .main-cart__image {
    display: block;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .main-cart__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-cart__name {
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-text, #f6f7f2);
  }

  .main-cart__variant,
  .main-cart__price {
    margin: 4px 0 0;
    font-size: 0.88rem;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-cart__remove {
    display: inline-block;
    margin-top: 8px;
    font-size: 0.82rem;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-cart__qty input {
    width: 64px;
    min-height: 44px;
    padding: 0 10px;
    border-radius: 8px;
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    background-color: var(--pp-bg-deep, #071014);
    color: var(--pp-text, #f6f7f2);
    text-align: center;
  }

  .main-cart__footer {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .main-cart__update {
    align-self: flex-start;
    min-height: 44px;
    padding-inline: 20px;
    border-radius: 999px;
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    background: transparent;
    color: var(--pp-text, #f6f7f2);
    font-weight: 500;
    cursor: pointer;
  }

  .main-cart__summary {
    padding: 24px;
    border-radius: 16px;
    background-color: var(--pp-surface, #14212a);
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .main-cart__subtotal {
    margin: 0;
    display: flex;
    justify-content: space-between;
    font-size: 1rem;
  }

  .main-cart__checkout {
    width: 100%;
    min-height: 54px;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    color: var(--pp-bg-deep, #071014);
    background-color: var(--pp-accent, #2dd4bf);
  }

  .main-cart__empty {
    text-align: center;
    padding: 48px 24px;
    border-radius: 16px;
    background-color: var(--pp-surface, #14212a);
    color: var(--pp-muted, #9aa8a2);
  }

  .main-cart__continue {
    display: inline-flex;
    margin-top: 16px;
    min-height: 48px;
    padding-inline: 24px;
    align-items: center;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-bg-deep, #071014);
    background-color: var(--pp-accent, #2dd4bf);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 549px) {
    .main-cart__item {
      grid-template-columns: 72px 1fr;
    }

    .main-cart__qty {
      grid-column: 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
