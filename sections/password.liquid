{% comment %}
  Password page — preserves storefront_password form.
{% endcomment %}

<div class="main-password full-width">
  <div class="main-password__inner">
    {% if section.settings.logo != blank %}
      {{
        section.settings.logo
        | image_url: width: 240
        | image_tag: loading: 'eager', class: 'main-password__logo', alt: shop.name
      }}
    {% else %}
      <h1 class="main-password__shop">{{ shop.name }}</h1>
    {% endif %}

    <p class="main-password__title">{{ 'password.title' | t }}</p>

    {% if shop.password_message != blank %}
      <p class="main-password__message">{{ shop.password_message }}</p>
    {% endif %}

    {% form 'storefront_password', class: 'main-password__form' %}
      {{ form.errors | default_errors }}

      <label class="main-password__label" for="password-input">
        {{ 'password.password' | t }}
      </label>
      <input
        class="main-password__input"
        type="password"
        name="password"
        id="password-input"
        autocomplete="current-password"
      >
      <button class="main-password__submit" type="submit">
        {{ 'password.enter' | t }}
      </button>
    {% endform %}
  </div>
</div>

{% stylesheet %}
  .main-password {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: var(--page-margin, 20px);
    background-color: var(--pp-bg-deep, #071014);
    color: var(--pp-text, #f6f7f2);
    text-align: center;
  }

  .main-password__inner {
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .main-password__logo {
    height: 36px;
    width: auto;
    margin-bottom: 8px;
  }

  .main-password__shop {
    margin: 0 0 8px;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .main-password__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .main-password__message {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-password__form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
  }

  .main-password__label {
    text-align: left;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-password__input {
    width: 100%;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 10px;
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    background-color: var(--pp-surface, #14212a);
    color: var(--pp-text, #f6f7f2);
  }

  .main-password__submit {
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    cursor: pointer;
    color: var(--pp-bg-deep, #071014);
    background-color: var(--pp-accent, #2dd4bf);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
