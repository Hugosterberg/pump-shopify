{% comment %}
  Collection page — lists products with pagination. No hardcoded product data.
{% endcomment %}

<div class="main-collection full-width">
  <div class="main-collection__inner">
    <header class="main-collection__header">
      <h1 class="main-collection__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="main-collection__description">{{ collection.description }}</div>
      {% endif %}
    </header>

    {% paginate collection.products by section.settings.products_per_page %}
      {% if collection.products.size > 0 %}
        <ul class="main-collection__grid" role="list">
          {% for product in collection.products %}
            <li class="main-collection__card">
              <a class="main-collection__link" href="{{ product.url }}">
                <div class="main-collection__media">
                  {% if product.compare_at_price > product.price %}
                    {% assign saving = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                    <span class="main-collection__badge">SPARA {{ saving }}%</span>
                  {% endif %}
                  {% unless product.available %}
                    <span class="main-collection__badge main-collection__badge--soldout">Slutsåld</span>
                  {% endunless %}
                  {% if product.featured_image != blank %}
                    {{
                      product.featured_image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        sizes: '(min-width: 750px) 33vw, 50vw',
                        widths: '300, 500, 800',
                        alt: product.featured_image.alt | default: product.title
                    }}
                  {% else %}
                    <div class="main-collection__placeholder">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="main-collection__info">
                  <h2 class="main-collection__name">{{ product.title }}</h2>
                  <p class="main-collection__price">
                    {% if product.compare_at_price > product.price %}
                      <s class="main-collection__compare">{{ product.compare_at_price | money }}</s>
                    {% endif %}
                    <span>{{ product.price | money }}</span>
                  </p>
                </div>
              </a>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="main-collection__empty">Inga produkter i denna kollektion.</p>
      {% endif %}

      {% if paginate.pages > 1 %}
        <nav class="main-collection__pagination" aria-label="Sidnavigering">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% stylesheet %}
  .main-collection {
    padding-block: 48px 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pp-bg-deep, #071014);
    color: var(--pp-text, #f6f7f2);
    min-height: 50vh;
  }

  .main-collection__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .main-collection__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .main-collection__title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .main-collection__description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-collection__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .main-collection__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--pp-surface, #14212a);
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .main-collection__link:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--pp-accent, #2dd4bf) 45%, transparent);
    box-shadow: 0 18px 40px -24px color-mix(in srgb, var(--pp-accent, #2dd4bf) 70%, #000);
  }

  .main-collection__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--pp-text, #f6f7f2) 4%, transparent);
  }

  .main-collection__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .main-collection__link:hover .main-collection__media img {
    transform: scale(1.05);
  }

  .main-collection__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    padding: 5px 11px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #06231f;
    background-color: var(--pp-accent, #2dd4bf);
  }

  .main-collection__badge--soldout {
    top: auto;
    bottom: 12px;
    color: var(--pp-text, #f6f7f2);
    background-color: color-mix(in srgb, #000 55%, transparent);
  }

  .main-collection__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--pp-text, #f6f7f2) 20%, transparent);
  }

  .main-collection__info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .main-collection__name {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .main-collection__price {
    margin: 0;
    font-size: 0.9rem;
    color: var(--pp-accent, #2dd4bf);
    font-weight: 600;
  }

  .main-collection__compare {
    margin-right: 8px;
    color: var(--pp-muted, #9aa8a2);
    font-weight: 400;
  }

  .main-collection__empty {
    text-align: center;
    padding: 48px;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-collection__pagination {
    margin-top: 40px;
    text-align: center;
  }

  .main-collection__pagination a,
  .main-collection__pagination span {
    color: var(--pp-text, #f6f7f2);
  }

  @media screen and (min-width: 750px) {
    .main-collection {
      padding-block: 64px 96px;
    }

    .main-collection__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .main-collection__name {
      font-size: 1.05rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .main-collection__link {
      transition: none;
    }

    .main-collection__link:hover {
      transform: none;
    }

    .main-collection__link:hover .main-collection__media img {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
