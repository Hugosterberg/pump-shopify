<div
  class="review-cards full-width"
  style="
    --rc-bg: {{ section.settings.background_color }};
    --rc-surface: {{ section.settings.surface_color }};
    --rc-text: {{ section.settings.text_color }};
    --rc-muted: {{ section.settings.muted_text_color }};
    --rc-accent: {{ section.settings.accent_color }};
  "
>
  <div class="review-cards__inner">
    {% if section.settings.heading != blank %}
      <header class="review-cards__header">
        {% if section.settings.eyebrow != blank %}
          <p class="review-cards__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="review-cards__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="review-cards__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {%- liquid
      assign review_blocks = section.blocks | where: 'type', 'review'
      assign app_blocks = section.blocks | where: 'type', '@app'
      assign show_placeholders = section.settings.show_placeholder_reviews
      assign use_judgeme = section.settings.use_judgeme_widget
      assign trustpilot_html = section.settings.trustpilot_embed_html
      assign has_live_source = false

      if app_blocks.size > 0
        assign has_live_source = true
        assign show_placeholders = false
      endif

      if use_judgeme and product != blank and product.metafields.judgeme.widget != blank
        assign has_live_source = true
        assign show_placeholders = false
      endif

      if trustpilot_html != blank
        assign has_live_source = true
        assign show_placeholders = false
      endif
    -%}

    {% if app_blocks.size > 0 %}
      <div class="review-cards__apps">
        {% for block in section.blocks %}
          {% if block.type == '@app' %}
            <div class="review-cards__app" {{ block.shopify_attributes }}>
              {% render block %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% elsif use_judgeme and product != blank %}
      <div
        id="judgeme_product_reviews"
        class="review-cards__judgeme jdgm-widget jdgm-review-widget"
        data-id="{{ product.id }}"
        data-product-title="{{ product.title | escape }}"
      >
        {{ product.metafields.judgeme.widget }}
      </div>
    {% endif %}

    {% if trustpilot_html != blank %}
      <div class="review-cards__trustpilot">
        {{ trustpilot_html }}
      </div>
    {% endif %}

    {% if review_blocks.size > 0 and show_placeholders %}
      {%- liquid
        assign total_reviews = section.settings.total_review_count
        if total_reviews == blank or total_reviews < 1
          assign total_reviews = review_blocks.size
        endif

        assign rating_sum = 0
        assign rating_count = 0
        for block in review_blocks
          if block.settings.rating > 0
            assign rating_sum = rating_sum | plus: block.settings.rating
            assign rating_count = rating_count | plus: 1
          endif
        endfor
        if rating_count > 0
          assign avg_rating = rating_sum | times: 1.0 | divided_by: rating_count | round: 1
          assign avg_rounded = avg_rating | round
        else
          assign avg_rating = 5
          assign avg_rounded = 5
        endif
      -%}
      <div class="review-cards__summary">
        <div class="review-cards__summary-score">
          <span class="review-cards__summary-number">{{ avg_rating }}</span>
          <div class="review-cards__summary-stars" role="img" aria-label="{{ avg_rating }} av 5 stjärnor">
            {% for i in (1..5) %}
              <span class="review-cards__star{% if i > avg_rounded %} review-cards__star--empty{% endif %}" aria-hidden="true">★</span>
            {% endfor %}
          </div>
        </div>
        <p class="review-cards__summary-text">
          Baserat på <strong>{{ total_reviews }} omdömen</strong>
          {% if section.settings.summary_note != blank %} · {{ section.settings.summary_note }}{% endif %}
        </p>
      </div>

      <ul class="review-cards__list" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <li class="review-cards__card" {{ block.shopify_attributes }}>
              {% if block.settings.rating > 0 %}
                <div class="review-cards__stars" role="img" aria-label="{{ block.settings.rating }} av 5 stjärnor">
                  {% for i in (1..5) %}
                    <span class="review-cards__star{% if i > block.settings.rating %} review-cards__star--empty{% endif %}" aria-hidden="true">★</span>
                  {% endfor %}
                </div>
              {% endif %}
              {% if block.settings.quote != blank %}
                <p class="review-cards__text">{{ block.settings.quote }}</p>
              {% endif %}
              <footer class="review-cards__footer">
                <div class="review-cards__meta">
                  {% if block.settings.author != blank %}
                    <cite class="review-cards__author">{{ block.settings.author }}</cite>
                  {% endif %}
                  {% if block.settings.context != blank %}
                    <span class="review-cards__context">{{ block.settings.context }}</span>
                  {% endif %}
                </div>
                <span class="review-cards__verified">Verifierat köp</span>
              </footer>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% elsif has_live_source == false and review_blocks.size == 0 and request.design_mode %}
      <p class="review-cards__empty">
        Lägg till Judge.me- eller TrustView-appblock i den här sektionen, eller klistra in Trustpilot TrustBox-kod under sektionens inställningar.
      </p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .review-cards {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--rc-bg, #071014);
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .review-cards__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .review-cards__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .review-cards__subheading {
    margin: 0;
    color: var(--rc-muted, #9aa8a2);
    line-height: 1.6;
  }

  .review-cards__apps,
  .review-cards__judgeme,
  .review-cards__trustpilot {
    margin-top: 8px;
  }

  .review-cards__app + .review-cards__app,
  .review-cards__judgeme + .review-cards__trustpilot,
  .review-cards__apps + .review-cards__trustpilot {
    margin-top: 28px;
  }

  .review-cards__empty {
    margin: 0;
    padding: 28px 20px;
    text-align: center;
    color: var(--rc-muted, #9aa8a2);
    border: 1px dashed color-mix(in srgb, var(--rc-text, #f6f7f2) 16%, transparent);
    border-radius: 16px;
  }

  .review-cards__summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 32px;
    padding: 24px 28px;
    border-radius: 22px;
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--rc-accent, #2dd4bf) 12%, var(--rc-surface, #14212a)),
      var(--rc-surface, #14212a)
    );
    border: 1px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 28%, transparent);
    box-shadow: 0 16px 40px -24px color-mix(in srgb, var(--rc-accent, #2dd4bf) 55%, #000);
  }

  .review-cards__summary-score {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .review-cards__summary-number {
    font-size: clamp(2.4rem, 6vw, 3rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__summary-stars {
    display: flex;
    gap: 3px;
    font-size: 1.25rem;
  }

  .review-cards__summary-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--rc-muted, #9aa8a2);
  }

  .review-cards__summary-text strong {
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .review-cards__card {
    position: relative;
    height: 100%;
    padding: 22px 22px 18px;
    border-radius: 18px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--rc-text, #f6f7f2) 4%, var(--rc-surface, #14212a)),
      var(--rc-surface, #14212a)
    );
    border: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .review-cards__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 22px;
    right: 22px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--rc-accent, #2dd4bf) 70%, transparent),
      transparent
    );
    opacity: 0.85;
  }

  .review-cards__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--rc-accent, #2dd4bf) 40%, transparent);
    box-shadow: 0 16px 40px -24px color-mix(in srgb, var(--rc-accent, #2dd4bf) 45%, #000);
  }

  .review-cards__stars {
    display: flex;
    gap: 2px;
    font-size: 1rem;
    line-height: 1;
  }

  .review-cards__star {
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__star--empty {
    color: color-mix(in srgb, var(--rc-text, #f6f7f2) 20%, transparent);
  }

  .review-cards__text {
    margin: 0;
    font-size: clamp(0.94rem, 2.4vw, 1.02rem);
    line-height: 1.65;
    color: var(--rc-text, #f6f7f2);
    text-wrap: pretty;
    flex: 1;
  }

  .review-cards__footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
    padding-top: 4px;
    border-top: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 7%, transparent);
  }

  .review-cards__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
  }

  .review-cards__author {
    font-style: normal;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .review-cards__context {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--rc-muted, #9aa8a2);
    background: color-mix(in srgb, var(--rc-text, #f6f7f2) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 8%, transparent);
  }

  .review-cards__verified {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__verified::before {
    content: '✓';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    font-size: 0.62rem;
    background: color-mix(in srgb, var(--rc-accent, #2dd4bf) 16%, transparent);
  }

  /* Soften Judge.me / Trustpilot widgets on dark theme */
  .review-cards__judgeme,
  .review-cards__app,
  .review-cards__trustpilot {
    color: var(--rc-text, #f6f7f2);
  }

  /* ——— Judge.me: premium speech bubbles + sort ——— */
  .review-cards .jdgm-rev-widg,
  .review-cards .jdgm-widget {
    font-family: inherit;
  }

  .review-cards .jdgm-rev-widg__header,
  .review-cards .jdgm-histogram,
  .review-cards .jdgm-rev-widg__summary {
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards .jdgm-write-rev-link,
  .review-cards a.jdgm-write-rev-link {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px !important;
    border-radius: 999px !important;
    background: linear-gradient(
      135deg,
      var(--rc-accent, #2dd4bf),
      color-mix(in srgb, #4cc9f0 40%, var(--rc-accent, #2dd4bf))
    ) !important;
    color: #071014 !important;
    font-weight: 750 !important;
    letter-spacing: 0.01em;
    border: none !important;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.4) inset,
      0 16px 34px -14px color-mix(in srgb, var(--rc-accent, #2dd4bf) 80%, #000),
      0 0 0 0 transparent;
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.22s ease;
  }

  .review-cards .jdgm-write-rev-link:hover {
    transform: translateY(-2px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.4) inset,
      0 18px 38px -12px color-mix(in srgb, var(--rc-accent, #2dd4bf) 85%, #000),
      0 0 0 4px color-mix(in srgb, var(--rc-accent, #2dd4bf) 14%, transparent);
  }

  /* Sort control */
  .review-cards .jdgm-rev-widg__sort-wrapper,
  .review-cards .jdgm-row-actions {
    margin: 6px 0 18px !important;
  }

  .review-cards .jdgm-sort-dropdown-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .review-cards .jdgm-sort-dropdown-wrapper::after {
    content: '';
    position: absolute;
    right: 14px;
    top: 50%;
    width: 7px;
    height: 7px;
    border-right: 1.5px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 80%, #fff);
    border-bottom: 1.5px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 80%, #fff);
    transform: translateY(-60%) rotate(45deg);
    pointer-events: none;
    z-index: 2;
  }

  .review-cards .jdgm-sort-dropdown,
  .review-cards .jdgm-sort-dropdown-wrapper select,
  .review-cards select.jdgm-sort-dropdown,
  .review-cards .jdgm-sort-dropdown-wrapper .jdgm-sort-dropdown {
    appearance: none !important;
    -webkit-appearance: none !important;
    min-height: 42px !important;
    min-width: 168px;
    padding: 10px 40px 10px 16px !important;
    border-radius: 999px !important;
    border: 1px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 42%, transparent) !important;
    background:
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--rc-accent, #2dd4bf) 14%, #101820),
        color-mix(in srgb, #14212a 88%, #000)
      ) !important;
    color: #f6f7f2 !important;
    font-size: 0.84rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.01em;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 10px 28px -18px rgba(0, 0, 0, 0.8);
    cursor: pointer;
  }

  .review-cards .jdgm-sort-dropdown:hover,
  .review-cards .jdgm-sort-dropdown:focus,
  .review-cards .jdgm-sort-dropdown-wrapper select:hover,
  .review-cards .jdgm-sort-dropdown-wrapper select:focus {
    border-color: color-mix(in srgb, var(--rc-accent, #2dd4bf) 70%, transparent) !important;
    outline: none !important;
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--rc-accent, #2dd4bf) 18%, transparent),
      0 12px 30px -16px rgba(0, 0, 0, 0.85);
  }

  .review-cards .jdgm-sort-dropdown option,
  .review-cards select.jdgm-sort-dropdown option {
    background: #121a20;
    color: #f6f7f2;
  }

  /* Custom Judge.me menu panel (non-native) */
  .review-cards .jdgm-sort-dropdown-wrapper ul,
  .review-cards .jdgm-dropdown,
  .review-cards [class*='sort'] ul {
    margin-top: 8px !important;
    padding: 8px !important;
    border-radius: 18px !important;
    border: 1px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 28%, transparent) !important;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, #1a2832 92%, #000),
        #0e151b
      ) !important;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 24px 48px -20px rgba(0, 0, 0, 0.85) !important;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    overflow: hidden;
  }

  .review-cards .jdgm-sort-dropdown-wrapper li,
  .review-cards .jdgm-dropdown li,
  .review-cards [class*='sort'] li {
    margin: 2px 0 !important;
    padding: 10px 14px !important;
    border-radius: 12px !important;
    color: #d7e2dd !important;
    font-size: 0.86rem !important;
    font-weight: 500 !important;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .review-cards .jdgm-sort-dropdown-wrapper li:hover,
  .review-cards .jdgm-dropdown li:hover,
  .review-cards [class*='sort'] li:hover {
    background: color-mix(in srgb, var(--rc-accent, #2dd4bf) 14%, transparent) !important;
    color: #fff !important;
  }

  .review-cards .jdgm-sort-dropdown-wrapper li.selected,
  .review-cards .jdgm-sort-dropdown-wrapper li[aria-selected='true'],
  .review-cards .jdgm-dropdown li.selected,
  .review-cards [class*='sort'] li.selected {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--rc-accent, #2dd4bf) 88%, #fff),
      color-mix(in srgb, #4cc9f0 40%, var(--rc-accent, #2dd4bf))
    ) !important;
    color: #071014 !important;
    font-weight: 700 !important;
  }

  .review-cards .jdgm-rev-widg__reviews,
  .review-cards .jdgm-rev-widg__body {
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding-bottom: 8px;
  }

  /* Speech bubbles */
  .review-cards .jdgm-rev {
    position: relative;
    margin: 0 0 10px !important;
    padding: 24px 24px 26px !important;
    border: 1px solid rgba(255, 255, 255, 0.72) !important;
    border-radius: 30px 30px 30px 18px !important;
    background:
      linear-gradient(145deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.7) 30%, transparent 55%),
      radial-gradient(120% 90% at 100% 0%, rgba(45, 212, 191, 0.14), transparent 44%),
      linear-gradient(168deg, #ffffff 0%, #f5faf8 48%, #e7f3ef 100%) !important;
    color: #0d1f1a !important;
    box-shadow:
      0 1.5px 0 rgba(255, 255, 255, 0.95) inset,
      0 0 0 1px rgba(15, 118, 110, 0.05) inset,
      0 22px 48px -26px rgba(0, 0, 0, 0.72),
      0 10px 24px -16px rgba(45, 212, 191, 0.32);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
    overflow: visible;
  }

  .review-cards .jdgm-rev::before {
    content: '';
    position: absolute;
    left: 0;
    top: 18px;
    bottom: 28px;
    width: 3px;
    border-radius: 999px;
    background: linear-gradient(180deg, #5eead4, var(--rc-accent, #2dd4bf) 40%, #38bdf8 75%, transparent);
    box-shadow: 0 0 14px color-mix(in srgb, var(--rc-accent, #2dd4bf) 50%, transparent);
    opacity: 1;
  }

  .review-cards .jdgm-rev::after {
    content: '';
    position: absolute;
    left: 28px;
    bottom: -10px;
    width: 22px;
    height: 22px;
    background: linear-gradient(135deg, #e7f3ef 8%, #dcece8 100%);
    border-right: 1px solid rgba(255, 255, 255, 0.45);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 0 0 6px 0;
    transform: rotate(45deg);
    box-shadow: 5px 5px 14px -7px rgba(0, 0, 0, 0.38);
    z-index: 0;
  }

  .review-cards .jdgm-rev:hover {
    transform: translateY(-5px);
    box-shadow:
      0 1.5px 0 rgba(255, 255, 255, 0.95) inset,
      0 28px 56px -22px rgba(0, 0, 0, 0.78),
      0 14px 32px -14px rgba(45, 212, 191, 0.42),
      0 0 0 1px color-mix(in srgb, var(--rc-accent, #2dd4bf) 18%, transparent);
  }

  .review-cards .jdgm-rev > * {
    position: relative;
    z-index: 1;
  }

  .review-cards .jdgm-rev__header,
  .review-cards .jdgm-rev__author,
  .review-cards .jdgm-rev__author-wrapper,
  .review-cards .jdgm-rev__buyer-badge,
  .review-cards .jdgm-rev__timestamp,
  .review-cards .jdgm-rev__title,
  .review-cards .jdgm-rev__body,
  .review-cards .jdgm-rev__content {
    color: inherit !important;
  }

  .review-cards .jdgm-rev__rating {
    margin-bottom: 4px !important;
  }

  .review-cards .jdgm-rev__author {
    color: #0f766e !important;
    font-weight: 700 !important;
    font-size: 0.95rem !important;
  }

  .review-cards .jdgm-rev__timestamp {
    color: #7a8c86 !important;
    font-size: 0.78rem !important;
    font-weight: 500 !important;
  }

  .review-cards .jdgm-rev__title {
    color: #0b1613 !important;
    font-weight: 700 !important;
    font-size: 1.02rem !important;
    letter-spacing: -0.01em;
    margin-top: 6px !important;
  }

  .review-cards .jdgm-rev__body,
  .review-cards .jdgm-rev__content p {
    color: #2a3b36 !important;
    line-height: 1.62 !important;
    font-size: 0.95rem !important;
  }

  .review-cards .jdgm-rev__buyer-badge,
  .review-cards .jdgm-rev__icon .jdgm-rev__buyer-badge,
  .review-cards span.jdgm-rev__buyer-badge {
    background: color-mix(in srgb, var(--rc-accent, #2dd4bf) 16%, #fff) !important;
    color: #0f766e !important;
    border: 1px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 40%, transparent) !important;
    border-radius: 999px !important;
    padding: 2px 9px !important;
    font-size: 0.68rem !important;
    font-weight: 700 !important;
