<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) {
      var script = document.currentScript;
      root = script && script.closest ? script.closest('.shopify-section') : null;
    }
    if (!root) root = document.querySelector('.review-cards');
    if (!root) return;

    var REAL_PHOTO = /gravatar|googleusercontent|fbcdn|facebook|cdn\.shopify|cloudinary|imgix|judge\.me\/(?:.*\/)?(?:uploads|media|profiles|reviewer)/i;
    var FAKE_PHOTO = /default|placeholder|avatar\.svg|user\.svg|person|silhouette|blank|data:image\/svg|fa-user|mystery|generic|no[_-]?photo|anonymous/i;

    function isRealPhoto(value) {
      if (!value) return false;
      if (FAKE_PHOTO.test(value)) return false;
      return REAL_PHOTO.test(value);
    }

    function polishIcon(icon) {
      if (!icon || icon.dataset.ppPolished === '1') return;

      var bg = icon.getAttribute('style') || '';
      var computedBg = '';
      try {
        computedBg = window.getComputedStyle(icon).backgroundImage || '';
      } catch (e) {}
      var img = icon.querySelector('img');
      var imgSrc = img ? img.currentSrc || img.getAttribute('src') || '' : '';
      var hasGlyph = !!icon.querySelector('svg, i, .fa, [class*="fa-"]');
      var hasReal =
        isRealPhoto(bg) ||
        isRealPhoto(computedBg) ||
        isRealPhoto(imgSrc);

      if (hasReal && !hasGlyph) {
        icon.classList.remove('jdgm-rev__icon--blank');
        icon.dataset.ppPolished = '1';
        return;
      }

      icon.classList.add('jdgm-rev__icon--blank');
      icon.style.setProperty('background-image', 'none', 'important');
      icon.querySelectorAll('svg, i, img, .fa, [class*="fa-"]').forEach(function (node) {
        node.remove();
      });
      icon.dataset.ppPolished = '1';
    }

    function alignFormActions() {
      root.querySelectorAll('form.jdgm-form, .jdgm-form').forEach(function (form) {
        if (form.querySelector('.pp-jdgm-form-actions')) return;

        var cancel =
          form.querySelector('a.jdgm-cancel-rev, .jdgm-cancel-rev, button.jdgm-cancel-rev') ||
          Array.prototype.find.call(form.querySelectorAll('a, button'), function (el) {
            return /avbryt/i.test((el.textContent || '').trim());
          });
        var submit =
          form.querySelector('.jdgm-submit-rev, input[type="submit"], button[type="submit"]') ||
          Array.prototype.find.call(form.querySelectorAll('button, input[type="submit"]'), function (el) {
            return /skicka/i.test((el.value || el.textContent || '').trim());
          });
        if (!cancel || !submit) return;

        cancel.classList.add('jdgm-cancel-rev');
        if (submit.tagName !== 'INPUT') submit.classList.add('jdgm-submit-rev');

        var parent = cancel.parentElement;
        var shared =
          parent &&
          parent === submit.parentElement &&
          parent !== form &&
          Array.prototype.every.call(parent.children, function (child) {
            return child === cancel || child === submit;
          });

        if (shared) {
          parent.classList.add('pp-jdgm-form-actions');
          return;
        }

        var row = document.createElement('div');
        row.className = 'pp-jdgm-form-actions';
        submit.parentNode.insertBefore(row, submit);
        row.appendChild(cancel);
        row.appendChild(submit);
      });
    }

    function polishAll() {
      root.querySelectorAll('.jdgm-rev__icon').forEach(polishIcon);
      simplifyNameFormat();
      alignFormActions();
    }

    function findNameFormatControl(form) {
      return (
        form.querySelector('select[name*="name_format"]') ||
        form.querySelector('select[name*="reviewer_name_format"]') ||
        form.querySelector('select[name="reviewer_name_format"]') ||
        form.querySelector('[name="reviewer_name_format"]') ||
        form.querySelector('.jdgm-form__reviewer-name-format') ||
        form.querySelector('[class*="name-format"] select') ||
        form.querySelector('[class*="name-format"]')
      );
    }

    function simplifyNameFormat() {
      root.querySelectorAll('form.jdgm-form, .jdgm-form').forEach(function (form) {
        if (form.dataset.ppNameSimplified === '1') return;

        var control = findNameFormatControl(form);
        if (control) {
          if (control.tagName === 'SELECT') {
            var fullOpt = Array.prototype.find.call(control.options || [], function (opt) {
              return opt.value === '' || opt.value === 'full_name' || opt.value === 'name';
            });
            if (!fullOpt && control.options && control.options.length) fullOpt = control.options[0];
            if (fullOpt) {
              control.value = fullOpt.value;
              try {
                control.dispatchEvent(new Event('change', { bubbles: true }));
                control.dispatchEvent(new Event('input', { bubbles: true }));
              } catch (e) {}
            }
          } else if (control.tagName === 'INPUT') {
            control.value = '';
          }
          control.classList.add('pp-jdgm-name-format');
        }

        form.querySelectorAll('label, .jdgm-form__label, p, span, div, legend').forEach(function (el) {
          if (el.dataset.ppNameLabelFixed === '1') return;
          var text = (el.textContent || '').replace(/\s+/g, ' ').trim();
          if (!/visningsnamn/i.test(text)) return;
          if (!/visas offentligt|displayed as|publicly as/i.test(text)) return;

          el.querySelectorAll('select, button, [role="listbox"], [role="combobox"], ul, .jdgm-dropdown, [class*="dropdown"]').forEach(function (node) {
            node.classList.add('pp-jdgm-name-format');
          });

          if (!el.querySelector('input, textarea')) {
            el.textContent = 'Visningsnamn';
            el.classList.add('pp-jdgm-name-label');
          }
          el.dataset.ppNameLabelFixed = '1';
        });

        form.querySelectorAll('ul, [role="listbox"]').forEach(function (list) {
          var t = (list.textContent || '').replace(/\s+/g, ' ');
          if (/Anonym/i.test(t) && (/John|J\.S\./i.test(t) || /last_initial|all_initials/i.test(t))) {
            list.classList.add('pp-jdgm-name-format');
            if (list.previousElementSibling) list.previousElementSibling.classList.add('pp-jdgm-name-format');
            if (list.parentElement && list.parentElement !== form) {
              list.parentElement.classList.add('pp-jdgm-name-format');
            }
          }
        });

        form.querySelectorAll('select').forEach(function (sel) {
          var opts = Array.prototype.map.call(sel.options || [], function (o) {
            return (o.textContent || '').trim();
          }).join(' ');
          if (/Anonym/i.test(opts) && (/John|J\.S\./i.test(opts) || sel.options.length <= 6)) {
            if (!sel.value || sel.selectedIndex > 0) {
              sel.selectedIndex = 0;
              try { sel.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
            }
            sel.classList.add('pp-jdgm-name-format');
          }
        });

        form.dataset.ppNameSimplified = '1';
      });
    }

    polishAll();

    var scheduled = false;
    var observer = new MutationObserver(function () {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(function () {
        scheduled = false;
        root.querySelectorAll('form.jdgm-form, .jdgm-form').forEach(function (form) {
          if (!form.dataset.ppNameSimplified) return;
          if (!form.querySelector('.pp-jdgm-name-label') && /visas offentligt/i.test(form.textContent || '')) {
            form.dataset.ppNameSimplified = '';
          }
        });
        polishAll();
      });
    });
    observer.observe(root, { childList: true, subtree: true });
  })();
</script>

