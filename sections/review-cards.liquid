<div
  class="review-cards full-width"
  style="
    --rc-bg: {{ section.settings.background_color }};
    --rc-surface: {{ section.settings.surface_color }};
    --rc-text: {{ section.settings.text_color }};
    --rc-muted: {{ section.settings.muted_text_color }};
    --rc-accent: {{ section.settings.accent_color }};
  "
>
  <div class="review-cards__inner">
    {% if section.settings.heading != blank %}
      <header class="review-cards__header">
        {% if section.settings.eyebrow != blank %}
          <p class="review-cards__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="review-cards__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="review-cards__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% assign review_blocks = section.blocks | where: 'type', 'review' %}
    {% assign app_blocks = section.blocks | where: 'type', '@app' %}
    {% assign show_placeholders = section.settings.show_placeholder_reviews %}

    {% if app_blocks.size > 0 %}
      {% assign show_placeholders = false %}
    {% endif %}

    {% if review_blocks.size > 0 and show_placeholders %}
      {%- liquid
        assign total_reviews = section.settings.total_review_count
        if total_reviews == blank or total_reviews < 1
          assign total_reviews = review_blocks.size
        endif

        assign rating_sum = 0
        assign rating_count = 0
        for block in review_blocks
          if block.settings.rating > 0
            assign rating_sum = rating_sum | plus: block.settings.rating
            assign rating_count = rating_count | plus: 1
          endif
        endfor
        if rating_count > 0
          assign avg_rating = rating_sum | times: 1.0 | divided_by: rating_count | round: 1
          assign avg_rounded = avg_rating | round
        else
          assign avg_rating = 5
          assign avg_rounded = 5
        endif
      -%}
      <div class="review-cards__summary">
        <div class="review-cards__summary-score">
          <span class="review-cards__summary-number">{{ avg_rating }}</span>
          <div class="review-cards__summary-stars" role="img" aria-label="{{ avg_rating }} av 5 stjärnor">
            {% for i in (1..5) %}
              <span class="review-cards__star{% if i > avg_rounded %} review-cards__star--empty{% endif %}" aria-hidden="true">★</span>
            {% endfor %}
          </div>
        </div>
        <p class="review-cards__summary-text">
          Baserat på <strong>{{ total_reviews }} omdömen</strong>
          {% if section.settings.summary_note != blank %} · {{ section.settings.summary_note }}{% endif %}
        </p>
      </div>
    {% endif %}

    {% for block in section.blocks %}
      {% case block.type %}
        {% when '@app' %}
          <div class="review-cards__app" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
      {% endcase %}
    {% endfor %}

    {% if review_blocks.size > 0 and show_placeholders %}
      <ul class="review-cards__list" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <li class="review-cards__card" {{ block.shopify_attributes }}>
              {% if block.settings.rating > 0 %}
                <div class="review-cards__stars" role="img" aria-label="{{ block.settings.rating }} av 5 stjärnor">
                  {% for i in (1..5) %}
                    <span class="review-cards__star{% if i > block.settings.rating %} review-cards__star--empty{% endif %}" aria-hidden="true">★</span>
                  {% endfor %}
                </div>
              {% endif %}
              {% if block.settings.quote != blank %}
                <p class="review-cards__text">{{ block.settings.quote }}</p>
              {% endif %}
              <footer class="review-cards__footer">
                <div class="review-cards__meta">
                  {% if block.settings.author != blank %}
                    <cite class="review-cards__author">{{ block.settings.author }}</cite>
                  {% endif %}
                  {% if block.settings.context != blank %}
                    <span class="review-cards__context">{{ block.settings.context }}</span>
                  {% endif %}
                </div>
                <span class="review-cards__verified">Verifierat köp</span>
              </footer>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .review-cards {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--rc-bg, #071014);
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .review-cards__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .review-cards__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .review-cards__subheading {
    margin: 0;
    color: var(--rc-muted, #9aa8a2);
    line-height: 1.6;
  }

  .review-cards__summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 32px;
    padding: 24px 28px;
    border-radius: 22px;
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--rc-accent, #2dd4bf) 12%, var(--rc-surface, #14212a)),
      var(--rc-surface, #14212a)
    );
    border: 1px solid color-mix(in srgb, var(--rc-accent, #2dd4bf) 28%, transparent);
    box-shadow: 0 16px 40px -24px color-mix(in srgb, var(--rc-accent, #2dd4bf) 55%, #000);
  }

  .review-cards__summary-score {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .review-cards__summary-number {
    font-size: clamp(2.4rem, 6vw, 3rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__summary-stars {
    display: flex;
    gap: 3px;
    font-size: 1.25rem;
  }

  .review-cards__summary-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--rc-muted, #9aa8a2);
  }

  .review-cards__summary-text strong {
    color: var(--rc-text, #f6f7f2);
  }

  .review-cards__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .review-cards__card {
    position: relative;
    height: 100%;
    padding: 22px 22px 18px;
    border-radius: 18px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--rc-text, #f6f7f2) 4%, var(--rc-surface, #14212a)),
      var(--rc-surface, #14212a)
    );
    border: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .review-cards__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 22px;
    right: 22px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--rc-accent, #2dd4bf) 70%, transparent),
      transparent
    );
    opacity: 0.85;
  }

  .review-cards__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--rc-accent, #2dd4bf) 40%, transparent);
    box-shadow: 0 16px 40px -24px color-mix(in srgb, var(--rc-accent, #2dd4bf) 45%, #000);
  }

  .review-cards__stars {
    display: flex;
    gap: 2px;
    font-size: 1rem;
    line-height: 1;
  }

  .review-cards__star {
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__star--empty {
    color: color-mix(in srgb, var(--rc-text, #f6f7f2) 20%, transparent);
  }

  .review-cards__text {
    margin: 0;
    font-size: clamp(0.94rem, 2.4vw, 1.02rem);
    line-height: 1.65;
    color: var(--rc-text, #f6f7f2);
    text-wrap: pretty;
    flex: 1;
  }

  .review-cards__footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
    padding-top: 4px;
    border-top: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 7%, transparent);
  }

  .review-cards__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
  }

  .review-cards__author {
    font-style: normal;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .review-cards__context {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--rc-muted, #9aa8a2);
    background: color-mix(in srgb, var(--rc-text, #f6f7f2) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--rc-text, #f6f7f2) 8%, transparent);
  }

  .review-cards__verified {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--rc-accent, #2dd4bf);
  }

  .review-cards__verified::before {
    content: '✓';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    font-size: 0.62rem;
    background: color-mix(in srgb, var(--rc-accent, #2dd4bf) 16%, transparent);
  }

  @media screen and (min-width: 540px) and (max-width: 749px) {
    .review-cards__list {
      grid-template-columns: repeat(2, 1fr);
    }

    .review-cards__card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      max-width: min(100%, 420px);
      justify-self: center;
    }
  }

  @media screen and (min-width: 750px) {
    .review-cards {
      padding-block: 56px;
    }

    .review-cards__list {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .review-cards__card {
      transition: none;
    }

    .review-cards__card:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Review cards",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Omdömen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Det här säger våra kunder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "38 verifierade omdömen — alla 5 stjärnor."
    },
    {
      "type": "number",
      "id": "total_review_count",
      "label": "Total review count",
      "default": 38
    },
    {
      "type": "text",
      "id": "summary_note",
      "label": "Summary note",
      "default": "Alla 5 stjärnor"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder_reviews",
      "label": "Show placeholder review cards",
      "info": "Turn off when Judge.me app block is added to this section.",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Skriv kundens omdöme här."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Kundnamn"
        },
        {
          "type": "text",
          "id": "context",
          "label": "Context",
          "default": "Verifierad köpare"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review cards",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "Smidig att ta med sig och fungerar perfekt efter en varm sommardag på fjället.",
            "author": "Anna",
            "context": "Camping"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Toppen att ha i bastun i vår stuga ute i skärgården!",
            "author": "Erik",
            "context": "Bastu"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Perfekt på båten, sköljer av salt och svett direkt på däck.",
            "author": "Maria",
            "context": "Båt"
          }
        }
      ]
    }
  ]
}
{% endschema %}
