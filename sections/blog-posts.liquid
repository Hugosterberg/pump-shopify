{% comment %}
  Blog posts — shows latest articles from a selected blog. No hardcoded content.
{% endcomment %}

{% liquid
  assign target_blog = blogs[section.settings.blog]
%}

<div
  class="blog-posts full-width"
  style="
    --bp-bg: {{ section.settings.background_color }};
    --bp-surface: {{ section.settings.surface_color }};
    --bp-text: {{ section.settings.text_color }};
    --bp-muted: {{ section.settings.muted_text_color }};
    --bp-accent: {{ section.settings.accent_color }};
  "
>
  <div class="blog-posts__inner">
    <header class="blog-posts__header">
      {% if section.settings.eyebrow != blank %}
        <p class="blog-posts__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="blog-posts__heading">{{ section.settings.heading | replace: 'pump', '<span class="brand-mark">pump</span>' }}</h2>
      {% endif %}
    </header>

    {% if target_blog != blank and target_blog.articles_count > 0 %}
      <ul class="blog-posts__grid" role="list">
        {% for article in target_blog.articles limit: section.settings.posts_to_show %}
          <li class="blog-posts__card">
            <article class="blog-posts__article">
              <a class="blog-posts__link" href="{{ article.url }}">
                <div class="blog-posts__media">
                  {% if article.image != blank %}
                    {{
                      article.image
                      | image_url: width: 320
                      | image_tag:
                        loading: 'lazy',
                        widths: '120, 200, 320',
                        sizes: '120px',
                        alt: article.image.alt | default: article.title
                    }}
                  {% else %}
                    <div class="blog-posts__placeholder">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="blog-posts__body">
                  <h3 class="blog-posts__title">{{ article.title }}</h3>
                  {% if section.settings.show_date %}
                    <time class="blog-posts__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{ article.published_at | date: '%-d %b %Y' }}
                    </time>
                  {% endif %}
                  {% if section.settings.show_excerpt and article.excerpt != blank %}
                    <p class="blog-posts__excerpt">{{ article.excerpt | strip_html | truncate: 90 }}</p>
                  {% endif %}
                </div>
              </a>
            </article>
          </li>
        {% endfor %}
      </ul>

      {% if section.settings.show_view_all and target_blog.url != blank %}
        <div class="blog-posts__footer">
          <a class="blog-posts__view-all" href="{{ target_blog.url }}">
            {{ section.settings.view_all_label | default: 'Visa alla inlägg' }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <p class="blog-posts__empty">Välj en blogg i temaredigeraren för att visa inlägg.</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .blog-posts {
    padding-block: 36px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--bp-bg, #101820);
    color: var(--bp-text, #f6f7f2);
  }

  .blog-posts__inner {
    max-width: 64rem;
    margin-inline: auto;
  }

  .blog-posts__header {
    text-align: center;
    margin-bottom: 22px;
  }

  .blog-posts__eyebrow {
    margin: 0 0 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bp-accent, #2dd4bf);
  }

  .blog-posts__heading {
    margin: 0;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    letter-spacing: -0.02em;
  }

  .blog-posts__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .blog-posts__article {
    height: 100%;
  }

  .blog-posts__link {
    display: grid;
    grid-template-columns: 84px 1fr;
    align-items: center;
    gap: 14px;
    height: 100%;
    padding: 8px;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    background-color: var(--bp-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--bp-text, #f6f7f2) 8%, transparent);
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .blog-posts__link:hover {
    border-color: color-mix(in srgb, var(--bp-accent, #2dd4bf) 45%, transparent);
    background-color: color-mix(in srgb, var(--bp-accent, #2dd4bf) 6%, var(--bp-surface, #14212a));
  }

  .blog-posts__media {
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
  }

  .blog-posts__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-posts__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--bp-text, #f6f7f2) 18%, transparent);
  }

  .blog-posts__body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-right: 8px;
    min-width: 0;
  }

  .blog-posts__title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .blog-posts__date {
    font-size: 0.74rem;
    color: var(--bp-muted, #9aa8a2);
  }

  .blog-posts__excerpt {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--bp-muted, #9aa8a2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-posts__footer {
    margin-top: 18px;
    text-align: center;
  }

  .blog-posts__view-all {
    display: inline-flex;
    min-height: 40px;
    padding-inline: 22px;
    align-items: center;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--bp-accent, #2dd4bf);
    border: 1px solid color-mix(in srgb, var(--bp-accent, #2dd4bf) 40%, transparent);
    transition: background-color 0.15s ease;
  }

  .blog-posts__view-all:hover {
    background-color: color-mix(in srgb, var(--bp-accent, #2dd4bf) 12%, transparent);
  }

  .blog-posts__empty {
    text-align: center;
    color: var(--bp-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .blog-posts {
      padding-block: 48px;
    }

    .blog-posts__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-posts__link {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Artiklar & guider"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lär dig mer om pump"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publish date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Visa alla inlägg"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Blog posts"
    }
  ]
}
{% endschema %}

