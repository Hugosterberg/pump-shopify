{% liquid
  assign showcase_product = section.settings.product
%}

<div
  id="product-showcase"
  class="product-showcase full-width"
  style="
    --pshow-bg: {{ section.settings.background_color }};
    --pshow-surface: {{ section.settings.surface_color }};
    --pshow-text: {{ section.settings.text_color }};
    --pshow-muted: {{ section.settings.muted_text_color }};
    --pshow-accent: {{ section.settings.accent_color }};
    --pshow-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  <div class="product-showcase__inner">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <header class="product-showcase__header">
        {% if section.settings.eyebrow != blank %}
          <p class="product-showcase__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="product-showcase__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </header>
    {% endif %}

    {% if showcase_product != blank %}
      {% assign current_variant = showcase_product.selected_or_first_available_variant %}
      <div class="product-showcase__grid">
        <div class="product-showcase__media">
          {% if showcase_product.featured_image != blank %}
            {{
              showcase_product.featured_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '500, 700, 900, 1200',
                class: 'product-showcase__image',
                alt: showcase_product.featured_image.alt | default: showcase_product.title
            }}
          {% else %}
            <div class="product-showcase__placeholder">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="product-showcase__buy">
          <div class="product-showcase__meta">
            <span class="product-showcase__badge">Bästsäljare</span>
            <span class="product-showcase__badge product-showcase__badge--muted">
              {% render 'icon', name: 'truck', size: 12 %}
              2–5 dagar
            </span>
            <span
              class="product-showcase__badge product-showcase__badge--muted"
              data-showcase-stock-badge
              {% unless current_variant.available %}hidden{% endunless %}
            >
              {% render 'icon', name: 'check', size: 12 %}
              I lager
            </span>
          </div>

          <div class="product-showcase__head">
            <h3 class="product-showcase__title">{{ showcase_product.title }}</h3>

            <div class="product-showcase__price" data-product-showcase-price>
              {% if current_variant.compare_at_price > current_variant.price %}
                <span class="product-showcase__price-compare" data-price-compare>
                  <s>{{ current_variant.compare_at_price | money }}</s>
                </span>
                {% assign saving = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round %}
                <span class="product-showcase__save" data-save-badge>Spara {{ saving }}%</span>
              {% else %}
                <span class="product-showcase__price-compare" data-price-compare hidden></span>
                <span class="product-showcase__save" data-save-badge hidden></span>
              {% endif %}
              <span class="product-showcase__price-current" data-price-current>{{ current_variant.price | money }}</span>
            </div>
          </div>

          <div class="product-showcase__offer">
            {% render 'free-shipping-bar', class_prefix: 'product-showcase__shipping', compact: true, embedded: true %}
          </div>

          {% if section.settings.description != blank %}
            <div class="product-showcase__description">{{ section.settings.description }}</div>
          {% elsif showcase_product.description != blank %}
            <div class="product-showcase__description">{{ showcase_product.description | strip_html | truncate: 200 }}</div>
          {% endif %}

          <div class="product-showcase__purchase">
            {% form 'product', showcase_product, class: 'product-showcase__form ajax-cart-form' %}
              {% assign current_variant = showcase_product.selected_or_first_available_variant %}

              {% if showcase_product.variants.size > 1 %}
                {% render 'pp-variant-picker',
                  product: showcase_product,
                  current_variant: current_variant,
                  section_id: section.id,
                  select_class: 'product-showcase__select'
                %}
              {% else %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
              {% endif %}

              <div class="product-showcase__qty-row">
                <label class="product-showcase__label" for="ProductShowcase-Qty-{{ section.id }}">
                  Antal
                </label>
                <input
                  id="ProductShowcase-Qty-{{ section.id }}"
                  class="product-showcase__qty"
                  type="number"
                  name="quantity"
                  min="1"
                  value="1"
                >
              </div>

              <div class="product-showcase__checkout-actions">
                <button
                  class="product-showcase__submit pp-btn-primary pp-btn-lg pp-btn--full"
                  type="submit"
                  data-product-showcase-submit
                  {% unless current_variant.available %}
                    disabled
                  {% endunless %}
                >
                  {% if current_variant.available %}
                    {{ section.settings.button_label | default: 'Lägg i varukorg' }}
                  {% else %}
                    Slutsåld
                  {% endif %}
                </button>

                <p class="product-showcase__checkout-divider" aria-hidden="true">
                  <span>eller</span>
                </p>

                {{ form | payment_button }}
              </div>
            {% endform %}

            <div class="product-showcase__buy-trust">
              {% render 'trust-near-atc', class_prefix: 'product-showcase__trust-atc', show_payment_icons: false %}
              {% render 'payment-icons', class_prefix: 'product-showcase__payment', label: 'Betala enkelt med', inline_row: true %}
            </div>

            <div class="product-showcase__buy-legal">
              {% render 'legal-links', class_prefix: 'product-showcase__legal', compact: true %}
            </div>
          </div>
        </div>
      </div>
    {% else %}
      <p class="product-showcase__empty">
        Välj en produkt i temaredigeraren för att visa köpboxen.
      </p>
    {% endif %}
  </div>
</div>

{% if showcase_product != blank %}
<script type="application/json" id="ProductShowcaseVariants-{{ section.id }}">
  [
    {%- for variant in showcase_product.variants -%}
      {
        "id": {{ variant.id | json }},
        "available": {{ variant.available | json }},
        "price": {{ variant.price | json }},
        "compare_at_price": {{ variant.compare_at_price | default: 0 | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>
<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var select = root.querySelector('[data-variant-select]');
    var variantsEl = document.getElementById('ProductShowcaseVariants-{{ section.id }}');
    if (!variantsEl) return;

    var variants = JSON.parse(variantsEl.textContent);
    var variantMap = {};
    variants.forEach(function (v) {
      variantMap[String(v.id)] = v;
    });

    var priceCurrent = root.querySelector('[data-price-current]');
    var priceCompare = root.querySelector('[data-price-compare]');
    var saveBadge = root.querySelector('[data-save-badge]');
    var submitBtn = root.querySelector('[data-product-showcase-submit]');
    var stockBadge = root.querySelector('[data-showcase-stock-badge]');
    var moneyFormat = (window.PumpTheme && window.PumpTheme.moneyFormat) || '';

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return (cents / 100).toFixed(0) + ' kr';
    }

    function dispatchVariantChange(variant) {
      document.dispatchEvent(
        new CustomEvent('pump:variant-change', {
          detail: {
            variantId: variant.id,
            available: variant.available,
            price: variant.price,
            compareAtPrice: variant.compare_at_price || 0,
            formattedPrice: formatMoney(variant.price),
            formattedComparePrice:
              variant.compare_at_price > variant.price ? formatMoney(variant.compare_at_price) : '',
          },
        })
      );
    }

    function updateVariant(id) {
      var variant = variantMap[String(id)];
      if (!variant) return;

      if (priceCurrent) priceCurrent.textContent = formatMoney(variant.price);

      if (variant.compare_at_price > variant.price) {
        var saving = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
        if (priceCompare) {
          priceCompare.hidden = false;
          priceCompare.innerHTML = '<s>' + formatMoney(variant.compare_at_price) + '</s>';
        }
        if (saveBadge) {
          saveBadge.hidden = false;
          saveBadge.textContent = 'Spara ' + saving + '%';
        }
      } else {
        if (priceCompare) priceCompare.hidden = true;
        if (saveBadge) saveBadge.hidden = true;
      }

      if (submitBtn) {
        submitBtn.disabled = !variant.available;
        submitBtn.textContent = variant.available
          ? {{ section.settings.button_label | default: 'Lägg i varukorg' | json }}
          : 'Slutsåld';
      }

      if (stockBadge) {
        stockBadge.hidden = !variant.available;
      }

      dispatchVariantChange(variant);
    }

    if (select) {
      select.addEventListener('change', function () {
        updateVariant(select.value);
      });
      updateVariant(select.value);
    }
  })();
</script>
{% endif %}

{% stylesheet %}
  .product-showcase {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pshow-bg, #101820);
    color: var(--pshow-text, #f6f7f2);
    scroll-margin-top: calc(var(--header-height, 64px) + 16px);
  }

  .product-showcase__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .product-showcase__header {
    text-align: center;
    margin-bottom: 24px;
  }

  .product-showcase__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .product-showcase__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 20px;
    align-items: start;
  }

  .product-showcase__media {
    position: relative;
    min-width: 0;
    border-radius: 20px;
    overflow: hidden;
    background-color: var(--pshow-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 8%, transparent);
    aspect-ratio: 1;
  }

  .product-showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-showcase__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--pshow-text, #f6f7f2) 20%, transparent);
  }

  .product-showcase__buy {
    min-width: 0;
    max-width: 100%;
    padding: clamp(20px, 3.5vw, 28px);
    border-radius: var(--pp-radius-lg, 20px);
    background:
      radial-gradient(120% 80% at 100% 0%, color-mix(in srgb, var(--pshow-accent, #2dd4bf) 8%, transparent), transparent 55%),
      linear-gradient(165deg, color-mix(in srgb, var(--pshow-surface, #14212a) 94%, #fff 6%) 0%, var(--pshow-surface, #14212a) 100%);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 10%, transparent);
    box-shadow:
      var(--pp-shadow-soft),
      inset 0 1px 0 color-mix(in srgb, var(--pshow-text, #f6f7f2) 6%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow: clip;
    isolation: isolate;
  }

  .product-showcase__head {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }

  .product-showcase__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  @media screen and (max-width: 479px) {
    .product-showcase__meta {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .product-showcase__meta::-webkit-scrollbar {
      display: none;
    }
  }

  .product-showcase__badges {
    display: contents;
  }

  .product-showcase__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
    text-transform: none;
    text-align: center;
    color: var(--pshow-accent-ink, #071014);
    background: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__badge--muted {
    color: var(--pshow-muted, #9aa8a2);
    text-transform: none;
    font-weight: 600;
    letter-spacing: 0;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 10%, transparent);
  }

  .product-showcase__offer {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
    padding: 12px 14px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 9%, transparent);
  }

  .product-showcase__offer .product-showcase__shipping {
    margin: 0;
    padding-top: 0;
    border-top: none;
    min-width: 0;
  }

  .product-showcase__offer [class*='__shipping__text'],
  .product-showcase__offer .free-shipping-bar__text {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .product-showcase__offer .product-showcase__shipping__track {
    width: 100%;
  }

  .product-showcase__shipping {
    margin: 0;
  }

  .product-showcase__title {
    margin: 0;
    font-size: clamp(1.25rem, 2.8vw, 1.65rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .product-showcase__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 12px;
    margin: 0;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--pshow-accent, #2dd4bf) 20%, transparent);
    background: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 6%, transparent);
  }

  .product-showcase__price-compare {
    font-size: 0.92rem;
    color: var(--pshow-muted, #9aa8a2);
    order: 1;
  }

  .product-showcase__price-compare s {
    text-decoration-thickness: 1px;
  }

  .product-showcase__price-compare[hidden] {
    display: none;
  }

  .product-showcase__save {
    order: 2;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--pshow-accent-ink, #071014);
    background: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__save[hidden] {
    display: none;
  }

  .product-showcase__price-current {
    flex: 1 1 100%;
    order: 3;
    font-size: clamp(2rem, 5.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--pshow-text, #f6f7f2);
  }

  .product-showcase__description {
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--pshow-muted, #9aa8a2);
    padding-top: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-showcase__purchase {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2px;
    min-width: 0;
    max-width: 100%;
  }

  .product-showcase__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
    min-width: 0;
    max-width: 100%;
  }

  .product-showcase__checkout-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 4px;
    min-width: 0;
    max-width: 100%;
    width: 100%;
  }

  .product-showcase__checkout-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 14px 0 12px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pshow-muted, #9aa8a2);
  }

  .product-showcase__checkout-divider::before,
  .product-showcase__checkout-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--pshow-text, #f6f7f2) 14%, transparent) 20%,
      color-mix(in srgb, var(--pshow-text, #f6f7f2) 14%, transparent) 80%,
      transparent
    );
  }

  .product-showcase__buy-trust {
    margin-top: 22px;
    padding: 18px;
    border-radius: 16px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--pshow-text, #f6f7f2) 4%, transparent), color-mix(in srgb, var(--pshow-bg, #101820) 40%, transparent));
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 9%, transparent);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-showcase__buy-trust .pp-trust-atc-wrap {
    margin: 0;
    padding: 0;
    border: 0;
  }

  @media screen and (min-width: 750px) {
    .product-showcase__buy-trust .pp-trust-atc:not(.pp-trust-atc--compact) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }
  }

  .product-showcase__buy-trust .pp-trust-atc__chip {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    padding: 12px 8px;
    min-height: 0;
    border-radius: 14px;
    border-color: color-mix(in srgb, var(--pshow-text, #f6f7f2) 9%, transparent);
    background: color-mix(in srgb, var(--pshow-bg, #101820) 50%, var(--pshow-surface, #14212a));
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--pshow-text, #f6f7f2) 4%, transparent);
  }

  .product-showcase__buy-trust .pp-trust-atc__chip-icon {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    margin: 0;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--pshow-accent, #2dd4bf) 25%, transparent);
  }

  .product-showcase__buy-trust .pp-trust-atc__chip-text {
    align-items: center;
    text-align: center;
    gap: 2px;
  }

  .product-showcase__buy-trust .pp-trust-atc__chip-text strong {
    font-size: clamp(0.68rem, 2vw, 0.82rem);
    line-height: 1.2;
  }

  .product-showcase__buy-trust .pp-trust-atc__chip-text span {
    font-size: clamp(0.62rem, 1.8vw, 0.74rem);
    line-height: 1.3;
  }

  .product-showcase__buy-trust .product-showcase__payment {
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 8%, transparent);
  }

  .product-showcase__buy-trust .pp-payment-icons__label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }

  .product-showcase__buy-legal {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 6%, transparent);
  }

  .product-showcase__buy-legal .product-showcase__legal {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--pshow-muted, #9aa8a2);
    text-align: center;
  }

  .product-showcase__buy-legal .product-showcase__legal span[aria-hidden='true'] {
    display: none;
  }

  .product-showcase__buy-legal .product-showcase__legal a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 14px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--pshow-muted, #9aa8a2) !important;
    text-decoration: none !important;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 10%, transparent);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .product-showcase__buy-legal .product-showcase__legal a:hover {
    color: var(--pshow-accent, #2dd4bf) !important;
    border-color: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 35%, transparent);
    background: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 8%, transparent);
  }

  .product-showcase__purchase .shopify-payment-button__more-options ~ ul,
  .product-showcase__purchase .shopify-payment-button__more-options ~ div[class*='icon'],
  .product-showcase__purchase .shopify-payment-button ul:not([class*='more-options']) {
    display: none !important;
  }

  .product-showcase__purchase .shopify-payment-button__more-options,
  .product-showcase__purchase .shopify-payment-button a[href*='checkout']:not([class*='button']),
  .product-showcase__purchase #more-payment-options-link {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: auto !important;
    max-width: 100%;
    margin: 10px auto 0 !important;
    padding: 9px 16px !important;
    border-radius: 999px !important;
    font-size: 0.78rem !important;
    font-weight: 500 !important;
    line-height: 1.3 !important;
    text-align: center;
    text-decoration: none !important;
    color: var(--pshow-muted, #9aa8a2) !important;
    -webkit-text-fill-color: var(--pshow-muted, #9aa8a2) !important;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 5%, transparent) !important;
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 12%, transparent) !important;
    box-shadow: none !important;
    min-height: auto !important;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .product-showcase__purchase .shopify-payment-button__more-options:hover,
  .product-showcase__purchase .shopify-payment-button a[href*='checkout']:not([class*='button']):hover,
  .product-showcase__purchase #more-payment-options-link:hover {
    color: var(--pshow-accent, #2dd4bf) !important;
    -webkit-text-fill-color: var(--pshow-accent, #2dd4bf) !important;
    border-color: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 40%, transparent) !important;
    background: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 8%, transparent) !important;
  }

  .product-showcase__purchase .shopify-payment-button {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .product-showcase__purchase .shopify-payment-button__button,
  .product-showcase__purchase .shopify-payment-button button {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    min-height: 54px !important;
    border-radius: var(--pp-radius-pill, 999px) !important;
    font-weight: 600 !important;
    font-size: 1rem !important;
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 16%, transparent) !important;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 7%, transparent) !important;
    color: var(--pshow-text, #f6f7f2) !important;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--pshow-text, #f6f7f2) 8%, transparent) !important;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    box-sizing: border-box !important;
  }

  .product-showcase__purchase .shopify-payment-button iframe {
    max-width: 100% !important;
    width: 100% !important;
  }

  .product-showcase__purchase .shopify-payment-button__button:hover,
  .product-showcase__purchase .shopify-payment-button button:hover {
    border-color: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 45%, transparent) !important;
    background: color-mix(in srgb, var(--pshow-accent, #2dd4bf) 10%, transparent) !important;
    transform: translateY(-1px);
  }

  .product-showcase__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--pshow-muted, #9aa8a2);
  }

  .product-showcase__select,
  .product-showcase__qty {
    width: 100%;
    min-height: 48px;
    padding: 0 14px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 15%, transparent);
    background-color: var(--pshow-bg, #101820);
    color: var(--pshow-text, #f6f7f2);
  }

  .product-showcase__qty-row {
    max-width: 132px;
  }

  .product-showcase__qty {
    text-align: center;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .product-showcase__submit {
    margin-top: 0;
  }

  @media screen and (min-width: 750px) {
    .product-showcase {
      padding-block: 68px;
    }

    .product-showcase__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 28px;
      align-items: center;
    }

    .product-showcase__price-current {
      font-size: clamp(2.25rem, 3.5vw, 3rem);
    }
  }

  .product-showcase__empty {
    text-align: center;
    padding: 48px 24px;
    border-radius: 16px;
    background-color: var(--pshow-surface, #14212a);
    color: var(--pshow-muted, #9aa8a2);
  }

  @media (prefers-reduced-motion: reduce) {
    .product-showcase__grid {
      gap: 20px;
    }
  }
{% endstylesheet %}

