{% liquid
  assign showcase_product = section.settings.product
%}

<div
  id="product-showcase"
  class="product-showcase full-width"
  style="
    --pshow-bg: {{ section.settings.background_color }};
    --pshow-surface: {{ section.settings.surface_color }};
    --pshow-text: {{ section.settings.text_color }};
    --pshow-muted: {{ section.settings.muted_text_color }};
    --pshow-accent: {{ section.settings.accent_color }};
    --pshow-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  <div class="product-showcase__inner">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <header class="product-showcase__header">
        {% if section.settings.eyebrow != blank %}
          <p class="product-showcase__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="product-showcase__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </header>
    {% endif %}

    {% if showcase_product != blank %}
      <div class="product-showcase__grid">
        <div class="product-showcase__media">
          {% if showcase_product.featured_image != blank %}
            {{
              showcase_product.featured_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '500, 700, 900, 1200',
                class: 'product-showcase__image',
                alt: showcase_product.featured_image.alt | default: showcase_product.title
            }}
          {% else %}
            <div class="product-showcase__placeholder">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="product-showcase__buy">
          <div class="product-showcase__badges">
            <span class="product-showcase__badge">Bästsäljare</span>
            <span class="product-showcase__badge product-showcase__badge--muted">Leverans 2–5 dagar</span>
          </div>
          <h3 class="product-showcase__title">{{ showcase_product.title }}</h3>

          <div class="product-showcase__price">
            {% if showcase_product.compare_at_price > showcase_product.price %}
              <span class="product-showcase__price-compare">
                <s>{{ showcase_product.compare_at_price | money }}</s>
              </span>
              {% assign saving = showcase_product.compare_at_price | minus: showcase_product.price | times: 100.0 | divided_by: showcase_product.compare_at_price | round %}
              <span class="product-showcase__save">Spara {{ saving }}%</span>
            {% endif %}
            <span class="product-showcase__price-current">{{ showcase_product.price | money }}</span>
          </div>

          {% if section.settings.description != blank %}
            <div class="product-showcase__description">{{ section.settings.description }}</div>
          {% elsif showcase_product.description != blank %}
            <div class="product-showcase__description">{{ showcase_product.description | strip_html | truncate: 200 }}</div>
          {% endif %}

          {% if section.blocks.size > 0 %}
            <ul class="product-showcase__trust" role="list">
              {% for block in section.blocks %}
                <li class="product-showcase__trust-item" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          <div class="product-showcase__form">
            {% form 'product', showcase_product, class: 'ajax-cart-form' %}
              {% assign current_variant = showcase_product.selected_or_first_available_variant %}

              {% if showcase_product.variants.size > 1 %}
                <label class="product-showcase__label" for="ProductShowcase-Variant-{{ section.id }}">
                  Variant
                </label>
                <select
                  id="ProductShowcase-Variant-{{ section.id }}"
                  class="product-showcase__select"
                  name="id"
                >
                  {% for variant in showcase_product.variants %}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == current_variant %}
                        selected="selected"
                      {% endif %}
                      {% unless variant.available %}
                        disabled
                      {% endunless %}
                    >
                      {{ variant.title }}, {{ variant.price | money }}
                    </option>
                  {% endfor %}
                </select>
              {% else %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
              {% endif %}

              <div class="product-showcase__qty-row">
                <label class="product-showcase__label" for="ProductShowcase-Qty-{{ section.id }}">
                  Antal
                </label>
                <input
                  id="ProductShowcase-Qty-{{ section.id }}"
                  class="product-showcase__qty"
                  type="number"
                  name="quantity"
                  min="1"
                  value="1"
                >
              </div>

              <button
                class="product-showcase__submit"
                type="submit"
                {% unless current_variant.available %}
                  disabled
                {% endunless %}
              >
                {% if current_variant.available %}
                  {{ section.settings.button_label | default: 'Lägg i varukorg' }}
                {% else %}
                  Slutsåld
                {% endif %}
              </button>

              {{ form | payment_button }}
            {% endform %}

            {% render 'trust-near-atc', class_prefix: 'product-showcase__trust-atc' %}
            {% render 'legal-links', class_prefix: 'product-showcase__legal', compact: true %}
          </div>
        </div>
      </div>
    {% else %}
      <p class="product-showcase__empty">
        Välj en produkt i temaredigeraren för att visa köpboxen.
      </p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-showcase {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pshow-bg, #101820);
    color: var(--pshow-text, #f6f7f2);
    scroll-margin-top: 80px;
  }

  .product-showcase__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .product-showcase__header {
    text-align: center;
    margin-bottom: 24px;
  }

  .product-showcase__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .product-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  .product-showcase__media {
    border-radius: 20px;
    overflow: hidden;
    background-color: var(--pshow-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 8%, transparent);
    aspect-ratio: 1;
  }

  .product-showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-showcase__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--pshow-text, #f6f7f2) 20%, transparent);
  }

  .product-showcase__buy {
    padding: 32px 28px;
    border-radius: var(--pp-radius-lg, 20px);
    background: linear-gradient(165deg, color-mix(in srgb, var(--pshow-surface, #14212a) 92%, #fff 8%) 0%, var(--pshow-surface, #14212a) 100%);
    border: 1px solid var(--pp-border);
    box-shadow: var(--pp-shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-showcase__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .product-showcase__badge {
    display: inline-flex;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pshow-accent-ink, #071014);
    background: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__badge--muted {
    color: var(--pshow-muted, #9aa8a2);
    text-transform: none;
    font-weight: 600;
    letter-spacing: 0;
    background: color-mix(in srgb, var(--pshow-text, #f6f7f2) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 10%, transparent);
  }

  .product-showcase__save {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--pshow-accent-ink, #071014);
    background: linear-gradient(135deg, var(--pshow-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 35%, var(--pshow-accent, #2dd4bf)));
  }

  .product-showcase__title {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    line-height: 1.2;
  }

  .product-showcase__price {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .product-showcase__price-compare {
    font-size: 1rem;
    color: var(--pshow-muted, #9aa8a2);
  }

  .product-showcase__price-current {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--pshow-accent, #2dd4bf);
  }

  .product-showcase__description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--pshow-muted, #9aa8a2);
  }

  .product-showcase__trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .product-showcase__trust-item {
    font-size: 0.88rem;
    padding-left: 20px;
    position: relative;
    color: var(--pshow-text, #f6f7f2);
  }

  .product-showcase__trust-item::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--pshow-accent, #2dd4bf);
    font-weight: 700;
  }

  .product-showcase__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 8px;
  }

  .product-showcase__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--pshow-muted, #9aa8a2);
  }

  .product-showcase__select,
  .product-showcase__qty {
    width: 100%;
    min-height: 48px;
    padding: 0 14px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--pshow-text, #f6f7f2) 15%, transparent);
    background-color: var(--pshow-bg, #101820);
    color: var(--pshow-text, #f6f7f2);
  }

  .product-showcase__qty-row {
    max-width: 120px;
  }

  .product-showcase__submit {
    width: 100%;
    min-height: 54px;
    border: none;
    border-radius: var(--pp-radius-pill, 999px);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    color: var(--pshow-accent-ink, #071014);
    background: linear-gradient(135deg, var(--pshow-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 28%, var(--pshow-accent, #2dd4bf)));
    box-shadow: var(--pp-shadow-glow);
    transition:
      transform var(--pp-transition, 0.2s ease),
      box-shadow var(--pp-transition, 0.2s ease),
      opacity var(--pp-transition, 0.2s ease);
  }

  .product-showcase__submit:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .product-showcase__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .product-showcase__form .shopify-payment-button {
    margin-top: 4px;
  }

  .product-showcase__empty {
    text-align: center;
    padding: 48px 24px;
    border-radius: 16px;
    background-color: var(--pshow-surface, #14212a);
    color: var(--pshow-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .product-showcase {
      padding-block: 68px;
    }

    .product-showcase__grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-showcase__submit {
      transition: none;
    }

    .product-showcase__submit:hover:not(:disabled) {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Bästsäljare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Perfect Combo"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Short description",
      "info": "Optional. Overrides the product description excerpt."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#071014"
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Fri frakt över 999 kr"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product showcase",
      "blocks": [
        { "type": "trust_point", "settings": { "text": "Fri frakt" } },
        { "type": "trust_point", "settings": { "text": "14 dagars ångerrätt" } },
        { "type": "trust_point", "settings": { "text": "Säker betalning" } }
      ]
    }
  ]
}
{% endschema %}
