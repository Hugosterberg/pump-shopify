<header
  class="site-header full-width"
  style="
    --hdr-bg: {{ section.settings.background_color }};
    --hdr-text: {{ section.settings.text_color }};
    --hdr-muted: {{ section.settings.muted_text_color }};
    --hdr-accent: {{ section.settings.accent_color }};
    --hdr-border: {{ section.settings.border_color }};
  "
>
  <div class="site-header__inner">
    <div class="site-header__brand">
      {% if section.settings.logo != blank %}
        <a class="site-header__logo-link" href="{{ routes.root_url }}">
          {{
            section.settings.logo
            | image_url: width: 300
            | image_tag:
              loading: 'eager',
              widths: '120, 180, 240, 300',
              sizes: '140px',
              class: 'site-header__logo',
              alt: shop.name
          }}
        </a>
      {% elsif settings.logo != blank %}
        <a class="site-header__logo-link" href="{{ routes.root_url }}">
          {{
            settings.logo
            | image_url: width: 300
            | image_tag:
              loading: 'eager',
              widths: '120, 180, 240, 300',
              sizes: '140px',
              class: 'site-header__logo',
              alt: shop.name
          }}
        </a>
      {% else %}
        <a
          class="site-header__logo-link site-header__logo-link--wave"
          href="{{ routes.root_url }}"
          aria-label="{{ shop.name }}"
        >
          <span
            class="site-header__logo-wave"
            style="--logo-mask: url('{{ 'pump-logo.png' | asset_url }}');"
            aria-hidden="true"
          ></span>
        </a>
      {% endif %}
    </div>

    {% if section.settings.menu != blank %}
      <nav class="site-header__nav" aria-label="Huvudmeny">
        <ul class="site-header__menu" role="list">
          {% for link in section.settings.menu.links %}
            <li>
              <a
                class="site-header__link{% if link.active %} site-header__link--active{% endif %}"
                href="{{ link.url }}"
                {% if link.current %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <div class="site-header__actions">
      {% if section.settings.show_localization %}
        {% render 'localization-form',
          class_prefix: 'site-header__localization',
          form_id: 'HeaderLocalizationForm',
          compact: true,
          show_label: false
        %}
      {% endif %}

      {% if section.settings.show_cta and section.settings.cta_label != blank %}
        <a class="site-header__cta" href="{{ section.settings.cta_link | default: '#product-showcase' }}">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}

      {% if shop.customer_accounts_enabled %}
        <a class="site-header__icon-btn" href="{{ routes.account_url }}" aria-label="Konto">
          <shopify-account menu="{{ section.settings.customer_account_menu }}">
            {{ 'icon-account.svg' | inline_asset_content }}
          </shopify-account>
        </a>
      {% endif %}

      <button type="button" class="site-header__icon-btn" data-search-open aria-label="Sök">
        {% render 'icon', name: 'search', size: 22 %}
      </button>

      <button
        type="button"
        class="site-header__icon-btn site-header__cart"
        data-cart-open
        aria-label="Varukorg{% if cart.item_count > 0 %}, {{ cart.item_count }} {% if cart.item_count == 1 %}artikel{% else %}artiklar{% endif %}{% endif %}"
      >
        {{ 'icon-cart.svg' | inline_asset_content }}
        <span class="site-header__cart-count" data-cart-count aria-hidden="true"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </button>

      {% if section.settings.menu != blank %}
        <button
          type="button"
          class="site-header__menu-toggle"
          data-mobile-nav-open
          aria-expanded="false"
          aria-controls="SiteHeaderMobileNav"
          aria-label="Öppna meny"
        >
          <span class="site-header__menu-icon" aria-hidden="true"></span>
        </button>
      {% endif %}
    </div>
  </div>

  {% if section.settings.menu != blank %}
    <div class="site-header__mobile-overlay" data-mobile-nav hidden>
      <div class="site-header__mobile-backdrop" data-mobile-nav-close tabindex="-1"></div>
      <nav
        id="SiteHeaderMobileNav"
        class="site-header__mobile-panel"
        aria-label="Mobilmeny"
        data-mobile-nav-panel
      >
        <div class="site-header__mobile-head">
          <span class="site-header__mobile-title">Meny</span>
          <button type="button" class="site-header__mobile-close" data-mobile-nav-close aria-label="Stäng meny">
            {% render 'icon', name: 'x', size: 20 %}
          </button>
        </div>
        <ul class="site-header__mobile-links" role="list">
          {% for link in section.settings.menu.links %}
            <li>
              <a
                class="site-header__mobile-link"
                href="{{ link.url }}"
                {% if link.current %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
        {% if section.settings.show_cta and section.settings.cta_label != blank %}
          <a class="site-header__mobile-cta pp-btn-primary pp-btn--full" href="{{ section.settings.cta_link | default: '#product-showcase' }}">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
        {% if section.settings.show_localization %}
          <div class="site-header__mobile-localization">
            {% render 'localization-form',
              class_prefix: 'site-header__mobile-loc',
              form_id: 'MobileLocalizationForm',
              compact: true,
              show_label: false
            %}
          </div>
        {% endif %}
      </nav>
    </div>
  {% endif %}
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background-color: var(--pp-glass, color-mix(in srgb, var(--hdr-bg, #071014) 88%, transparent));
    backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid var(--pp-border);
    color: var(--hdr-text, #f6f7f2);
  }

  .site-header__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    padding-inline: var(--page-margin, 20px);
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .site-header__brand {
    flex-shrink: 0;
  }

  .site-header__title {
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--hdr-text, #f6f7f2);
    letter-spacing: -0.02em;
  }

  .site-header__logo-link {
    display: block;
    line-height: 0;
  }

  .site-header__logo {
    height: 32px;
    width: auto;
  }

  /* The "pump" wordmark stays pure brand white. The transparent PNG
     is used as an alpha mask filled with solid white. */
  .site-header__logo-wave {
    display: block;
    width: 92px;
    height: 26px;
    -webkit-mask: var(--logo-mask) center / contain no-repeat;
    mask: var(--logo-mask) center / contain no-repeat;
    background-color: #ffffff;
  }

  .site-header__nav {
    display: none;
  }

  .site-header__menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 28px;
  }

  .site-header__link {
    position: relative;
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--hdr-muted, #9aa8a2);
    transition: color 0.15s ease;
  }

  .site-header__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: var(--pp-gradient-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .site-header__link:hover,
  .site-header__link--active {
    color: var(--hdr-text, #f6f7f2);
  }

  .site-header__link:hover::after,
  .site-header__link--active::after {
    transform: scaleX(1);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .site-header__cta {
    display: none;
    min-height: 40px;
    padding-inline: 20px;
    align-items: center;
    border-radius: var(--pp-radius-pill, 999px);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--hdr-bg, #071014);
    background: linear-gradient(135deg, var(--hdr-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 30%, var(--hdr-accent, #2dd4bf)));
    box-shadow: 0 10px 28px -16px color-mix(in srgb, var(--hdr-accent, #2dd4bf) 70%, #000);
    transition: transform var(--pp-transition, 0.2s ease), box-shadow var(--pp-transition, 0.2s ease);
  }

  .site-header__cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--pp-shadow-glow);
  }

  .site-header__icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: none;
    color: var(--hdr-text, #f6f7f2);
    text-decoration: none;
    background: transparent;
    transition: background-color 0.15s ease;
  }

  .site-header__icon-btn:hover {
    background-color: color-mix(in srgb, var(--hdr-accent, #2dd4bf) 14%, transparent);
    color: var(--hdr-text, #f6f7f2);
  }

  .site-header__icon-btn svg {
    width: 22px;
    height: 22px;
  }

  .site-header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 18px;
    height: 18px;
    padding-inline: 4px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    color: var(--hdr-bg, #071014);
    background-color: var(--hdr-accent, #2dd4bf);
  }

  .site-header__cart-count[hidden] {
    display: none;
  }

  .site-header__menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--hdr-text, #f6f7f2);
    background: color-mix(in srgb, var(--hdr-text, #f6f7f2) 6%, transparent);
  }

  .site-header__menu-icon,
  .site-header__menu-icon::before,
  .site-header__menu-icon::after {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--hdr-text, #f6f7f2);
    border-radius: 1px;
    position: relative;
  }

  .site-header__menu-icon::before,
  .site-header__menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .site-header__menu-icon::before {
    top: -6px;
  }

  .site-header__menu-icon::after {
    top: 6px;
    transition: transform 0.2s ease, top 0.2s ease;
  }

  .site-header__menu-icon::before {
    transition: transform 0.2s ease, top 0.2s ease;
  }

  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-icon {
    background-color: transparent;
  }

  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-icon::before {
    top: 0;
    transform: rotate(45deg);
  }

  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-icon::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .site-header__mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 220;
  }

  .site-header__mobile-overlay[hidden] {
    display: none;
  }

  body.mobile-nav-open {
    overflow: hidden;
  }

  .site-header__mobile-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(7 16 20 / 72%);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .site-header__mobile-overlay.is-open .site-header__mobile-backdrop {
    opacity: 1;
  }

  .site-header__mobile-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: min(100%, 320px);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 20px;
    background: linear-gradient(180deg, var(--hdr-bg, #071014) 0%, color-mix(in srgb, var(--hdr-bg, #071014) 92%, #000) 100%);
    border-left: 1px solid var(--hdr-border, rgba(255, 255, 255, 0.08));
    box-shadow: -24px 0 60px rgb(0 0 0 / 45%);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header__mobile-overlay.is-open .site-header__mobile-panel {
    transform: translateX(0);
  }

  .site-header__mobile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--hdr-text, #f6f7f2) 10%, transparent);
  }

  .site-header__mobile-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hdr-muted, #9aa8a2);
  }

  .site-header__mobile-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--hdr-muted, #9aa8a2);
    background: color-mix(in srgb, var(--hdr-text, #f6f7f2) 6%, transparent);
  }

  .site-header__mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    overflow-y: auto;
  }

  .site-header__mobile-link {
    display: block;
    padding: 14px 16px;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--hdr-text, #f6f7f2);
    transition: background 0.18s ease, color 0.18s ease;
  }

  .site-header__mobile-link:hover,
  .site-header__mobile-link[aria-current='page'] {
    background: color-mix(in srgb, var(--hdr-accent, #2dd4bf) 12%, transparent);
    color: var(--hdr-accent, #2dd4bf);
  }

  .site-header__mobile-cta {
    margin-top: 20px;
    --pp-accent: var(--hdr-accent, #2dd4bf);
    --pp-accent-ink: var(--hdr-bg, #071014);
  }

  .site-header__mobile-localization {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--hdr-border, rgba(255, 255, 255, 0.08));
  }

  .site-header__mobile-loc__fields--compact {
    flex-direction: column;
    align-items: stretch;
  }

  .site-header__mobile-loc__fields--compact select {
    max-width: none;
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .site-header__inner {
      min-height: 72px;
    }

    .site-header__nav {
      display: block;
    }

    .site-header__cta {
      display: inline-flex;
    }

    .site-header__menu-toggle {
      display: none;
    }

    .site-header__mobile-overlay {
      display: none !important;
    }

    .site-header__logo {
      height: 36px;
    }

    .site-header__logo-wave {
      width: 106px;
      height: 30px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;

    function onScroll() {
      header.classList.toggle('is-scrolled', window.scrollY > 8);
    }

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const mobileNav = header.querySelector('[data-mobile-nav]');
    const mobileOpen = header.querySelector('[data-mobile-nav-open]');
    const mobilePanel = header.querySelector('[data-mobile-nav-panel]');
    let mobileLastFocus = null;

    function openMobileNav() {
      if (!mobileNav || !mobileOpen) return;
      mobileLastFocus = document.activeElement;
      mobileNav.hidden = false;
      mobileNav.classList.add('is-open');
      mobileOpen.setAttribute('aria-expanded', 'true');
      document.body.classList.add('mobile-nav-open');
      window.requestAnimationFrame(function () {
        const firstLink = mobilePanel && mobilePanel.querySelector('a, button');
        if (firstLink) firstLink.focus();
      });
    }

    function closeMobileNav() {
      if (!mobileNav || !mobileOpen) return;
      mobileNav.classList.remove('is-open');
      mobileOpen.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('mobile-nav-open');
      window.setTimeout(function () {
        if (!mobileNav.classList.contains('is-open')) {
          mobileNav.hidden = true;
        }
      }, 280);
      if (mobileLastFocus && typeof mobileLastFocus.focus === 'function') {
        mobileLastFocus.focus();
      }
    }

    if (mobileOpen) {
      mobileOpen.addEventListener('click', function () {
        if (mobileNav.classList.contains('is-open')) {
          closeMobileNav();
        } else {
          openMobileNav();
        }
      });
    }

    header.querySelectorAll('[data-mobile-nav-close]').forEach(function (el) {
      el.addEventListener('click', closeMobileNav);
    });

    if (mobilePanel) {
      mobilePanel.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', closeMobileNav);
      });
    }

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && mobileNav && mobileNav.classList.contains('is-open')) {
        closeMobileNav();
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "Show country & language selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "rgba(255,255,255,0.08)"
    }
  ]
}
{% endschema %}

