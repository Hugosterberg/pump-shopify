    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Portabel komfort överallt. Smarta lösningar för livet utomhus."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "info@pumpportable.com"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
