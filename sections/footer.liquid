<footer
  class="site-footer full-width"
  style="
    --ftr-bg: {{ section.settings.background_color }};
    --ftr-surface: {{ section.settings.surface_color }};
    --ftr-text: {{ section.settings.text_color }};
    --ftr-muted: {{ section.settings.muted_text_color }};
    --ftr-accent: {{ section.settings.accent_color }};
  "
>
  <div class="site-footer__inner">
    {% if section.settings.show_newsletter %}
      <div class="site-footer__newsletter">
        <div class="site-footer__newsletter-copy">
          {% if section.settings.newsletter_title != blank %}
            <h2 class="site-footer__newsletter-title">{{ section.settings.newsletter_title }}</h2>
          {% endif %}
          {% if section.settings.newsletter_text != blank %}
            <p class="site-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
          {% endif %}
        </div>

        {% form 'customer', class: 'site-footer__newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter,footer">

          {% if form.posted_successfully? %}
            <p class="site-footer__newsletter-success">
              {{ section.settings.newsletter_success | default: 'Tack! Du är nu anmäld.' }}
            </p>
          {% else %}
            <div class="site-footer__newsletter-field">
              <label class="visually-hidden" for="FooterNewsletter-{{ section.id }}">
                {{ section.settings.newsletter_placeholder | default: 'E-post' }}
              </label>
              <input
                id="FooterNewsletter-{{ section.id }}"
                class="site-footer__newsletter-input"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="{{ section.settings.newsletter_placeholder | default: 'E-post' }}"
                autocomplete="email"
                required
              >
              <button
                class="site-footer__newsletter-submit"
                type="submit"
                aria-label="{{ section.settings.newsletter_button | default: 'Prenumerera' }}"
              >
                {% render 'icon', name: 'arrow-right', size: 18 %}
              </button>
            </div>
            {% render 'newsletter-privacy-note', class_prefix: 'site-footer__newsletter-privacy' %}
            {%- if form.errors -%}
              <p class="site-footer__newsletter-error">{{ form.errors | default_errors }}</p>
            {%- endif -%}
          {% endif %}
        {% endform %}
      </div>
    {% endif %}

    <div class="site-footer__top">
      <div class="site-footer__brand">
        {% if section.settings.logo != blank %}
          {{
            section.settings.logo
            | image_url: width: 240
            | image_tag: loading: 'lazy', class: 'site-footer__logo', alt: shop.name
          }}
        {% else %}
          <a class="site-footer__logo-link" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
            <img
              src="{{ 'pump-logo.png' | asset_url }}"
              alt="{{ shop.name }}"
              class="site-footer__logo-wordmark"
              width="96"
              height="28"
              loading="lazy"
            >
          </a>
        {% endif %}
        {% if section.settings.tagline != blank %}
          <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
        {% endif %}
        {% if section.settings.contact_email != blank %}
          <a class="site-footer__email" href="mailto:{{ section.settings.contact_email }}">
            {{ section.settings.contact_email }}
          </a>
        {% endif %}
        {% if section.settings.instagram_url != blank or section.settings.facebook_url != blank %}
          <div class="site-footer__social">
            {% if section.settings.instagram_url != blank %}
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                Instagram
              </a>
            {% endif %}
            {% if section.settings.facebook_url != blank %}
              <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 8.5V7c0-.8.2-1.3 1.2-1.3H17V3h-2.2C12.8 3 12 4.5 12 6.5V8.5H10V12h2v9h2v-9h2.1l.9-3.5H14z" fill="currentColor"/></svg>
                Facebook
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if section.settings.menu != blank %}
        <nav class="site-footer__nav" aria-label="Sidfotsmeny">
          <h2 class="site-footer__nav-title">{{ section.settings.menu_title | default: 'Länkar' }}</h2>
          <ul role="list">
            {% for link in section.settings.menu.links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

      {% if section.settings.secondary_menu != blank %}
        <nav class="site-footer__nav" aria-label="Support">
          <h2 class="site-footer__nav-title">{{ section.settings.secondary_menu_title | default: 'Support' }}</h2>
          <ul role="list">
            {% for link in section.settings.secondary_menu.links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}
    </div>

    {% if section.settings.show_trust_highlights %}
      <div class="site-footer__trust-highlights">
        {% if section.settings.trust_warranty_title != blank %}
          <div class="site-footer__trust-item">
            <span class="site-footer__trust-icon" aria-hidden="true">
              {% render 'icon', name: 'shield', size: 18 %}
            </span>
            <div class="site-footer__trust-body">
              <h3 class="site-footer__trust-title">{{ section.settings.trust_warranty_title }}</h3>
              {% if section.settings.trust_warranty_text != blank %}
                <p class="site-footer__trust-text">{{ section.settings.trust_warranty_text }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% if section.settings.trust_shipping_title != blank %}
          <div class="site-footer__trust-item">
            <span class="site-footer__trust-icon" aria-hidden="true">
              {% render 'icon', name: 'truck', size: 18 %}
            </span>
            <div class="site-footer__trust-body">
              <h3 class="site-footer__trust-title">{{ section.settings.trust_shipping_title }}</h3>
              {% if section.settings.trust_shipping_text != blank %}
                <p class="site-footer__trust-text">{{ section.settings.trust_shipping_text }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.show_legal_links %}
      <div class="site-footer__legal-row">
        {% render 'legal-business-info',
          business_name: section.settings.legal_business_name,
          org_number: section.settings.legal_org_number,
          show_address: section.settings.show_legal_address
        %}
        {% render 'legal-links', class_prefix: 'site-footer__legal' %}
        {% render 'localization-form', class_prefix: 'site-footer__localization' %}
      </div>
    {% endif %}

    {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
      <div class="site-footer__payment">
        <span class="site-footer__payment-label">Betalningsmetoder</span>
        <div class="site-footer__payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}
      </p>
      {% if section.settings.show_powered_by %}
        <p class="site-footer__powered">{{ powered_by_link }}</p>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    margin-top: auto;
    padding-block: 64px 32px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--ftr-bg, #071014);
    color: var(--ftr-text, #f6f7f2);
    border-top: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 8%, transparent);
  }

  .site-footer__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .site-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 36px;
    border-bottom: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 8%, transparent);
  }

  .site-footer__newsletter-copy {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 48ch;
  }

  .site-footer__newsletter-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .site-footer__newsletter-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__newsletter-field {
    display: flex;
    gap: 8px;
    max-width: 420px;
  }

  .site-footer__newsletter-input {
    flex: 1;
    min-width: 0;
    min-height: 46px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 15%, transparent);
    background-color: var(--ftr-surface, #14212a);
    color: var(--ftr-text, #f6f7f2);
  }

  .site-footer__newsletter-input::placeholder {
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__newsletter-submit {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--ftr-bg, #071014);
    background-color: var(--ftr-accent, #2dd4bf);
    transition: transform 0.15s ease;
  }

  .site-footer__newsletter-submit:hover {
    transform: translateX(2px);
  }

  .site-footer__newsletter-success {
    margin: 0;
    font-weight: 600;
    color: var(--ftr-accent, #2dd4bf);
  }

  .site-footer__newsletter-error {
    margin: 8px 0 0;
    font-size: 0.82rem;
    color: #f59e0b;
  }

  .site-footer__newsletter-privacy {
    margin: 10px 0 0;
    max-width: 48ch;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__newsletter-privacy a {
    color: var(--ftr-text, #f6f7f2);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer__legal-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 6%, transparent);
  }

  .site-footer__trust-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    padding-top: 28px;
    border-top: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 8%, transparent);
  }

  .site-footer__trust-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .site-footer__trust-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    color: var(--ftr-accent, #2dd4bf);
    background: color-mix(in srgb, var(--ftr-accent, #2dd4bf) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--ftr-accent, #2dd4bf) 28%, transparent);
  }

  .site-footer__trust-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .site-footer__trust-title {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--ftr-text, #f6f7f2);
  }

  .site-footer__trust-text {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--ftr-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .site-footer__trust-highlights {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  .legal-business {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 42ch;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--ftr-muted, #9aa8a2);
  }

  .legal-business__name {
    margin: 0;
    font-weight: 600;
    color: var(--ftr-text, #f6f7f2);
  }

  .legal-business__org,
  .legal-business__address,
  .legal-business__contact {
    margin: 0;
  }

  .legal-business a {
    color: inherit;
    text-decoration: none;
  }

  .legal-business a:hover {
    color: var(--ftr-accent, #2dd4bf);
  }

  .site-footer__legal__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
  }

  .site-footer__legal a {
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--ftr-text, #f6f7f2);
  }

  .site-footer__legal a:hover {
    color: var(--ftr-accent, #2dd4bf);
  }

  .site-footer__localization {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .site-footer__localization__label {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__localization__fields {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .site-footer__localization .pp-loc__trigger {
    border-radius: 999px;
    background: var(--ftr-surface, #14212a);
  }

  .site-footer__localization__submit {
    min-height: 40px;
    padding-inline: 16px;
    border: none;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--ftr-bg, #071014);
    background: var(--ftr-accent, #2dd4bf);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 32ch;
  }

  .site-footer__logo {
    height: 28px;
    width: auto;
  }

  .site-footer__logo-link {
    display: inline-block;
    line-height: 0;
  }

  .site-footer__logo-wordmark {
    display: block;
    height: 28px;
    width: auto;
  }

  .site-footer__name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .site-footer__tagline {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__email {
    font-size: 0.9rem;
    color: var(--ftr-accent, #2dd4bf);
    text-decoration: none;
  }

  .site-footer__social {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }

  .site-footer__social a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--ftr-text, #f6f7f2);
  }

  .site-footer__social a:hover {
    color: var(--ftr-accent, #2dd4bf);
  }

  .site-footer__nav-title {
    margin: 0 0 14px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .site-footer__nav a {
    font-size: 0.92rem;
    text-decoration: none;
    color: var(--ftr-text, #f6f7f2);
    transition: color 0.15s ease;
  }

  .site-footer__nav a:hover {
    color: var(--ftr-accent, #2dd4bf);
  }

  .site-footer__payment {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 6%, transparent);
  }

  .site-footer__payment-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .site-footer__payment-icons svg {
    height: 24px;
    width: auto;
  }

  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--ftr-text, #f6f7f2) 6%, transparent);
    font-size: 0.82rem;
    color: var(--ftr-muted, #9aa8a2);
  }

  .site-footer__copyright,
  .site-footer__powered {
    margin: 0;
  }

  .site-footer__powered a {
    color: inherit;
  }

  @media screen and (min-width: 750px) {
    .site-footer__newsletter {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }

    .site-footer__newsletter-field {
      width: 420px;
    }

    .site-footer__top {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 48px;
    }

    .site-footer__legal-row {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
      gap: 40px;
    }

    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer__newsletter-submit {
      transition: none;
    }

    .site-footer__newsletter-submit:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter signup"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter title",
      "default": "Håll dig uppdaterad"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Få tips och erbjudanden, vi hör bara av oss när något riktigt bra dyker upp."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "E-post"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button label (for screen readers)",
      "default": "Prenumerera"
    },
    {
      "type": "text",
      "id": "newsletter_success",
      "label": "Success message",
      "default": "Tack! Du är nu anmäld."
    },
    {
      "type": "header",
      "content": "Trust highlights"
    },
    {
      "type": "checkbox",
      "id": "show_trust_highlights",
      "label": "Show warranty & shipping highlights",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_warranty_title",
      "label": "Warranty title",
      "default": "1 års garanti"
    },
    {
      "type": "text",
      "id": "trust_warranty_text",
      "label": "Warranty text",
      "default": "Vi strävar efter att erbjuda saker som håller."
