    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu title",
      "default": "Länkar"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary menu"
    },
    {
      "type": "text",
      "id": "secondary_menu_title",
      "label": "Secondary menu title",
      "default": "Support"
