{% comment %}
  Search page — preserves Shopify search form and pagination.
{% endcomment %}

<div class="main-search full-width">
  <div class="main-search__inner">
    <h1 class="main-search__title">{{ 'search.title' | t }}</h1>

    <form class="main-search__form" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="SearchInput">{{ 'search.placeholder' | t }}</label>
      <input
        id="SearchInput"
        class="main-search__input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
      >
      <button class="main-search__submit" type="submit">{{ 'search.submit' | t }}</button>
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <div class="main-search__empty">
          <p class="main-search__message">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
          <p class="main-search__empty-hint">Prova ett annat sökord eller bläddra bland våra produkter.</p>
          <ul class="main-search__suggestions" role="list">
            <li><a class="main-search__suggestion" href="/products/portabel-dusch">Portabel dusch</a></li>
            <li><a class="main-search__suggestion" href="/products/portabel-hink">Portabel hink</a></li>
            <li><a class="main-search__suggestion" href="/products/the-perfect-combo-portabel-dusch-vikbar-hink-1">The Perfect Combo</a></li>
            <li><a class="main-search__suggestion" href="/pages/faq">Vanliga frågor</a></li>
          </ul>
          <a class="main-search__cta" href="{{ routes.all_products_collection_url }}">Se alla produkter</a>
        </div>
      {% else %}
        <p class="main-search__message">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        {% paginate search.results by 20 %}
          <ul class="main-search__results" role="list">
            {% for result in search.results %}
              <li class="main-search__result">
                {% assign featured_image = result.featured_image | default: result.image %}
                <a class="main-search__link" href="{{ result.url }}">
                  {% if featured_image %}
                    <div class="main-search__media">
                      {{
                        featured_image
                        | image_url: width: 200
                        | image_tag: loading: 'lazy', widths: '100, 200', sizes: '80px', alt: result.title
                      }}
                    </div>
                  {% endif %}
                  <div class="main-search__info">
                    <span class="main-search__name">{{ result.title }}</span>
                    {% if result.price %}
                      <span class="main-search__price">{{ result.price | money }}</span>
                    {% endif %}
                  </div>
                </a>
              </li>
            {% endfor %}
          </ul>

          {% if paginate.pages > 1 %}
            <nav class="main-search__pagination" aria-label="Sidnavigering">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% endpaginate %}
      {% endif %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .main-search {
    padding-block: 48px 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pp-bg-deep, #071014);
    color: var(--pp-text, #f6f7f2);
    min-height: 50vh;
  }

  .main-search__inner {
    max-width: 720px;
    margin-inline: auto;
  }

  .main-search__title {
    margin: 0 0 24px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    letter-spacing: -0.02em;
  }

  .main-search__form {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
  }

  .main-search__input {
    flex: 1;
    min-height: 52px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    background-color: var(--pp-surface, #14212a);
    color: var(--pp-text, #f6f7f2);
  }

  .main-search__submit {
    flex-shrink: 0;
    min-height: 52px;
    padding-inline: 24px;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    cursor: pointer;
    color: var(--pp-bg-deep, #071014);
    background-color: var(--pp-accent, #2dd4bf);
  }

  .main-search__message {
    margin: 0 0 24px;
    color: var(--pp-muted, #9aa8a2);
  }

  .main-search__results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .main-search__link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background-color: var(--pp-surface, #14212a);
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
    transition: background-color 0.15s ease;
  }

  .main-search__link:hover {
    background-color: color-mix(in srgb, var(--pp-accent, #2dd4bf) 8%, var(--pp-surface, #14212a));
  }

  .main-search__media {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .main-search__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-search__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .main-search__name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .main-search__price {
    font-size: 0.88rem;
    color: var(--pp-accent, #2dd4bf);
  }

  .main-search__pagination {
    margin-top: 32px;
    text-align: center;
  }

  .main-search__empty {
    padding: 28px 24px;
    border-radius: 16px;
    background-color: var(--pp-surface, #14212a);
    border: 1px solid var(--pp-border, rgba(255, 255, 255, 0.08));
  }

  .main-search__empty-hint {
    margin: 0 0 16px;
    font-size: 0.92rem;
    color: var(--pp-text, #f6f7f2);
  }

  .main-search__suggestions {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .main-search__suggestion {
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-text, #f6f7f2);
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--pp-accent, #2dd4bf) 25%, transparent);
    transition: background-color 0.15s ease;
  }

  .main-search__suggestion:hover {
    background: color-mix(in srgb, var(--pp-accent, #2dd4bf) 18%, transparent);
  }

  .main-search__cta {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    padding-inline: 20px;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: var(--pp-bg-deep, #071014);
    background-color: var(--pp-accent, #2dd4bf);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
