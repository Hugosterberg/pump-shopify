<div
  class="final-cta full-width"
  style="
    --fcta-bg: {{ section.settings.background_color }};
    --fcta-text: {{ section.settings.text_color }};
    --fcta-muted: {{ section.settings.muted_text_color }};
    --fcta-accent: {{ section.settings.accent_color }};
    --fcta-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  <div class="final-cta__inner">
    <span class="final-cta__icon" aria-hidden="true">
      {% render 'icon', name: 'droplet', size: 26 %}
    </span>
    {% if section.settings.heading != blank %}
      <h2 class="final-cta__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="final-cta__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.button_label != blank %}
      <a class="final-cta__btn" href="{{ section.settings.button_link | default: '#product-showcase' }}">
        {{ section.settings.button_label }}
      </a>
    {% endif %}

    <div class="final-cta__trust">
      {% render 'trust-near-atc', class_prefix: 'final-cta__trust-atc', show_payment_icons: false, compact: true %}
    </div>
  </div>
</div>

{% stylesheet %}
  .final-cta {
    padding-block: 44px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--fcta-bg, #14212a);
    color: var(--fcta-text, #f6f7f2);
    text-align: center;
    background-image: radial-gradient(
      80% 80% at 50% 100%,
      color-mix(in srgb, var(--fcta-accent, #2dd4bf) 18%, transparent) 0%,
      transparent 60%
    );
  }

  .final-cta__inner {
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .final-cta__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 999px;
    color: var(--fcta-accent, #2dd4bf);
    background-color: color-mix(in srgb, var(--fcta-accent, #2dd4bf) 14%, transparent);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--fcta-accent, #2dd4bf) 8%, transparent);
  }

  .final-cta__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .final-cta__subheading {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--fcta-muted, #9aa8a2);
  }

  .final-cta__btn {
    display: inline-flex;
    margin-top: 8px;
    min-height: 54px;
    padding-inline: 32px;
    align-items: center;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    color: var(--fcta-accent-ink, #071014);
    background: linear-gradient(135deg, var(--fcta-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 30%, var(--fcta-accent, #2dd4bf)));
    box-shadow: 0 10px 30px -10px color-mix(in srgb, var(--fcta-accent, #2dd4bf) 80%, #000);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .final-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -10px color-mix(in srgb, var(--fcta-accent, #2dd4bf) 90%, #000);
  }

  .final-cta__trust {
    width: 100%;
    margin-top: 8px;
  }

  .final-cta__trust .pp-trust-atc--compact {
    justify-content: center;
    gap: 8px;
  }

  .final-cta__trust-atc-wrap {
    border-top: 0;
    padding-top: 0;
    margin-top: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .final-cta__btn {
      transition: none;
    }

    .final-cta__btn:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Final CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Redo för friheten?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ta med duschen dit livet händer: camping, båt, bastu eller strand."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Köp The Perfect Combo"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#071014"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
