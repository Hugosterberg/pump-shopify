<div
  class="whats-included full-width"
  style="
    --wi-bg: {{ section.settings.background_color }};
    --wi-surface: {{ section.settings.surface_color }};
    --wi-text: {{ section.settings.text_color }};
    --wi-muted: {{ section.settings.muted_text_color }};
    --wi-accent: {{ section.settings.accent_color }};
  "
>
  <div class="whats-included__inner">
    {% if section.settings.heading != blank %}
      <header class="whats-included__header">
        {% if section.settings.eyebrow != blank %}
          <p class="whats-included__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="whats-included__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="whats-included__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="whats-included__list" role="list">
        {% for block in section.blocks %}
          <li class="whats-included__item" {{ block.shopify_attributes }}>
            <span class="whats-included__check" aria-hidden="true">✓</span>
            <span>{{ block.settings.item }}</span>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .whats-included {
    padding-block: 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--wi-bg, #071014);
    color: var(--wi-text, #f6f7f2);
  }

  .whats-included__inner {
    max-width: 640px;
    margin-inline: auto;
  }

  .whats-included__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .whats-included__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--wi-accent, #2dd4bf);
  }

  .whats-included__heading {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    letter-spacing: -0.02em;
  }

  .whats-included__subheading {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--wi-muted, #9aa8a2);
  }

  .whats-included__list {
    list-style: none;
    margin: 0;
    padding: 28px 24px;
    border-radius: 16px;
    background-color: var(--wi-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--wi-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .whats-included__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .whats-included__check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--wi-bg, #071014);
    background-color: var(--wi-accent, #2dd4bf);
  }

  @media screen and (min-width: 750px) {
    .whats-included {
      padding-block: 96px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "What's included",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "I förpackningen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vad ingår?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Allt du behöver för att komma igång direkt."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Included item",
      "settings": [
        {
          "type": "text",
          "id": "item",
          "label": "Item",
          "default": "1× portabel dusch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What's included",
      "blocks": [
        { "type": "item", "settings": { "item": "1× portabel dusch med digital display" } },
        { "type": "item", "settings": { "item": "1× duschmunstycke" } },
        { "type": "item", "settings": { "item": "1× spolmunstycke" } },
        { "type": "item", "settings": { "item": "1× vattenslang (2 m)" } },
        { "type": "item", "settings": { "item": "1× USB-C laddkabel" } },
        { "type": "item", "settings": { "item": "1× 3-i-1 multikrok" } },
        { "type": "item", "settings": { "item": "1× nätverkspåse" } },
        { "type": "item", "settings": { "item": "1× vikbar hink (20 liter)" } }
      ]
    }
  ]
}
{% endschema %}
