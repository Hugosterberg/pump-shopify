{% comment %}
  About section — brand story, values and an optional image.
  Designed for a Page using the "page.about" template.
{% endcomment %}

<div
  class="about-section full-width"
  style="
    --ab-bg: {{ section.settings.background_color }};
    --ab-surface: {{ section.settings.surface_color }};
    --ab-text: {{ section.settings.text_color }};
    --ab-muted: {{ section.settings.muted_text_color }};
    --ab-accent: {{ section.settings.accent_color }};
  "
>
  <div class="about-section__inner">
    <div class="about-section__lead">
      <div class="about-section__copy">
        {% if section.settings.eyebrow != blank %}
          <p class="about-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="about-section__heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="about-section__body rte">{{ section.settings.body }}</div>
        {% endif %}
        {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
          <a class="about-section__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label }}</a>
        {% endif %}
      </div>

      {% if section.settings.image != blank %}
        <div class="about-section__media">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '500, 800, 1200',
              sizes: '(min-width: 750px) 45vw, 100vw',
              alt: section.settings.heading | default: shop.name
          }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <ul class="about-section__values" role="list">
        {% for block in section.blocks %}
          <li class="about-section__value" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank and block.settings.icon != 'none' %}
              <span class="about-section__value-icon">{% render 'icon', name: block.settings.icon, size: 22 %}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h2 class="about-section__value-title">{{ block.settings.title }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="about-section__value-text">{{ block.settings.text }}</p>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .about-section {
    padding-block: 56px 80px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--ab-bg, #071014);
    color: var(--ab-text, #f6f7f2);
  }

  .about-section__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .about-section__lead {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  .about-section__eyebrow {
    margin: 0 0 12px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ab-accent, #2dd4bf);
  }

  .about-section__heading {
    margin: 0 0 18px;
    font-size: clamp(1.9rem, 4.5vw, 2.9rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .about-section__body {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ab-muted, #9aa8a2);
  }

  .about-section__cta {
    display: inline-flex;
    align-items: center;
    min-height: 52px;
    margin-top: 26px;
    padding-inline: 30px;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: #06231f;
    background-color: var(--ab-accent, #2dd4bf);
  }

  .about-section__cta:hover {
    filter: brightness(1.05);
  }

  .about-section__media {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .about-section__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-section__values {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .about-section__value {
    padding: 24px;
    border-radius: 16px;
    background-color: var(--ab-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--ab-text, #f6f7f2) 8%, transparent);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .about-section__value:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--ab-accent, #2dd4bf) 40%, transparent);
  }

  .about-section__value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-bottom: 14px;
    border-radius: 12px;
    color: var(--ab-accent, #2dd4bf);
    background-color: color-mix(in srgb, var(--ab-accent, #2dd4bf) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--ab-accent, #2dd4bf) 30%, transparent);
  }

  .about-section__value-title {
    margin: 0 0 8px;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .about-section__value-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ab-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .about-section {
      padding-block: 80px 110px;
    }

    .about-section__lead {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 56px;
    }

    .about-section__values {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Om oss"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Portabel komfort, var livet än tar dig"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Vi brinner för smarta och portabla lösningar som gör livet enklare, på resan, ute i naturen eller bara i vardagen. pump föddes ur en enkel idé: att ta med den där sköna, fräscha känslan överallt.</p><p>Vi strävar efter att erbjuda produkter som håller, med design som är lika genomtänkt som funktionen.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Kontakta oss"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "shield", "label": "Shield / warranty" },
            { "value": "truck", "label": "Truck / shipping" },
            { "value": "feather", "label": "Feather / lightweight" },
            { "value": "package", "label": "Package / portable" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "check", "label": "Check" },
            { "value": "bolt", "label": "Bolt" }
          ],
          "default": "shield"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "1 års garanti" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Vi strävar efter att erbjuda saker som håller." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "About section",
      "blocks": [
        { "type": "value", "settings": { "icon": "shield", "title": "1 års garanti", "text": "Vi strävar efter att erbjuda saker som håller." } },
        { "type": "value", "settings": { "icon": "truck", "title": "Fri frakt", "text": "Fri frakt på order över 999 kr inom Sverige." } },
        { "type": "value", "settings": { "icon": "feather", "title": "Smart & portabelt", "text": "Genomtänkt design som följer med överallt." } }
      ]
    }
  ]
}
{% endschema %}

