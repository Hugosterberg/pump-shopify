{% comment %}
  Product cards — showcases up to 3 products selected in the theme editor.
  Uses real Shopify product objects (no hardcoded IDs/prices) and keeps
  commerce-safe add-to-cart via {% form 'product' %}.
{% endcomment %}

<div
  id="ProductCards-{{ section.id }}"
  class="product-cards full-width"
  style="
    --pc-bg: {{ section.settings.background_color }};
    --pc-surface: {{ section.settings.surface_color }};
    --pc-text: {{ section.settings.text_color }};
    --pc-muted: {{ section.settings.muted_text_color }};
    --pc-accent: {{ section.settings.accent_color }};
  "
>
  <div class="product-cards__inner">
    {% if section.settings.heading != blank %}
      <header class="product-cards__header">
        {% if section.settings.eyebrow != blank %}
          <p class="product-cards__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="product-cards__heading">{{ section.settings.heading | replace: 'pump', '<span class="brand-mark">pump</span>' | raw }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="product-cards__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="product-cards__grid" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign product = block.settings.product
          %}
          <li class="product-cards__card" {{ block.shopify_attributes }}>
            {% if product != blank %}
              {% assign variant = product.selected_or_first_available_variant %}
              <a class="product-cards__media" href="{{ product.url }}" aria-label="{{ product.title }}">
                {% if block.settings.badge != blank %}
                  <span class="product-cards__badge">{{ block.settings.badge }}</span>
                {% elsif product.compare_at_price > product.price %}
                  {% assign saving = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                  <span class="product-cards__badge">SPARA {{ saving }}%</span>
                {% endif %}
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 500, 800',
                      sizes: '(min-width: 750px) 33vw, 100vw',
                      alt: product.featured_image.alt | default: product.title
                  }}
                {% else %}
                  <div class="product-cards__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                {% endif %}
              </a>

              <div class="product-cards__body">
                <h3 class="product-cards__title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>

                <div class="product-cards__price">
                  {% if product.compare_at_price > product.price %}
                    <span class="product-cards__price-sale">{{ product.price | money }}</span>
                    <s class="product-cards__price-was">{{ product.compare_at_price | money }}</s>
                  {% else %}
                    <span class="product-cards__price-sale">{{ product.price | money }}</span>
                  {% endif %}
                </div>

                {% if block.settings.description != blank %}
                  <p class="product-cards__desc">{{ block.settings.description }}</p>
                {% endif %}

                <div class="product-cards__actions">
                  {% if variant != blank and product.available %}
                    {% form 'product', product, class: 'product-cards__form ajax-cart-form' %}
                      <input type="hidden" name="id" value="{{ variant.id }}">
                      <button
                        type="submit"
                        name="add"
                        class="product-cards__btn product-cards__btn--primary"
                      >
                        {{ section.settings.buy_label | default: 'Köp nu' }}
                      </button>
                    {% endform %}
                  {% else %}
                    <span class="product-cards__btn product-cards__btn--soldout" aria-disabled="true">
                      Slutsåld
                    </span>
                  {% endif %}
                  <a class="product-cards__btn product-cards__btn--ghost" href="{{ product.url }}">
                    Läs mer
                  </a>
                </div>
              </div>
            {% else %}
              <div class="product-cards__body product-cards__body--empty">
                <div class="product-cards__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                <p class="product-cards__desc">Välj en produkt i temaredigeraren.</p>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.show_view_all %}
      {% liquid
        assign view_all_url = section.settings.view_all_url
        if view_all_url == blank
          assign view_all_url = routes.all_products_collection_url
        endif
      %}
      <div class="product-cards__footer">
        <a class="product-cards__view-all" href="{{ view_all_url }}">
          {{ section.settings.view_all_label | default: 'Visa alla produkter' }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-cards {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pc-bg, #0b1117);
    color: var(--pc-text, #f6f7f2);
  }

  .product-cards__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .product-cards__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .product-cards__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-accent, #2dd4bf);
  }

  .product-cards__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .product-cards__subheading {
    margin: 0;
    color: var(--pc-muted, #9aa8a2);
    line-height: 1.6;
  }

  .product-cards__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .product-cards__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--pc-surface, #14212a) 78%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid color-mix(in srgb, var(--pc-text, #f6f7f2) 12%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--pc-text, #f6f7f2) 10%, transparent);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .product-cards__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--pc-accent, #2dd4bf) 45%, transparent);
  }

  .product-cards__card.is-tilting {
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .product-cards__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .product-cards__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-cards__card:hover .product-cards__media img {
    transform: scale(1.04);
  }

  .product-cards__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--pc-text, #f6f7f2) 18%, transparent);
  }

  .product-cards__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 1;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #06231f;
    background-color: var(--pc-accent, #2dd4bf);
    overflow: hidden;
    box-shadow: 0 4px 14px -4px color-mix(in srgb, var(--pc-accent, #2dd4bf) 90%, #000);
  }

  .product-cards__badge::after {
    content: '';
    position: absolute;
    top: 0;
    left: -120%;
    width: 60%;
    height: 100%;
    background: linear-gradient(100deg, transparent, color-mix(in srgb, #fff 75%, transparent), transparent);
    transform: skewX(-20deg);
    animation: badge-shimmer 3.2s ease-in-out infinite;
  }

  @keyframes badge-shimmer {
    0% { left: -120%; }
    55%, 100% { left: 160%; }
  }

  .product-cards__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    flex: 1;
  }

  .product-cards__body--empty {
    align-items: center;
    text-align: center;
  }

  .product-cards__title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .product-cards__title a {
    color: inherit;
    text-decoration: none;
  }

  .product-cards__price {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .product-cards__price-sale {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--pc-text, #f6f7f2);
  }

  .product-cards__price-was {
    font-size: 0.95rem;
    color: var(--pc-muted, #9aa8a2);
  }

  .product-cards__desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--pc-muted, #9aa8a2);
    flex: 1;
  }

  .product-cards__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 4px;
  }

  .product-cards__form {
    margin: 0;
  }

  .product-cards__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding-inline: 22px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .product-cards__btn--primary {
    position: relative;
    overflow: hidden;
    color: var(--pp-accent-ink, #06231f);
    background: linear-gradient(135deg, var(--pc-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 28%, var(--pc-accent, #2dd4bf)));
    box-shadow: var(--pp-shadow-glow);
    transition: transform var(--pp-transition, 0.2s ease), filter var(--pp-transition, 0.2s ease);
  }

  .product-cards__btn--primary::after {
    content: '';
    position: absolute;
    top: 0;
    left: -70%;
    width: 45%;
    height: 100%;
    background: linear-gradient(100deg, transparent, color-mix(in srgb, #ffffff 55%, transparent), transparent);
    transform: skewX(-20deg);
    pointer-events: none;
    transition: left 0.6s ease;
  }

  .product-cards__card:hover .product-cards__btn--primary::after {
    left: 130%;
  }

  .product-cards__btn--primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.03);
  }

  .product-cards__btn--ghost {
    color: var(--pc-text, #f6f7f2);
    border-color: color-mix(in srgb, var(--pc-text, #f6f7f2) 28%, transparent);
    background-color: transparent;
  }

  .product-cards__btn--soldout {
    color: var(--pc-muted, #9aa8a2);
    background-color: color-mix(in srgb, var(--pc-text, #f6f7f2) 8%, transparent);
    cursor: not-allowed;
  }

  @media screen and (min-width: 750px) {
    .product-cards {
      padding-block: 68px;
    }

    .product-cards__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .product-cards__footer {
    margin-top: 36px;
    text-align: center;
  }

  .product-cards__view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding-inline: 30px;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    color: var(--pc-text, #f6f7f2);
    border: 1px solid color-mix(in srgb, var(--pc-text, #f6f7f2) 28%, transparent);
    transition: border-color 0.18s ease, color 0.18s ease;
  }

  .product-cards__view-all:hover {
    border-color: var(--pc-accent, #2dd4bf);
    color: var(--pc-accent, #2dd4bf);
  }

  @media (prefers-reduced-motion: reduce) {
    .product-cards__card,
    .product-cards__media img,
    .product-cards__btn--primary::after {
      transition: none;
    }

    .product-cards__badge::after {
      animation: none;
      display: none;
    }

    .product-cards__card:hover {
      transform: none;
    }

    .product-cards__card:hover .product-cards__media img {
      transform: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('ProductCards-{{ section.id }}');
    if (!root) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none)').matches) return;

    var cards = root.querySelectorAll('.product-cards__card');
    var MAX = 6;

    cards.forEach(function (card) {
      var raf = null;

      function onMove(e) {
        var rect = card.getBoundingClientRect();
        var px = (e.clientX - rect.left) / rect.width - 0.5;
        var py = (e.clientY - rect.top) / rect.height - 0.5;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(function () {
          card.style.transform =
            'translateY(-4px) perspective(800px) rotateX(' + (-py * MAX).toFixed(2) +
            'deg) rotateY(' + (px * MAX).toFixed(2) + 'deg)';
        });
      }

      function reset() {
        if (raf) cancelAnimationFrame(raf);
        card.classList.remove('is-tilting');
        card.style.transform = '';
      }

      card.addEventListener('mouseenter', function () { card.classList.add('is-tilting'); });
      card.addEventListener('mousemove', onMove);
      card.addEventListener('mouseleave', reset);
    });
  })();
</script>

{% schema %}
{
  "name": "Product cards",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Våra produkter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Välj din pump"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Allt du behöver för att kunna duscha precis där du vill."
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Köp nu"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'view all products' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Visa alla produkter"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link",
      "info": "Defaults to /collections/all if left empty."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0B1117"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "textarea", "id": "description", "label": "Short description" },
        { "type": "text", "id": "badge", "label": "Badge (optional, overrides auto sale badge)" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Product cards",
      "blocks": [
        { "type": "product", "settings": { "description": "Allt du behöver för att duscha var du vill, dusch + vikbar hink." } },
        { "type": "product", "settings": { "description": "Kompakt och kraftfull laddningsbar dusch. Liten i storlek, stor i funktion." } },
        { "type": "product", "settings": { "description": "Vikbar hink som rymmer 20 liter. Perfekt komplement till duschen." } }
      ]
    }
  ]
}
{% endschema %}

