{% comment %}
  Product cards — showcases up to 3 products selected in the theme editor.
  Uses real Shopify product objects (no hardcoded IDs/prices) and keeps
  commerce-safe add-to-cart via {% form 'product' %}.
{% endcomment %}

<div
  id="ProductCards-{{ section.id }}"
  class="product-cards full-width"
  style="
    --pc-bg: {{ section.settings.background_color }};
    --pc-surface: {{ section.settings.surface_color }};
    --pc-text: {{ section.settings.text_color }};
    --pc-muted: {{ section.settings.muted_text_color }};
    --pc-accent: {{ section.settings.accent_color }};
  "
>
  <div class="product-cards__inner">
    {% if section.settings.heading != blank %}
      <header class="product-cards__header">
        {% if section.settings.eyebrow != blank %}
          <p class="product-cards__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="product-cards__heading">{% render 'brand-mark-text', text: section.settings.heading %}</h2>
        {% if section.settings.subheading != blank %}
          <p class="product-cards__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="product-cards__grid" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign product = block.settings.product
            assign is_featured = block.settings.featured
            if is_featured == false and product != blank
              if product.handle contains 'perfect-combo'
                assign is_featured = true
              endif
            endif
          %}
          <li class="product-cards__card{% if is_featured %} product-cards__card--featured{% endif %}" {{ block.shopify_attributes }}>
            {% if product != blank %}
              <a class="product-cards__media" href="{{ product.url }}" aria-label="{{ product.title }}">
                {% if block.settings.badge != blank %}
                  <span class="product-cards__badge">{{ block.settings.badge }}</span>
                {% elsif product.compare_at_price > product.price %}
                  {% assign saving = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                  <span class="product-cards__badge">SPARA {{ saving }}%</span>
                {% endif %}
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 500, 800',
                      sizes: '(min-width: 750px) 33vw, 100vw',
                      alt: product.featured_image.alt | default: product.title
                  }}
                {% else %}
                  <div class="product-cards__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                {% endif %}
              </a>

              <div class="product-cards__body">
                <h3 class="product-cards__title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>

                <div class="product-cards__price">
                  {% render 'pp-product-price', product: product %}
                </div>

                {% if block.settings.description != blank %}
                  <p class="product-cards__desc">{{ block.settings.description }}</p>
                {% endif %}

                {% render 'pp-product-actions',
                  product: product,
                  buy_label: section.settings.buy_label,
                  form_class: 'product-cards__form'
                %}
              </div>
            {% else %}
              <div class="product-cards__body product-cards__body--empty">
                <div class="product-cards__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                <p class="product-cards__desc">Välj en produkt i temaredigeraren.</p>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.show_view_all %}
      {% liquid
        assign view_all_url = section.settings.view_all_url
        if view_all_url == blank
          assign view_all_url = routes.all_products_collection_url
        endif
      %}
      <div class="product-cards__closing">
        <a class="product-cards__view-all" href="{{ view_all_url }}">
          {{ section.settings.view_all_label | default: 'Visa alla produkter' }}
          <span class="product-cards__view-all-icon" aria-hidden="true">→</span>
        </a>
        {% render 'trust-near-atc', class_prefix: 'product-cards__trust', show_payment_icons: false, compact: true %}
      </div>
    {% else %}
      <div class="product-cards__closing product-cards__closing--trust-only">
        {% render 'trust-near-atc', class_prefix: 'product-cards__trust', show_payment_icons: false, compact: true %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-cards {
    position: relative;
    padding-block: var(--pp-section-py, 52px);
    padding-inline: var(--page-margin, 20px);
    background-color: var(--pc-bg, #0b1117);
    color: var(--pc-text, #f6f7f2);
    overflow: hidden;
    --pp-accent: var(--pc-accent, #2dd4bf);
    --pp-text: var(--pc-text, #f6f7f2);
    --pp-muted: var(--pc-muted, #9aa8a2);
  }

  .product-cards::before {
    content: '';
    position: absolute;
    top: 10%;
    left: 50%;
    width: min(900px, 90vw);
    height: 400px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--pc-accent, #2dd4bf) 14%, transparent), transparent 68%);
    pointer-events: none;
  }

  .product-cards__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .product-cards__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .product-cards__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pc-accent, #2dd4bf);
  }

  .product-cards__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .product-cards__subheading {
    margin: 0;
    color: var(--pc-muted, #9aa8a2);
    line-height: 1.6;
  }

  .product-cards__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .product-cards__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    overflow: hidden;
    background: var(--pp-gradient-surface, linear-gradient(165deg, #1d2b35 0%, #14212a 100%));
    border: 1px solid color-mix(in srgb, var(--pc-text, #f6f7f2) 10%, transparent);
    box-shadow: var(--pp-shadow-soft);
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.22s ease, box-shadow 0.22s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .product-cards__card--featured {
    border-color: color-mix(in srgb, var(--pc-accent, #2dd4bf) 45%, transparent);
    box-shadow:
      var(--pp-shadow-soft),
      0 0 0 1px color-mix(in srgb, var(--pc-accent, #2dd4bf) 20%, transparent),
      0 20px 50px -28px color-mix(in srgb, var(--pc-accent, #2dd4bf) 45%, #000);
  }

  .product-cards__card--featured::before {
    content: 'Mest populär';
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pp-accent-ink, #071014);
    background: var(--pp-gradient-accent, linear-gradient(135deg, #2dd4bf, #4cc9f0));
    box-shadow: 0 6px 16px -8px color-mix(in srgb, var(--pc-accent, #2dd4bf) 80%, #000);
  }

  .product-cards__card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--pc-accent, #2dd4bf) 45%, transparent);
    box-shadow: var(--pp-shadow-card);
  }

  .product-cards__card.is-tilting {
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .product-cards__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .product-cards__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-cards__card:hover .product-cards__media img {
    transform: scale(1.04);
  }

  .product-cards__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--pc-text, #f6f7f2) 18%, transparent);
  }

  .product-cards__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 1;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #06231f;
    background-color: var(--pc-accent, #2dd4bf);
    overflow: hidden;
    box-shadow: 0 4px 14px -4px color-mix(in srgb, var(--pc-accent, #2dd4bf) 90%, #000);
  }

  .product-cards__badge::after {
    content: '';
    position: absolute;
    top: 0;
    left: -120%;
    width: 60%;
    height: 100%;
    background: linear-gradient(100deg, transparent, color-mix(in srgb, #fff 75%, transparent), transparent);
    transform: skewX(-20deg);
    animation: badge-shimmer 3.2s ease-in-out infinite;
  }

  @keyframes badge-shimmer {
    0% { left: -120%; }
    55%, 100% { left: 160%; }
  }

  .product-cards__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    flex: 1;
  }

  .product-cards__body--empty {
    align-items: center;
    text-align: center;
  }

  .product-cards__title {
    margin: 0;
    font-size: clamp(1.05rem, 2.6vw, 1.2rem);
    font-weight: 600;
    line-height: 1.3;
    text-wrap: balance;
  }

  .product-cards__title a {
    color: inherit;
    text-decoration: none;
  }

  .product-cards__price {
    margin: 0;
  }

  .product-cards__desc {
    margin: 0;
    font-size: clamp(0.84rem, 2.2vw, 0.9rem);
    line-height: 1.55;
    color: var(--pc-muted, #9aa8a2);
    flex: 1;
    text-wrap: pretty;
  }

  @media screen and (min-width: 750px) {
    .product-cards {
      padding-block: 68px;
    }

    .product-cards__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .product-cards__closing {
    margin-top: 40px;
    padding: clamp(24px, 4vw, 32px);
    border-radius: var(--pp-radius-lg, 20px);
    text-align: center;
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--pc-surface, #14212a) 88%, #fff 12%) 0%,
      var(--pc-surface, #14212a) 100%
    );
    border: 1px solid color-mix(in srgb, var(--pc-text, #f6f7f2) 10%, transparent);
    box-shadow: var(--pp-shadow-soft);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .product-cards__closing--trust-only {
    padding-block: 20px;
  }

  .product-cards__view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 52px;
    padding-inline: 32px;
    border-radius: 999px;
    font-weight: 600;
    font-size: clamp(0.92rem, 2.4vw, 1rem);
    text-decoration: none;
    color: var(--pc-text, #f6f7f2);
    border: 1px solid color-mix(in srgb, var(--pc-text, #f6f7f2) 22%, transparent);
    background: color-mix(in srgb, var(--pc-text, #f6f7f2) 4%, transparent);
    transition:
      border-color 0.18s ease,
      color 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .product-cards__view-all-icon {
    display: inline-flex;
    transition: transform 0.18s ease;
  }

  .product-cards__view-all:hover {
    border-color: color-mix(in srgb, var(--pc-accent, #2dd4bf) 55%, transparent);
    color: var(--pc-accent, #2dd4bf);
    transform: translateY(-1px);
    box-shadow: 0 12px 32px -20px color-mix(in srgb, var(--pc-accent, #2dd4bf) 70%, #000);
  }

  .product-cards__view-all:hover .product-cards__view-all-icon {
    transform: translateX(3px);
  }

  .product-cards__closing .pp-trust-atc--compact {
    width: 100%;
    max-width: 52rem;
    gap: 10px;
  }

  @media screen and (min-width: 640px) {
    .product-cards__closing .pp-trust-atc--compact {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .product-cards__closing .pp-trust-atc__pill {
      justify-content: center;
      padding-inline: 12px;
      text-align: center;
      flex-direction: column;
      gap: 8px;
      min-height: 88px;
      border-radius: 16px;
    }

    .product-cards__closing .pp-trust-atc__pill-icon {
      width: 36px;
      height: 36px;
    }

    .product-cards__closing .pp-trust-atc__pill-text {
      text-align: center;
      font-size: 0.78rem;
      line-height: 1.3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-cards__card,
    .product-cards__media img {
      transition: none;
    }

    .product-cards__badge::after {
      animation: none;
      display: none;
    }

    .product-cards__card:hover {
      transform: none;
    }

    .product-cards__card:hover .product-cards__media img {
      transform: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('ProductCards-{{ section.id }}');
    if (!root) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none)').matches) return;

    var cards = root.querySelectorAll('.product-cards__card');
    var MAX = 6;

    cards.forEach(function (card) {
      var raf = null;

      function onMove(e) {
        var rect = card.getBoundingClientRect();
        var px = (e.clientX - rect.left) / rect.width - 0.5;
        var py = (e.clientY - rect.top) / rect.height - 0.5;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(function () {
          card.style.transform =
            'translateY(-4px) perspective(800px) rotateX(' + (-py * MAX).toFixed(2) +
            'deg) rotateY(' + (px * MAX).toFixed(2) + 'deg)';
        });
      }

      function reset() {
        if (raf) cancelAnimationFrame(raf);
        card.classList.remove('is-tilting');
        card.style.transform = '';
      }

      card.addEventListener('mouseenter', function () { card.classList.add('is-tilting'); });
      card.addEventListener('mousemove', onMove);
      card.addEventListener('mouseleave', reset);
    });
  })();
</script>

{% schema %}
{
  "name": "Product cards",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Våra produkter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Välj din pump"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Allt du behöver för att kunna duscha precis där du vill."
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'view all products' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Visa alla produkter"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link",
      "info": "Defaults to /collections/all if left empty."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0B1117"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "textarea", "id": "description", "label": "Short description" },
        { "type": "text", "id": "badge", "label": "Badge (optional, overrides auto sale badge)" },
        { "type": "checkbox", "id": "featured", "label": "Highlight as featured", "default": false, "info": "Auto-enabled for Perfect Combo if unchecked." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Product cards",
      "blocks": [
        { "type": "product", "settings": { "description": "Allt du behöver för att duscha var du vill, dusch + vikbar hink." } },
        { "type": "product", "settings": { "description": "Kompakt och kraftfull laddningsbar dusch. Liten i storlek, stor i funktion." } },
        { "type": "product", "settings": { "description": "Vikbar hink som rymmer 20 liter. Perfekt komplement till duschen." } }
      ]
    }
  ]
}
{% endschema %}

