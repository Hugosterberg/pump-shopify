{% liquid
  assign source_product = product
  if source_product == blank
    assign source_product = section.settings.product
  endif

  assign related_collection = source_product.collections.first
  assign related_count = 0
%}

{% if related_collection != blank and related_collection.products.size > 1 %}
  <div
    class="related-products full-width"
    style="
      --rp-bg: {{ section.settings.background_color }};
      --rp-surface: {{ section.settings.surface_color }};
      --rp-text: {{ section.settings.text_color }};
      --rp-muted: {{ section.settings.muted_text_color }};
      --rp-accent: {{ section.settings.accent_color }};
    "
  >
    <div class="related-products__inner">
      {% if section.settings.heading != blank %}
        <h2 class="related-products__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <ul class="related-products__grid" role="list">
        {% for related in related_collection.products %}
          {% if related.id != source_product.id and related_count < section.settings.max_products %}
            {% assign related_count = related_count | plus: 1 %}
            <li class="related-products__card">
              <a class="related-products__link" href="{{ related.url }}">
                <div class="related-products__media">
                  {% if related.featured_image != blank %}
                    {{
                      related.featured_image
                      | image_url: width: 600
                      | image_tag: loading: 'lazy', widths: '300, 600', sizes: '(min-width: 750px) 25vw, 50vw', alt: related.title
                    }}
                  {% endif %}
                </div>
                <div class="related-products__info">
                  <h3 class="related-products__name">{{ related.title }}</h3>
                  <p class="related-products__price">{{ related.price | money }}</p>
                </div>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .related-products {
    padding-block: 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--rp-bg, #101820);
    color: var(--rp-text, #f6f7f2);
  }

  .related-products__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .related-products__heading {
    margin: 0 0 32px;
    text-align: center;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    letter-spacing: -0.02em;
  }

  .related-products__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .related-products__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--rp-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--rp-text, #f6f7f2) 8%, transparent);
    transition: transform 0.15s ease;
  }

  .related-products__link:hover {
    transform: translateY(-3px);
  }

  .related-products__media {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .related-products__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-products__info {
    padding: 14px;
  }

  .related-products__name {
    margin: 0 0 4px;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .related-products__price {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--rp-accent, #2dd4bf);
  }

  @media screen and (min-width: 750px) {
    .related-products {
      padding-block: 96px;
    }

    .related-products__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-products__link {
      transition: none;
    }

    .related-products__link:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Only needed off the product page. On product pages the current product is used automatically."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Du kanske också gillar"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
