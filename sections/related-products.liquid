{% liquid
  assign source_product = product
  if source_product == blank
    assign source_product = section.settings.product
  endif

  assign related_collection = section.settings.collection
  if related_collection == blank and source_product != blank
    for coll in source_product.collections
      if coll.handle != 'all' and coll.handle != 'frontpage' and coll.products.size > 1
        assign related_collection = coll
        break
      endif
    endfor
  endif

  if related_collection == blank or related_collection.products.size <= 1
    assign related_collection = collections.all
  endif

  assign related_count = 0
%}

{% if related_collection != blank and related_collection.products.size > 1 %}
  <div
    class="related-products full-width"
    style="
      --rp-bg: {{ section.settings.background_color }};
      --rp-surface: {{ section.settings.surface_color }};
      --rp-text: {{ section.settings.text_color }};
      --rp-muted: {{ section.settings.muted_text_color }};
      --rp-accent: {{ section.settings.accent_color }};
    "
  >
    <div class="related-products__inner">
      {% if section.settings.heading != blank %}
        <header class="related-products__header">
          <h2 class="related-products__heading">{{ section.settings.heading }}</h2>
        </header>
      {% endif %}

      <ul class="related-products__grid" role="list">
        {% for related in related_collection.products %}
          {% if related.id != source_product.id and related_count < section.settings.max_products %}
            {% assign related_count = related_count | plus: 1 %}
            <li class="related-products__card pp-product-card">
              <a class="pp-product-card__media related-products__media" href="{{ related.url }}" aria-label="{{ related.title }}">
                {% if related.compare_at_price > related.price %}
                  {% assign saving = related.compare_at_price | minus: related.price | times: 100.0 | divided_by: related.compare_at_price | round %}
                  <span class="pp-product-card__badge">Spara {{ saving }}%</span>
                {% endif %}
                {% unless related.available %}
                  <span class="pp-product-card__badge pp-product-card__badge--soldout">Slutsåld</span>
                {% endunless %}
                {% if related.featured_image != blank %}
                  {{
                    related.featured_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 600, 800',
                      sizes: '(min-width: 750px) 25vw, 50vw',
                      alt: related.featured_image.alt | default: related.title
                  }}
                {% else %}
                  <div class="related-products__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                {% endif %}
              </a>

              <div class="pp-product-card__body related-products__body">
                <h3 class="pp-product-card__title">
                  <a href="{{ related.url }}">{{ related.title }}</a>
                </h3>

                {% render 'pp-product-price', product: related %}

                {% render 'pp-product-actions',
                  product: related,
                  buy_label: section.settings.buy_label,
                  form_class: 'related-products__form'
                %}
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .related-products {
    padding-block: 56px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--rp-bg, #101820);
    color: var(--rp-text, #f6f7f2);
  }

  .related-products__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .related-products__header {
    text-align: center;
    margin-bottom: 28px;
  }

  .related-products__heading {
    margin: 0;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    letter-spacing: -0.02em;
  }

  .related-products__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .related-products__card {
    --pp-text: var(--rp-text, #f6f7f2);
    --pp-muted: var(--rp-muted, #9aa8a2);
    --pp-accent: var(--rp-accent, #2dd4bf);
    background: var(--rp-surface, #14212a);
  }

  .related-products__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--rp-text, #f6f7f2) 18%, transparent);
  }

  @media screen and (min-width: 750px) {
    .related-products {
      padding-block: 72px;
    }

    .related-products__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media screen and (min-width: 990px) {
    .related-products__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Only needed off the product page. On product pages the current product is used automatically."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Optional. Defaults to the product's primary collection, then All products."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Du kanske också gillar"
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
