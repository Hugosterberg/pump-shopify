{%- liquid
  assign rv_buy_label = 'products.add_to_cart' | t
  if section.settings.buy_label != blank
    assign rv_buy_label = section.settings.buy_label
  endif
-%}
<div
  class="recently-viewed full-width"
  data-recently-viewed
  data-max="{{ section.settings.max_products }}"
  data-heading="{{ section.settings.heading | escape }}"
  data-empty-text="{{ section.settings.empty_text | escape }}"
  data-buy-label="{{ rv_buy_label | escape }}"
  data-sold-out-label="{{ 'products.sold_out' | t | escape }}"
  data-choose-variant-label="{{ 'products.choose_variant' | t | escape }}"
  data-learn-more-label="{{ 'products.learn_more' | t | escape }}"
  data-save-percent-label="{{ 'products.save_percent' | t: percent: '__PCT__' | escape }}"
  style="
    --rv-bg: {{ section.settings.background_color }};
    --rv-surface: {{ section.settings.surface_color }};
    --rv-text: {{ section.settings.text_color }};
    --rv-muted: {{ section.settings.muted_text_color }};
    --rv-accent: {{ section.settings.accent_color }};
  "
  hidden
>
  <div class="recently-viewed__inner">
    <h2 class="recently-viewed__heading">{{ section.settings.heading }}</h2>
    <ul class="recently-viewed__grid" role="list" data-recently-viewed-grid></ul>
    <p class="recently-viewed__empty" data-recently-viewed-empty hidden>{{ section.settings.empty_text }}</p>
  </div>
</div>

{% stylesheet %}
  .recently-viewed {
    padding-block: 56px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--rv-bg, #071014);
    color: var(--rv-text, #f6f7f2);
  }

  .recently-viewed__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .recently-viewed__heading {
    margin: 0 0 28px;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    letter-spacing: -0.02em;
  }

  .recently-viewed__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .recently-viewed__card {
    --pp-text: var(--rv-text, #f6f7f2);
    --pp-muted: var(--rv-muted, #9aa8a2);
    --pp-accent: var(--rv-accent, #2dd4bf);
    background: var(--rv-surface, #14212a);
  }

  .recently-viewed__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--rv-text, #f6f7f2) 18%, transparent);
  }

  .recently-viewed__empty {
    margin: 0;
    font-size: 0.92rem;
    color: var(--rv-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .recently-viewed__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const STORAGE_KEY = 'pump_recently_viewed';
    const section = document.querySelector('[data-recently-viewed]');
    if (!section) return;

    const grid = section.querySelector('[data-recently-viewed-grid]');
    const emptyEl = section.querySelector('[data-recently-viewed-empty]');
    const max = Number(section.dataset.max || 4);
    const currentPath = window.location.pathname;

    let handles = [];
    try {
      handles = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch (e) {
      handles = [];
    }

    handles = handles.filter(function (handle) {
      return typeof handle === 'string' && handle.length > 0;
    });

    if (currentPath.indexOf('/products/') !== -1) {
      const parts = currentPath.split('/products/');
      const currentHandle = parts[1] ? parts[1].split('/')[0].split('?')[0] : '';
      if (currentHandle) {
        handles = handles.filter(function (h) { return h !== currentHandle; });
      }
    }

    if (!handles.length) {
      section.hidden = true;
      return;
    }

    const toFetch = handles.slice(0, max);

    const buyLabel = section.dataset.buyLabel || {{ 'products.add_to_cart' | t | json }};
    const soldOutLabel = section.dataset.soldOutLabel || {{ 'products.sold_out' | t | json }};
    const chooseVariantLabel = section.dataset.chooseVariantLabel || {{ 'products.choose_variant' | t | json }};
    const learnMoreLabel = section.dataset.learnMoreLabel || {{ 'products.learn_more' | t | json }};
    const savePercentLabel = section.dataset.savePercentLabel || {{ 'products.save_percent' | t: percent: '__PCT__' | json }};

    function formatMoney(cents) {
      if (window.PumpTheme && window.PumpTheme.moneyFormat && typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
        return Shopify.formatMoney(cents, window.PumpTheme.moneyFormat);
      }
      return (cents / 100).toLocaleString('sv-SE') + ' kr';
    }

    function renderPrice(product) {
      const current = formatMoney(product.price);
      if (product.compare_at_price && product.compare_at_price > product.price) {
        const saving = Math.round(((product.compare_at_price - product.price) / product.compare_at_price) * 100);
        return (
          '<div class="pp-price">' +
          '<span class="pp-price__meta">' +
          '<s class="pp-price__compare">' + formatMoney(product.compare_at_price) + '</s>' +
          '<span class="pp-price__save">' + savePercentLabel.replace('__PCT__', String(saving)) + '</span>' +
          '</span>' +
          '<span class="pp-price__current">' + current + '</span>' +
          '</div>'
        );
      }
      return '<div class="pp-price"><span class="pp-price__current">' + current + '</span></div>';
    }

    function renderActions(product) {
      const variants = product.variants || [];
      if (!product.available) {
        return '<div class="pp-product-actions"><span class="pp-btn-primary pp-btn--full" aria-disabled="true">' + soldOutLabel + '</span></div>';
      }
      if (variants.length > 1) {
        return (
          '<div class="pp-product-actions">' +
          '<a class="pp-btn-primary pp-btn--full" href="' + product.url + '">' + chooseVariantLabel + '</a>' +
          '<a class="pp-btn-secondary pp-btn--full" href="' + product.url + '">' + learnMoreLabel + '</a>' +
          '</div>'
        );
      }
      const variant = variants[0];
      return (
        '<div class="pp-product-actions">' +
        '<form action="/cart/add" method="post" class="ajax-cart-form pp-product-actions__form recently-viewed__form">' +
        '<input type="hidden" name="id" value="' + variant.id + '">' +
        '<button type="submit" name="add" class="pp-btn-primary pp-btn--full">' + buyLabel + '</button>' +
        '</form>' +
        '<a class="pp-btn-secondary pp-btn--full" href="' + product.url + '">' + learnMoreLabel + '</a>' +
        '</div>'
      );
    }

    Promise.all(
      toFetch.map(function (handle) {
        return fetch('/products/' + encodeURIComponent(handle) + '.js')
          .then(function (res) { return res.ok ? res.json() : null; })
          .catch(function () { return null; });
      })
    ).then(function (products) {
      const valid = products.filter(Boolean);
      if (!valid.length) {
        section.hidden = true;
        return;
      }

      section.hidden = false;
      grid.innerHTML = valid
        .map(function (product) {
          const img = product.featured_image || product.images[0];
          const imgHtml = img
            ? '<img src="' + img + '" alt="' + (product.title || '').replace(/"/g, '&quot;') + '" loading="lazy" width="400" height="400">'
            : '<div class="recently-viewed__placeholder">' + (product.title || '') + '</div>';
          return (
            '<li class="recently-viewed__card pp-product-card">' +
            '<a class="pp-product-card__media recently-viewed__media" href="' + product.url + '" aria-label="' + (product.title || '').replace(/"/g, '&quot;') + '">' +
            imgHtml +
            '</a>' +
            '<div class="pp-product-card__body recently-viewed__body">' +
            '<h3 class="pp-product-card__title"><a href="' + product.url + '">' + product.title + '</a></h3>' +
            renderPrice(product) +
            renderActions(product) +
            '</div></li>'
          );
        })
        .join('');
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Recently viewed",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nyligen visade"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty state",
      "default": "Du har inte tittat på några produkter än."
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
