{% javascript %}
  (function () {
    const root = document.querySelector('[data-main-product]');
    if (!root) return;

    const sectionId = root.dataset.sectionId;
    const mediaJson = document.getElementById('ProductMedia-' + sectionId);
    const variantsJson = document.getElementById('ProductVariants-' + sectionId);
    if (!mediaJson || !variantsJson) return;

    const mediaItems = JSON.parse(mediaJson.textContent);
    const variants = JSON.parse(variantsJson.textContent);
    const mediaWrap = root.querySelector('[data-main-product-media]');
    const variantSelect = root.querySelector('[data-variant-select]');
    const hiddenVariantId = root.querySelector('[data-variant-id]');
    const priceCurrent = root.querySelector('[data-price-current]');
    const priceCompare = root.querySelector('[data-price-compare]');
    const saveBadge = root.querySelector('[data-save-badge]');
    const submitBtn = root.querySelector('[data-main-product-submit]');
    const thumbButtons = root.querySelectorAll('[data-media-index]');

    const moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return (cents / 100).toFixed(0) + ' kr';
    }

    function findVariant(id) {
      return variants.find((variant) => String(variant.id) === String(id));
    }

    function findMediaIndex(mediaId) {
      if (!mediaId) return 0;
      const index = mediaItems.findIndex((item) => String(item.id) === String(mediaId));
      return index >= 0 ? index : 0;
    }

    function setActiveThumb(index) {
      thumbButtons.forEach((btn) => {
        const active = Number(btn.dataset.mediaIndex) === index;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    const zoomIcon =
      '<span class="main-product__media-zoom" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>';

    function mediaMarkup(media) {
      const alt = (media.alt || '').replace(/"/g, '&quot;');
      if (media.media_type === 'video' && media.sources && media.sources.length) {
        const source = media.sources[0];
        return (
          '<video class="main-product__image" controls playsinline preload="metadata" poster="' +
          media.src +
          '" data-media-id="' +
          media.id +
          '"><source src="' +
          source.url +
          '" type="' +
          (source.mime_type || 'video/mp4') +
          '"></video>' +
          zoomIcon
        );
      }
      return (
        '<img class="main-product__image" src="' +
        media.src +
        '" alt="' +
        alt +
        '" loading="eager" data-media-id="' +
        media.id +
        '">' +
        zoomIcon
      );
    }

    function showMedia(index) {
      const media = mediaItems[index];
      if (!media || !mediaWrap) return;

      setActiveThumb(index);

      const openBtn = mediaWrap.querySelector('[data-media-modal-open]');
      if (!openBtn) return;

      openBtn.innerHTML = mediaMarkup(media);
    }

    function dispatchVariantChange(variant) {
      document.dispatchEvent(
        new CustomEvent('pump:variant-change', {
          detail: {
            variantId: variant.id,
            available: variant.available,
            price: variant.price,
            formattedPrice: formatMoney(variant.price),
          },
        })
      );
    }

    function updateVariant(id) {
      const variant = findVariant(id);
      if (!variant) return;

      if (priceCurrent) priceCurrent.textContent = formatMoney(variant.price);

      if (priceCompare) {
        if (variant.compare_at_price > variant.price) {
          priceCompare.hidden = false;
          priceCompare.textContent = formatMoney(variant.compare_at_price);
          if (saveBadge) {
            const pct = Math.round(((variant.compare_at_price - variant.price) * 100) / variant.compare_at_price);
            saveBadge.hidden = false;
            saveBadge.textContent = 'Spara ' + pct + '%';
          }
        } else {
          priceCompare.hidden = true;
          if (saveBadge) saveBadge.hidden = true;
        }
      }

      if (submitBtn) {
        submitBtn.disabled = !variant.available;
        submitBtn.textContent = variant.available ? submitBtn.dataset.availableLabel || 'Lägg i varukorg' : 'Slutsåld';
      }

      if (variant.featured_media_id) {
        showMedia(findMediaIndex(variant.featured_media_id));
      }

      dispatchVariantChange(variant);
    }

    if (submitBtn && !submitBtn.dataset.availableLabel) {
      submitBtn.dataset.availableLabel = submitBtn.textContent.trim();
    }

    thumbButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        showMedia(Number(btn.dataset.mediaIndex));
      });
    });

    if (variantSelect) {
      variantSelect.addEventListener('change', () => updateVariant(variantSelect.value));
      updateVariant(variantSelect.value);
    } else if (hiddenVariantId) {
      updateVariant(hiddenVariantId.value);
    }

    const modal = document.querySelector('[data-media-modal]');
    const modalContent = document.querySelector('[data-media-modal-content]');
    const modalOpenBtn = root.querySelector('[data-media-modal-open]');
    let modalIndex = 0;

    function renderModalMedia(index) {
      const media = mediaItems[index];
      if (!media || !modalContent) return;
      modalIndex = index;
      if (media.media_type === 'video' && media.sources && media.sources.length) {
        const source = media.sources[0];
        modalContent.innerHTML =
          '<video controls autoplay playsinline poster="' +
          media.src +
          '"><source src="' +
          source.url +
          '" type="' +
          (source.mime_type || 'video/mp4') +
          '"></video>';
      } else {
        modalContent.innerHTML =
          '<img src="' + media.src + '" alt="' + (media.alt || '').replace(/"/g, '&quot;') + '">';
      }
    }

    function openModal(index) {
      if (!modal) return;
      renderModalMedia(typeof index === 'number' ? index : findMediaIndex(mediaWrap?.querySelector('[data-media-id]')?.dataset.mediaId));
      if (typeof modal.showModal === 'function') {
        modal.showModal();
      } else {
        modal.setAttribute('open', '');
      }
      modal.querySelector('[data-media-modal-close]')?.focus();
    }

    function closeModal() {
      if (!modal) return;
      if (typeof modal.close === 'function') {
        modal.close();
      } else {
        modal.removeAttribute('open');
      }
    }

    modalOpenBtn?.addEventListener('click', () => {
      const activeThumb = root.querySelector('.main-product__thumb-btn.is-active');
      openModal(activeThumb ? Number(activeThumb.dataset.mediaIndex) : 0);
    });

    document.querySelector('[data-media-modal-close]')?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });

    document.querySelector('[data-media-modal-prev]')?.addEventListener('click', () => {
      const next = (modalIndex - 1 + mediaItems.length) % mediaItems.length;
      renderModalMedia(next);
      showMedia(next);
    });

    document.querySelector('[data-media-modal-next]')?.addEventListener('click', () => {
      const next = (modalIndex + 1) % mediaItems.length;
      renderModalMedia(next);
      showMedia(next);
    });

    modal?.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeModal();
        modalOpenBtn?.focus();
      }
    });
  })();
{% endjavascript %}

