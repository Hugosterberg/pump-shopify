{% comment %}
  Product page section — gallery, variant picker, trust row and payment button.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media
-%}

<div
  id="main-product"
  class="main-product full-width"
  data-main-product
  data-product-handle="{{ product.handle }}"
  data-section-id="{{ section.id }}"
  style="
    --mp-bg: {{ section.settings.background_color }};
    --mp-surface: {{ section.settings.surface_color }};
    --mp-text: {{ section.settings.text_color }};
    --mp-muted: {{ section.settings.muted_text_color }};
    --mp-accent: {{ section.settings.accent_color }};
    --mp-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  <div class="main-product__inner">
    {% render 'breadcrumbs' %}

    <div class="main-product__gallery">
      {% if product.media.size > 0 %}
        <div class="main-product__media-main" id="MainProductMedia-{{ section.id }}" data-main-product-media>
          <button
            type="button"
            class="main-product__media-open"
            data-media-modal-open
            aria-label="{% if featured_media.media_type == 'video' %}Spela upp media{% else %}Öppna bild i modal{% endif %}"
          >
            {% if featured_media != blank %}
              {% if featured_media.media_type == 'image' %}
                {{
                  featured_media
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'eager',
                    fetchpriority: 'high',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    widths: '500, 700, 900, 1200, 1400',
                    class: 'main-product__image',
                    alt: featured_media.alt | default: product.title,
                    data-media-id: featured_media.id
                }}
              {% else %}
                {{ featured_media | media_tag: class: 'main-product__image', data-media-id: featured_media.id }}
              {% endif %}
            {% endif %}
            <span class="main-product__media-zoom" aria-hidden="true">{% render 'icon', name: 'search', size: 18 %}</span>
          </button>
        </div>
        {% if product.media.size > 1 %}
          <ul class="main-product__thumbs" role="list" data-main-product-thumbs>
            {% for media in product.media limit: 8 %}
              {%- liquid
                assign thumb_active = false
                if featured_media != blank and media.id == featured_media.id
                  assign thumb_active = true
                elsif featured_media == blank and forloop.first
                  assign thumb_active = true
                endif
              -%}
              <li class="main-product__thumb">
                <button
                  type="button"
                  class="main-product__thumb-btn{% if thumb_active %} is-active{% endif %}"
                  data-media-index="{{ forloop.index0 }}"
                  data-media-id="{{ media.id }}"
                  aria-label="{{ media.alt | default: product.title | escape }}"
                  aria-pressed="{% if thumb_active %}true{% else %}false{% endif %}"
                >
                  {% if media.media_type == 'image' %}
                    {{
                      media
                      | image_url: width: 200
                      | image_tag: loading: 'lazy', widths: '100, 200', sizes: '80px', alt: media.alt
                    }}
                  {% else %}
                    {{
                      media.preview_image
                      | image_url: width: 200
                      | image_tag: loading: 'lazy', widths: '100, 200', sizes: '80px', alt: media.alt
                    }}
                  {% endif %}
                </button>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      {% else %}
        <div class="main-product__placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="main-product__info">
      {% if section.blocks.size > 0 %}
        <div class="main-product__reviews-slot">
          {% for block in section.blocks %}
            {% if block.type == '@app' %}
              <div {{ block.shopify_attributes }}>{% render block %}</div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      <h1 class="main-product__title">{{ product.title }}</h1>

      <div class="main-product__actions">
        <button
          type="button"
          class="main-product__action-btn"
          data-wishlist-toggle="{{ product.handle }}"
          aria-pressed="false"
        >
          {% render 'icon', name: 'sparkles', size: 14 %}
          Önskelista
        </button>
        <button
          type="button"
          class="main-product__action-btn"
          data-compare-toggle="{{ product.handle }}"
          aria-pressed="false"
        >
          {% render 'icon', name: 'sliders', size: 14 %}
          Jämför
        </button>
      </div>

      <div class="main-product__badges">
        {% if current_variant.available %}
          <span class="main-product__badge main-product__badge--stock">
            {% render 'icon', name: 'check', size: 12 %}
            I lager — skickas snabbt
          </span>
        {% endif %}
        <span class="main-product__badge main-product__badge--delivery">
          {% render 'icon', name: 'truck', size: 12 %}
          Leverans 2–5 dagar
        </span>
        {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 8 %}
          <span class="main-product__badge main-product__badge--urgency">
            {% render 'icon', name: 'bolt', size: 12 %}
            Bara {{ current_variant.inventory_quantity }} kvar
          </span>
        {% endif %}
      </div>

      <div class="main-product__price" data-main-product-price>
        {% if current_variant.compare_at_price > current_variant.price %}
          <s class="main-product__price-compare" data-price-compare>{{ current_variant.compare_at_price | money }}</s>
          {% assign saving = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round %}
          <span class="main-product__save-badge" data-save-badge>Spara {{ saving }}%</span>
        {% else %}
          <s class="main-product__price-compare" data-price-compare hidden></s>
          <span class="main-product__save-badge" data-save-badge hidden></span>
        {% endif %}
        <span class="main-product__price-current" data-price-current>{{ current_variant.price | money }}</span>
      </div>

      {% render 'free-shipping-bar', class_prefix: 'main-product__shipping' %}

      {% if product.description != blank %}
        <div class="main-product__description">{{ product.description }}</div>
      {% endif %}

      <div class="main-product__form-wrap">
        {% capture product_form_id %}MainProductForm-{{ section.id }}{% endcapture %}
        {% form 'product', product, id: product_form_id, class: 'main-product__form ajax-cart-form' %}
          {% if product.variants.size > 1 %}
            <label class="main-product__label" for="MainProduct-Variant-{{ section.id }}">Variant</label>
            <select
              id="MainProduct-Variant-{{ section.id }}"
              class="main-product__select"
              name="id"
              data-variant-select
            >
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  {% if variant == current_variant %}
                    selected="selected"
                  {% endif %}
                  {% unless variant.available %}
                    disabled
                  {% endunless %}
                >
                  {{ variant.title }}{% unless variant.available %} — slutsåld{% endunless %}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          {% endif %}

          <div class="main-product__qty-row">
            <label class="main-product__label" for="MainProduct-Qty-{{ section.id }}">Antal</label>
            <input
              id="MainProduct-Qty-{{ section.id }}"
              class="main-product__qty"
              type="number"
              name="quantity"
              min="1"
              value="1"
            >
          </div>

          <button
            class="main-product__submit"
            type="submit"
            data-main-product-submit
            {% unless current_variant.available %}
              disabled
            {% endunless %}
          >
            {% if current_variant.available %}
              {{ section.settings.button_label | default: 'Lägg i varukorg' }}
            {% else %}
              Slutsåld
            {% endif %}
          </button>

          {{ form | payment_button }}
        {% endform %}

        <div class="main-product__buy-trust">
          {% render 'trust-near-atc', class_prefix: 'main-product__trust-atc', show_payment_icons: false %}
          {% render 'payment-icons', class_prefix: 'main-product__payment', label: 'Betala enkelt med' %}
        </div>

        {% render 'product-upsell', product: product %}

        <div class="main-product__buy-legal">
          {% render 'legal-links', class_prefix: 'main-product__legal', compact: true %}
        </div>
      </div>
    </div>
  </div>
</div>

<dialog class="main-product__modal" data-media-modal aria-label="Produktmedia">
  <div class="main-product__modal-inner">
    <button type="button" class="main-product__modal-close" data-media-modal-close aria-label="Stäng">
      {% render 'icon', name: 'x', size: 22 %}
    </button>
    <div class="main-product__modal-content" data-media-modal-content></div>
    {% if product.media.size > 1 %}
      <div class="main-product__modal-nav">
        <button type="button" class="main-product__modal-prev" data-media-modal-prev aria-label="Föregående bild">‹</button>
        <button type="button" class="main-product__modal-next" data-media-modal-next aria-label="Nästa bild">›</button>
      </div>
    {% endif %}
  </div>
</dialog>

<script type="application/json" id="ProductMedia-{{ section.id }}">
  [
    {%- for media in product.media -%}
      {%- liquid
        if media.media_type == 'image'
          assign media_src = media | image_url: width: 1400
          assign media_alt = media.alt | default: product.title
        else
          assign media_src = media.preview_image | image_url: width: 1400
          assign media_alt = media.alt | default: product.title
        endif
      -%}
      {
        "id": {{ media.id | json }},
        "media_type": {{ media.media_type | json }},
        "src": {{ media_src | json }},
        "alt": {{ media_alt | json }},
        "sources": [
          {%- for source in media.sources -%}
            {
              "url": {{ source.url | json }},
              "mime_type": {{ source.mime_type | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>

<script type="application/json" id="ProductVariants-{{ section.id }}">
  [
    {%- for variant in product.variants -%}
      {
        "id": {{ variant.id | json }},
        "available": {{ variant.available | json }},
        "price": {{ variant.price | json }},
        "compare_at_price": {{ variant.compare_at_price | default: 0 | json }},
        "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id | json }}{% else %}null{% endif %}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>

{% stylesheet %}
  .main-product {
    padding-block: 48px 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--mp-bg, #071014);
    color: var(--mp-text, #f6f7f2);
    scroll-margin-top: 80px;
  }

  .main-product__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: start;
  }

  .main-product__gallery {
    min-width: 0;
  }

  .main-product__media-main {
    border-radius: var(--pp-radius-lg, 20px);
    overflow: hidden;
    background-color: var(--mp-surface, #14212a);
    border: 1px solid var(--pp-border);
    aspect-ratio: 1;
    box-shadow: var(--pp-shadow-soft);
    position: relative;
  }

  .main-product__media-open {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    cursor: zoom-in;
    background: transparent;
    position: relative;
  }

  .main-product__media-zoom {
    position: absolute;
    right: 14px;
    bottom: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    color: var(--mp-text, #f6f7f2);
    background: color-mix(in srgb, var(--mp-bg, #071014) 72%, transparent);
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 12%, transparent);
    pointer-events: none;
  }

  .main-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .main-product__modal {
    width: min(960px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    padding: 0;
    border: none;
    border-radius: var(--pp-radius-lg, 20px);
    background: var(--mp-bg, #071014);
    color: var(--mp-text, #f6f7f2);
    box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.7);
  }

  .main-product__modal::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(6px);
  }

  .main-product__modal-inner {
    position: relative;
    padding: 16px;
  }

  .main-product__modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    color: var(--mp-text, #f6f7f2);
    background: color-mix(in srgb, var(--mp-bg, #071014) 80%, transparent);
  }

  .main-product__modal-content img,
  .main-product__modal-content video {
    width: 100%;
    max-height: calc(100vh - 120px);
    object-fit: contain;
    border-radius: 12px;
  }

  .main-product__modal-nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 12px;
  }

  .main-product__modal-prev,
  .main-product__modal-next {
    min-width: 44px;
    min-height: 44px;
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 12%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--mp-text, #f6f7f2) 6%, transparent);
    color: var(--mp-text, #f6f7f2);
    font-size: 1.4rem;
    cursor: pointer;
  }

  .main-product__thumbs {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .main-product__thumb {
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  .main-product__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .main-product__action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 36px;
    padding: 0 14px;
    border-radius: var(--pp-radius-pill, 999px);
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 12%, transparent);
    background: color-mix(in srgb, var(--mp-text, #f6f7f2) 4%, transparent);
    color: var(--mp-muted, #9aa8a2);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .main-product__action-btn.is-active,
  .main-product__action-btn:hover {
    border-color: color-mix(in srgb, var(--mp-accent, #2dd4bf) 45%, transparent);
    color: var(--mp-accent, #2dd4bf);
  }

  .main-product__thumb-btn {
    width: 72px;
    height: 72px;
    padding: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    background: var(--mp-surface, #14212a);
    transition:
      border-color var(--pp-transition, 0.2s ease),
      transform var(--pp-transition, 0.2s ease),
      box-shadow var(--pp-transition, 0.2s ease);
  }

  .main-product__thumb-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -12px rgb(0 0 0 / 50%);
  }

  .main-product__thumb-btn.is-active {
    border-color: var(--mp-accent, #2dd4bf);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--mp-accent, #2dd4bf) 35%, transparent);
  }

  .main-product__thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .main-product__placeholder {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 20px;
    background-color: var(--mp-surface, #14212a);
    color: color-mix(in srgb, var(--mp-text, #f6f7f2) 20%, transparent);
  }

  .main-product__title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .main-product__reviews-slot {
    margin-bottom: 10px;
  }

  .main-product__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .main-product__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: clamp(0.68rem, 2vw, 0.75rem);
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    text-wrap: balance;
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 10%, transparent);
    background: color-mix(in srgb, var(--mp-text, #f6f7f2) 4%, transparent);
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__badge--stock {
    color: var(--mp-accent, #2dd4bf);
    border-color: color-mix(in srgb, var(--mp-accent, #2dd4bf) 35%, transparent);
    background: color-mix(in srgb, var(--mp-accent, #2dd4bf) 10%, transparent);
  }

  .main-product__badge--urgency {
    color: #fbbf24;
    border-color: color-mix(in srgb, #fbbf24 40%, transparent);
    background: color-mix(in srgb, #fbbf24 12%, transparent);
  }

  .main-product__price {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .main-product__price-compare {
    font-size: 1rem;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__price-compare[hidden] {
    display: none;
  }

  .main-product__price-current {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--mp-accent, #2dd4bf);
  }

  .main-product__save-badge {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--mp-accent-ink, #071014);
    background: linear-gradient(135deg, var(--mp-accent, #2dd4bf), color-mix(in srgb, var(--pp-accent-blue, #4cc9f0) 35%, var(--mp-accent, #2dd4bf)));
    box-shadow: 0 4px 12px -6px color-mix(in srgb, var(--mp-accent, #2dd4bf) 70%, #000);
  }

  .main-product__save-badge[hidden] {
    display: none;
  }

  .main-product__description {
    margin-bottom: 20px;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__shipping {
    margin-bottom: 20px;
  }

  .main-product__trust-atc-wrap {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .main-product__trust {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .main-product__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__trust-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    color: var(--mp-accent, #2dd4bf);
    background: color-mix(in srgb, var(--mp-accent, #2dd4bf) 14%, transparent);
  }

  .main-product__form-wrap {
    padding: clamp(22px, 4vw, 28px);
    border-radius: var(--pp-radius-lg, 20px);
    background: linear-gradient(165deg, color-mix(in srgb, var(--mp-surface, #14212a) 92%, #fff 8%) 0%, var(--mp-surface, #14212a) 100%);
    border: 1px solid var(--pp-border);
    box-shadow: var(--pp-shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .main-product__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  .main-product__buy-trust {
    margin-top: 20px;
    padding: 16px;
    border-radius: 16px;
    background: color-mix(in srgb, var(--mp-text, #f6f7f2) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .main-product__buy-trust .pp-trust-atc-wrap {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .main-product__buy-trust .pp-trust-atc:not(.pp-trust-atc--compact) {
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .main-product__buy-trust .pp-trust-atc__chip {
    flex-direction: row;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    min-height: 0;
    border-radius: 12px;
    border-color: color-mix(in srgb, var(--mp-text, #f6f7f2) 8%, transparent);
    background: color-mix(in srgb, var(--mp-bg, #071014) 55%, var(--mp-surface, #14212a));
  }

  .main-product__buy-trust .pp-trust-atc__chip-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    margin: 0;
  }

  .main-product__buy-trust .pp-trust-atc__chip-text {
    align-items: flex-start;
    text-align: left;
    justify-content: center;
    gap: 2px;
  }

  .main-product__buy-trust .pp-trust-atc__chip-text strong {
    font-size: 0.82rem;
    line-height: 1.25;
  }

  .main-product__buy-trust .pp-trust-atc__chip-text span {
    font-size: 0.74rem;
    line-height: 1.35;
  }

  .main-product__buy-trust .main-product__payment {
    padding-top: 14px;
    border-top: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 8%, transparent);
  }

  .main-product__buy-trust .pp-payment-icons__grid {
    gap: 6px;
  }

  .main-product__buy-trust .pp-payment-icons__pill {
    min-width: 50px;
    min-height: 32px;
    padding: 5px 8px;
  }

