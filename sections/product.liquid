{% comment %}
  Product page section — preserves Shopify product form, variant picker and payment button.
{% endcomment %}

<div
  id="main-product"
  class="main-product full-width"
  style="
    --mp-bg: {{ section.settings.background_color }};
    --mp-surface: {{ section.settings.surface_color }};
    --mp-text: {{ section.settings.text_color }};
    --mp-muted: {{ section.settings.muted_text_color }};
    --mp-accent: {{ section.settings.accent_color }};
    --mp-accent-ink: {{ section.settings.accent_text_color }};
  "
>
  <div class="main-product__inner">
    <div class="main-product__gallery">
      {% if product.media.size > 0 %}
        <div class="main-product__media-main">
          {% assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media %}
          {% if featured_media != blank %}
            {% if featured_media.media_type == 'image' %}
              {{
                featured_media
                | image_url: width: 1400
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  widths: '500, 700, 900, 1200, 1400',
                  class: 'main-product__image',
                  alt: featured_media.alt | default: product.title
              }}
            {% else %}
              {{ featured_media | media_tag: class: 'main-product__image' }}
            {% endif %}
          {% endif %}
        </div>
        {% if product.media.size > 1 %}
          <ul class="main-product__thumbs" role="list">
            {% for media in product.media limit: 6 %}
              <li class="main-product__thumb">
                {% if media.media_type == 'image' %}
                  {{
                    media
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', widths: '100, 200', sizes: '80px', alt: media.alt
                  }}
                {% else %}
                  {{ media | media_tag }}
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      {% else %}
        <div class="main-product__placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="main-product__info">
      <h1 class="main-product__title">{{ product.title }}</h1>

      <div class="main-product__price">
        {% assign current_variant = product.selected_or_first_available_variant %}
        {% if current_variant.compare_at_price > current_variant.price %}
          <s class="main-product__price-compare">{{ current_variant.compare_at_price | money }}</s>
        {% endif %}
        <span class="main-product__price-current">{{ current_variant.price | money }}</span>
      </div>

      {% if product.description != blank %}
        <div class="main-product__description">{{ product.description }}</div>
      {% endif %}

      <div class="main-product__form-wrap">
        {% form 'product', product %}
          {% assign current_variant = product.selected_or_first_available_variant %}

          {% if product.variants.size > 1 %}
            <label class="main-product__label" for="MainProduct-Variant-{{ section.id }}">Variant</label>
            <select
              id="MainProduct-Variant-{{ section.id }}"
              class="main-product__select"
              name="id"
            >
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  {% if variant == current_variant %}
                    selected="selected"
                  {% endif %}
                  {% unless variant.available %}
                    disabled
                  {% endunless %}
                >
                  {{ variant.title }}, {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% endif %}

          <div class="main-product__qty-row">
            <label class="main-product__label" for="MainProduct-Qty-{{ section.id }}">Antal</label>
            <input
              id="MainProduct-Qty-{{ section.id }}"
              class="main-product__qty"
              type="number"
              name="quantity"
              min="1"
              value="1"
            >
          </div>

          <button
            class="main-product__submit"
            type="submit"
            {% unless current_variant.available %}
              disabled
            {% endunless %}
          >
            {% if current_variant.available %}
              {{ section.settings.button_label | default: 'Lägg i varukorg' }}
            {% else %}
              Slutsåld
            {% endif %}
          </button>

          {{ form | payment_button }}
        {% endform %}
      </div>
    </div>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="main-product__app">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when '@app' %}
            <div {{ block.shopify_attributes }}>
              {% render block %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .main-product {
    padding-block: 48px 72px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--mp-bg, #071014);
    color: var(--mp-text, #f6f7f2);
    scroll-margin-top: 80px;
  }

  .main-product__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: start;
  }

  .main-product__media-main {
    border-radius: 20px;
    overflow: hidden;
    background-color: var(--mp-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 8%, transparent);
    aspect-ratio: 1;
  }

  .main-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-product__thumbs {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: flex;
    gap: 10px;
    overflow-x: auto;
  }

  .main-product__thumb {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 10%, transparent);
  }

  .main-product__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-product__placeholder {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 20px;
    background-color: var(--mp-surface, #14212a);
    color: color-mix(in srgb, var(--mp-text, #f6f7f2) 20%, transparent);
  }

  .main-product__title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .main-product__price {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .main-product__price-compare {
    font-size: 1rem;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__price-current {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--mp-accent, #2dd4bf);
  }

  .main-product__description {
    margin-bottom: 28px;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__form-wrap {
    padding: 28px 24px;
    border-radius: 20px;
    background-color: var(--mp-surface, #14212a);
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .main-product__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--mp-muted, #9aa8a2);
  }

  .main-product__select,
  .main-product__qty {
    width: 100%;
    min-height: 48px;
    padding: 0 14px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--mp-text, #f6f7f2) 15%, transparent);
    background-color: var(--mp-bg, #071014);
    color: var(--mp-text, #f6f7f2);
  }

  .main-product__qty-row {
    max-width: 120px;
  }

  .main-product__submit {
    width: 100%;
    min-height: 54px;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    color: var(--mp-accent-ink, #071014);
    background-color: var(--mp-accent, #2dd4bf);
  }

  .main-product__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .main-product__form-wrap .shopify-payment-button {
    margin-top: 4px;
  }

  .main-product__app {
    max-width: var(--page-width, 90rem);
    margin: 40px auto 0;
  }

  @media screen and (min-width: 750px) {
    .main-product {
      padding-block: 64px 96px;
    }

    .main-product__inner {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart label",
      "default": "Lägg i varukorg"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text",
      "default": "#071014"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
