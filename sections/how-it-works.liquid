<div
  id="how-it-works"
  class="how-it-works full-width"
  style="
    --hiw-bg: {{ section.settings.background_color }};
    --hiw-surface: {{ section.settings.surface_color }};
    --hiw-text: {{ section.settings.text_color }};
    --hiw-muted: {{ section.settings.muted_text_color }};
    --hiw-accent: {{ section.settings.accent_color }};
  "
>
  <div class="how-it-works__inner">
    {% if section.settings.heading != blank %}
      <header class="how-it-works__header">
        {% if section.settings.eyebrow != blank %}
          <p class="how-it-works__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="how-it-works__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="how-it-works__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ol class="how-it-works__steps">
        {% for block in section.blocks %}
          <li class="how-it-works__step" {{ block.shopify_attributes }}>
            <div class="how-it-works__badge" aria-hidden="true">
              <span class="how-it-works__badge-ring"></span>
              {% if block.settings.icon != blank and block.settings.icon != 'none' %}
                <span class="how-it-works__icon">{% render 'icon', name: block.settings.icon, size: 26 %}</span>
              {% endif %}
              <span class="how-it-works__number">{{ forloop.index }}</span>
            </div>
            <div class="how-it-works__content">
              {% if block.settings.title != blank %}
                <h3 class="how-it-works__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="how-it-works__text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ol>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .how-it-works {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--hiw-bg, #101820);
    color: var(--hiw-text, #f6f7f2);
    scroll-margin-top: 80px;
  }

  .how-it-works__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .how-it-works__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 28px;
  }

  .how-it-works__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hiw-accent, #2dd4bf);
  }

  .how-it-works__heading {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .how-it-works__subheading {
    margin: 0;
    color: var(--hiw-muted, #9aa8a2);
    line-height: 1.6;
  }

  .how-it-works__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    counter-reset: step;
  }

  .how-it-works__step {
    position: relative;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 26px 24px;
    border-radius: 20px;
    background: var(--pp-gradient-surface);
    border: 1px solid color-mix(in srgb, var(--hiw-text, #f6f7f2) 8%, transparent);
    box-shadow: var(--pp-shadow-soft);
    transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
  }

  .how-it-works__step:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--hiw-accent, #2dd4bf) 45%, transparent);
    box-shadow: var(--pp-shadow-card);
  }

  .how-it-works__badge {
    position: relative;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: grid;
    place-items: center;
  }

  .how-it-works__badge-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: color-mix(in srgb, var(--hiw-accent, #2dd4bf) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--hiw-accent, #2dd4bf) 40%, transparent);
    transition: box-shadow 0.2s ease;
  }

  .how-it-works__step:hover .how-it-works__badge-ring {
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--hiw-accent, #2dd4bf) 10%, transparent);
  }

  .how-it-works__icon {
    position: relative;
    z-index: 1;
    display: inline-flex;
    color: var(--hiw-accent, #2dd4bf);
  }

  .how-it-works__number {
    position: absolute;
    z-index: 2;
    top: -6px;
    right: -6px;
    width: 24px;
    height: 24px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--hiw-bg, #101820);
    background-color: var(--hiw-accent, #2dd4bf);
    border: 2px solid var(--hiw-surface, #14212a);
  }

  .how-it-works__title {
    margin: 0 0 6px;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .how-it-works__text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--hiw-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .how-it-works {
      padding-block: 68px;
    }

    .how-it-works__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .how-it-works__step {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }

    /* Flowing connector line between steps 1 -> 2 -> 3 */
    .how-it-works__step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 56px;
      right: -24px;
      width: 24px;
      height: 2px;
      background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--hiw-accent, #2dd4bf) 70%, transparent),
        color-mix(in srgb, var(--hiw-accent, #2dd4bf) 20%, transparent)
      );
    }

    .how-it-works__step:not(:last-child)::before {
      content: '';
      position: absolute;
      top: 52px;
      right: -28px;
      z-index: 1;
      width: 9px;
      height: 9px;
      border-top: 2px solid var(--hiw-accent, #2dd4bf);
      border-right: 2px solid var(--hiw-accent, #2dd4bf);
      transform: rotate(45deg);
    }
  }
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) and (min-width: 750px) {
      .how-it-works__step {
        animation: hiw-reveal linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 28%;
      }
    }
  }

  @keyframes hiw-reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .how-it-works__step,
    .how-it-works__badge-ring {
      transition: none;
    }

    .how-it-works__step:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Så funkar det"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tre steg till en riktig dusch"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ingen rördragning. Ingen fast installation. Bara ren komfort."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#101820"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "droplets", "label": "Vatten (fyll på)" },
            { "value": "droplet", "label": "Droppe" },
            { "value": "arrow-down", "label": "Pil ner (sänk ner)" },
            { "value": "submerge", "label": "Sänk ner i vatten" },
            { "value": "shower", "label": "Duschmunstycke" },
            { "value": "bolt", "label": "Blixt (slå på)" },
            { "value": "sliders", "label": "Reglage (justera)" },
            { "value": "package", "label": "Paket" }
          ],
          "default": "droplets"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Fyll på vatten" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Använd hinken, en dunk eller valfri vattenkälla." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step", "settings": { "icon": "droplets", "title": "Fyll på vatten", "text": "Använd den vikbara hinken, en dunk eller valfri vattenkälla." } },
        { "type": "step", "settings": { "icon": "arrow-down", "title": "Sänk ner pumpen", "text": "Placera pumpen i vattnet och häng upp duschmunstycket." } },
        { "type": "step", "settings": { "icon": "bolt", "title": "Slå på pumpen & duscha", "text": "Slå på pumpen och njut av ett kraftfullt, justerbart vattenflöde." } }
      ]
    }
  ]
}
{% endschema %}
