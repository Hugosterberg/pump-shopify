{% comment %}
  PUMP ecosystem — frames PUMP as a growing range of portable utilities.
  Two block types:
    - product → links a real product (no hardcoded data)
    - coming  → a "Snart" placeholder for upcoming products
{% endcomment %}

<div
  class="ecosystem full-width"
  style="
    --ec-bg: {{ section.settings.background_color }};
    --ec-surface: {{ section.settings.surface_color }};
    --ec-text: {{ section.settings.text_color }};
    --ec-muted: {{ section.settings.muted_text_color }};
    --ec-accent: {{ section.settings.accent_color }};
  "
>
  <div class="ecosystem__inner">
    <header class="ecosystem__header">
      {% if section.settings.eyebrow != blank %}
        <p class="ecosystem__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ecosystem__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        {% assign eco_points = section.settings.subheading | split: ' · ' %}
        <ul class="ecosystem__points" role="list">
          {% for point in eco_points %}
            <li class="ecosystem__point">{{ point }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <ul class="ecosystem__grid" role="list">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'product' %}
              {% assign product = block.settings.product %}
              <li class="ecosystem__card" {{ block.shopify_attributes }}>
                <a class="ecosystem__link" href="{% if product != blank %}{{ product.url }}{% else %}#{% endif %}">
                  <div class="ecosystem__media">
                    {% if product != blank and product.featured_image != blank %}
                      {{
                        product.featured_image
                        | image_url: width: 700
                        | image_tag:
                          loading: 'lazy',
                          widths: '300, 500, 700',
                          sizes: '(min-width: 750px) 25vw, 50vw',
                          alt: product.title
                      }}
                    {% else %}
                      <div class="ecosystem__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                    {% endif %}
                  </div>
                  <div class="ecosystem__body">
                    <h3 class="ecosystem__name">
                      {% if product != blank %}{{ product.title }}{% else %}{{ block.settings.fallback_title }}{% endif %}
                    </h3>
                    {% if product != blank %}
                      <p class="ecosystem__price">{{ product.price | money }}</p>
                    {% endif %}
                  </div>
                </a>
              </li>
            {% when 'coming' %}
              <li class="ecosystem__card ecosystem__card--coming" {{ block.shopify_attributes }}>
                <div class="ecosystem__media ecosystem__media--coming">
                  <span class="ecosystem__soon-badge">{{ block.settings.badge | default: 'Snart' }}</span>
                  <span class="ecosystem__soon-mark" aria-hidden="true">+</span>
                </div>
                <div class="ecosystem__body">
                  <h3 class="ecosystem__name">{{ block.settings.title }}</h3>
                  {% if block.settings.text != blank %}
                    <p class="ecosystem__coming-text">{{ block.settings.text }}</p>
                  {% endif %}
                </div>
              </li>
          {% endcase %}
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .ecosystem {
    padding-block: 52px;
    padding-inline: var(--page-margin, 20px);
    background-color: var(--ec-bg, #071014);
    color: var(--ec-text, #f6f7f2);
  }

  .ecosystem__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .ecosystem__header {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .ecosystem__eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ec-accent, #2dd4bf);
  }

  .ecosystem__heading {
    margin: 0 0 12px;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    letter-spacing: -0.02em;
  }

  .ecosystem__points {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 18px;
  }

  .ecosystem__point {
    position: relative;
    padding-left: 16px;
    font-size: 0.9rem;
    color: var(--ec-muted, #9aa8a2);
  }

  .ecosystem__point::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 7px;
    height: 7px;
    margin-top: -3.5px;
    border-radius: 50%;
    background-color: var(--ec-accent, #2dd4bf);
  }

  .ecosystem__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .ecosystem__card {
    border-radius: 18px;
    overflow: hidden;
    background-color: var(--ec-surface, #111c24);
    border: 1px solid color-mix(in srgb, var(--ec-text, #f6f7f2) 8%, transparent);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .ecosystem__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--ec-accent, #2dd4bf) 45%, transparent);
  }

  .ecosystem__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ecosystem__media {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--ec-text, #f6f7f2) 4%, transparent);
  }

  .ecosystem__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ecosystem__card:hover .ecosystem__media img {
    transform: scale(1.05);
  }

  .ecosystem__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--ec-text, #f6f7f2) 18%, transparent);
  }

  .ecosystem__media--coming {
    position: relative;
    display: grid;
    place-items: center;
    background:
      repeating-linear-gradient(45deg, color-mix(in srgb, var(--ec-accent, #2dd4bf) 6%, transparent) 0 10px, transparent 10px 20px),
      color-mix(in srgb, var(--ec-text, #f6f7f2) 3%, transparent);
  }

  .ecosystem__soon-mark {
    font-size: 3rem;
    font-weight: 300;
    color: color-mix(in srgb, var(--ec-accent, #2dd4bf) 60%, transparent);
  }

  .ecosystem__soon-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 5px 11px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ec-accent, #2dd4bf);
    border: 1px solid color-mix(in srgb, var(--ec-accent, #2dd4bf) 50%, transparent);
  }

  .ecosystem__card--coming {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--ec-accent, #2dd4bf) 30%, transparent);
  }

  .ecosystem__body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ecosystem__name {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .ecosystem__price {
    margin: 0;
    font-weight: 700;
    color: var(--ec-accent, #2dd4bf);
  }

  .ecosystem__coming-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--ec-muted, #9aa8a2);
  }

  @media screen and (min-width: 750px) {
    .ecosystem {
      padding-block: 68px;
    }

    .ecosystem__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ecosystem__card,
    .ecosystem__media img {
      transition: none;
    }

    .ecosystem__card:hover {
      transform: none;
    }

    .ecosystem__card:hover .ecosystem__media img {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "pump ecosystem",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portable Utilities Made Perfect" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ekosystemet av portabla prylar" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "info": "Separate points with ' · ' to show them as a row of bullet points.", "default": "Det börjar med duschen · Fler portabla produkter på väg · Utvecklat av ett svenskt team · Byggt för att hålla" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#071014" },
    { "type": "color", "id": "surface_color", "label": "Surface", "default": "#111C24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F6F7F2" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#9AA8A2" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#2DD4BF" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Produkt" }
      ]
    },
    {
      "type": "coming",
      "name": "Coming soon",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "Snart" },
        { "type": "text", "id": "title", "label": "Title", "default": "Nästa portabla pryl" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Vi jobbar på fler smarta lösningar. Häng med!" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "pump ecosystem",
      "blocks": [
        { "type": "product", "settings": { "fallback_title": "The Portable Shower" } },
        { "type": "product", "settings": { "fallback_title": "The Portable Bucket" } },
        { "type": "product", "settings": { "fallback_title": "The Perfect Combo" } },
        { "type": "coming", "settings": { "badge": "Snart", "title": "Nästa portabla pryl", "text": "Fler smarta lösningar är på väg." } }
      ]
    }
  ]
}
{% endschema %}

