{% comment %}
  Full Judge.me All Reviews page — official widget, premium Pump framing.
  Assign this section via templates/page.reviews.json and create a Shopify page
  with handle "recensioner" (or "reviews") using the Reviews template.
{% endcomment %}

{%- liquid
  assign shop_rating = shop.metafields.judgeme.all_reviews_rating
  assign shop_count = shop.metafields.judgeme.all_reviews_count
  assign rating_value = blank
  assign rating_count = blank

  if shop_rating != blank
    assign rating_value = shop_rating.value | default: shop_rating
  endif
  if shop_count != blank
    assign rating_count = shop_count.value | default: shop_count
  endif

  if rating_value != blank
    assign rating_display = rating_value | times: 1.0 | round: 1
    assign rating_rounded = rating_value | round
  else
    assign rating_display = blank
    assign rating_rounded = 5
  endif
-%}

<section
  class="pp-jdgm-all full-width"
  style="
    --ja-bg: {{ section.settings.background_color }};
    --ja-surface: {{ section.settings.surface_color }};
    --ja-text: {{ section.settings.text_color }};
    --ja-muted: {{ section.settings.muted_text_color }};
    --ja-accent: {{ section.settings.accent_color }};
  "
>
  <div class="pp-jdgm-all__inner">
    <header class="pp-jdgm-all__header">
      {% if section.settings.eyebrow != blank %}
        <p class="pp-jdgm-all__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="pp-jdgm-all__heading">{{ section.settings.heading }}</h1>
      {% elsif page.title != blank %}
        <h1 class="pp-jdgm-all__heading">{{ page.title }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="pp-jdgm-all__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if rating_display != blank or rating_count != blank %}
        <div class="pp-jdgm-all__summary">
          {% if rating_display != blank %}
            <div class="pp-jdgm-all__score">
              <span class="pp-jdgm-all__score-number">{{ rating_display }}</span>
              <div class="pp-jdgm-all__stars" role="img" aria-label="{{ rating_display }} av 5 stjärnor">
                {% for i in (1..5) %}
                  <span class="pp-jdgm-all__star{% if i > rating_rounded %} pp-jdgm-all__star--empty{% endif %}" aria-hidden="true">★</span>
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if rating_count != blank %}
            <p class="pp-jdgm-all__count">
              {{ rating_count }} verifierade omdömen via Judge.me
            </p>
          {% endif %}
        </div>
      {% endif %}
    </header>

    <div class="pp-jdgm-all__widget" id="judgeme_all_reviews">
      <div class="jdgm-widget jdgm-all-reviews-widget">
        {{ shop.metafields.judgeme.all_reviews_header }}
        {{ shop.metafields.judgeme.all_reviews }}
      </div>
    </div>

    {% if section.settings.show_back_link %}
      <p class="pp-jdgm-all__back">
        <a href="{{ routes.root_url }}">← Tillbaka till startsidan</a>
      </p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .pp-jdgm-all {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(48px, 8vw, 88px);
    padding-inline: var(--page-margin, 20px);
    background:
      radial-gradient(55% 42% at 50% -6%, color-mix(in srgb, var(--ja-accent, #2dd4bf) 20%, transparent), transparent 70%),
      radial-gradient(40% 34% at 90% 90%, color-mix(in srgb, #38bdf8 10%, transparent), transparent 72%),
      linear-gradient(180deg, #05090c 0%, var(--ja-bg, #071014) 45%, #060b10 100%);
    color: var(--ja-text, #f6f7f2);
  }

  .pp-jdgm-all__inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
    margin-inline: auto;
  }

  .pp-jdgm-all__header {
    text-align: center;
    margin-bottom: clamp(28px, 5vw, 44px);
  }

  .pp-jdgm-all__eyebrow {
    margin: 0 0 8px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ja-accent, #2dd4bf);
  }

  .pp-jdgm-all__heading {
    margin: 0;
    font-size: clamp(1.75rem, 4.5vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    text-wrap: balance;
  }

  .pp-jdgm-all__subheading {
    margin: 12px auto 0;
    max-width: 36rem;
    font-size: clamp(0.95rem, 2.2vw, 1.05rem);
    line-height: 1.55;
    color: var(--ja-muted, #9aa8a2);
    text-wrap: pretty;
  }

  .pp-jdgm-all__summary {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    padding: 16px 22px;
    border-radius: 18px;
    background: color-mix(in srgb, var(--ja-surface, #14212a) 88%, transparent);
    border: 1px solid color-mix(in srgb, var(--ja-accent, #2dd4bf) 22%, transparent);
  }

  .pp-jdgm-all__score {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .pp-jdgm-all__score-number {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ja-accent, #2dd4bf);
    font-variant-numeric: tabular-nums;
  }

  .pp-jdgm-all__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--ja-accent, #2dd4bf);
    font-size: 1.05rem;
    line-height: 1;
  }

  .pp-jdgm-all__star--empty {
    opacity: 0.28;
  }

  .pp-jdgm-all__count {
    margin: 0;
    font-size: 0.82rem;
    color: var(--ja-muted, #9aa8a2);
  }

  .pp-jdgm-all__widget {
    padding: clamp(16px, 3vw, 28px);
    border-radius: 22px;
    background:
      linear-gradient(165deg, color-mix(in srgb, var(--ja-surface, #14212a) 92%, #fff), #0b1218);
    border: 1px solid color-mix(in srgb, var(--ja-text, #f6f7f2) 8%, transparent);
    box-shadow: 0 24px 60px -36px rgba(0, 0, 0, 0.9);
  }

  .pp-jdgm-all__widget .jdgm-widget,
  .pp-jdgm-all__widget .jdgm-all-reviews-widget {
    color: inherit;
  }

  .pp-jdgm-all__back {
    margin: 28px 0 0;
    text-align: center;
  }

  .pp-jdgm-all__back a {
    color: var(--ja-accent, #2dd4bf);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .pp-jdgm-all__back a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Judge.me all reviews",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Judge.me"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Alla omdömen"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Verifierade kundomdömen från Judge.me — bläddra, filtrera och läs allt på ett ställe."
    },
    {
      "type": "checkbox",
      "id": "show_back_link",
      "label": "Show back to home link",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#071014"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#9AA8A2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Judge.me all reviews"
    }
  ]
}
{% endschema %}
