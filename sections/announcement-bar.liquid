{% if section.settings.text != blank %}
  <div
    class="announcement-bar full-width"
    style="
      --ab-bg: {{ section.settings.background_color }};
      --ab-text: {{ section.settings.text_color }};
      --ab-accent: {{ section.settings.accent_color }};
    "
  >
  <div class="announcement-bar__inner">
    {% if section.settings.link != blank %}
      <a class="announcement-bar__link" href="{{ section.settings.link }}">
        {{ section.settings.text }}
      </a>
    {% else %}
      <p class="announcement-bar__text">{{ section.settings.text }}</p>
    {% endif %}
  </div>
  </div>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    padding: 10px var(--page-margin, 20px);
    background-color: var(--ab-bg, #14212a);
    color: var(--ab-text, #f6f7f2);
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    border-bottom: 1px solid color-mix(in srgb, var(--ab-text, #f6f7f2) 8%, transparent);
  }

  .announcement-bar__inner {
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
  }

  .announcement-bar__link:hover {
    color: var(--ab-accent, #2dd4bf);
  }

  .announcement-bar__text {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Fri frakt på beställningar över 999 kr"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#14212A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F6F7F2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2DD4BF"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
