    "faq": {
      "type": "faq-section",
      "blocks": {
        "f-1": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Hur fungerar den portabla duschen?", "answer": "<p>Duschen drar vatten från valfri behållare eller vattenkälla, till exempel en hink, dunk eller sjö, via en inbyggd elpump och pumpar ut det genom duschmunstycket med jämnt och justerbart tryck. Allt drivs av ett laddningsbart batteri, så du behöver varken eluttag eller fast installation. Perfekt för camping, stranden, träning eller ute i trädgården.</p>" } },
        "f-2": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Behöver jag el eller batterier?", "answer": "<p>Nej, inget extra behövs. Det laddningsbara batteriet (6000 mAh) är inbyggt i pumpen och laddas via USB-C, samma typ av kabel som till dina andra prylar. En full laddning ger ~150 minuters drift.</p>" } },
        "f-3": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Hur länge räcker batteriet?", "answer": "<p>Med full laddning får du ~150 minuters drift, beroende på flödesinställning. Den inbyggda displayen visar batterinivån i realtid så du har full koll, och du laddar enkelt upp igen via USB-C på cirka 4–5 timmar.</p>" } },
        "f-4": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Kan jag använda den med varmt vatten?", "answer": "<p>Ja, upp till 50°C fungerar bra. Varmare än så kan skada pumpen. Den digitala displayen visar vattentemperaturen så du alltid har koll på hur varmt det är.</p>" } },
        "f-6": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Är den vattentålig?", "answer": "<p>Ja! Alla delar är vattentåliga, inklusive pumpen och elektroniken. Pumpen är gjord för att sänkas ned i vattnet du duschar med.</p>" } },
        "f-7": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Hur mycket vatten går åt per dusch?", "answer": "<p>En 10-litersdunk räcker oftast till en dusch på 6–8 minuter, beroende på flöde. Med justerbart tryck och ett flöde på upp till 8 L/min bestämmer du själv hur snålt eller kraftfullt du duschar (något lägre flöde med slang).</p>" } },
        "f-8": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Var kan jag använda duschen?", "answer": "<p>Var som helst där du har tillgång till vatten:</p><ul><li>På stranden eller i naturen</li><li>På campingen</li><li>I vanlife, husbilen eller stugan</li><li>Efter träning</li><li>För att skölja av barn, husdjur eller redskap</li><li>Hemma på balkongen eller i trädgården</li></ul><p>Fäst den med sugproppen på en vägg, häng den i en krok eller håll den i handen.</p>" } },
        "f-9": { "type": "faq", "settings": { "category": "Användning & tips", "question": "Fungerar den inomhus?", "answer": "<p>Absolut, så länge du har en behållare med vatten, till exempel en hink eller dunk. Fäst duschen med sugproppen på en kakelvägg, häng den i en krok eller håll den i handen.</p>" } },
        "f-11": { "type": "faq", "settings": { "category": "Frakt & leverans", "question": "Hur lång är leveranstiden?", "answer": "<p>2–5 arbetsdagar inom Sverige och normalt något längre inom övriga EU.</p>" } },
        "f-12": { "type": "faq", "settings": { "category": "Frakt & leverans", "question": "Vilka fraktalternativ erbjuder ni?", "answer": "<p>Du väljer själv i kassan om du vill ha hemleverans eller hämta hos ombud.</p>" } },
        "f-13": { "type": "faq", "settings": { "category": "Frakt & leverans", "question": "Vad kostar frakten?", "answer": "<p>Fri frakt inom Sverige vid köp över 999 kr, annars tillkommer en fraktkostnad på 69 kr. För leveranser inom övriga EU räknas frakten ut automatiskt i kassan.</p>" } },
        "f-14": { "type": "faq", "settings": { "category": "Frakt & leverans", "question": "Kan jag spåra mitt paket?", "answer": "<p>Ja! Så fort din order har skickats får du ett spårningsnummer via e-post eller sms, så att du kan följa paketet hela vägen hem.</p>" } },
        "f-15": { "type": "faq", "settings": { "category": "Frakt & leverans", "question": "Levererar ni utanför Sverige?", "answer": "<p>Ja, vi levererar inom hela EU. Leveranstiden är vanligtvis något längre än inom Sverige och frakten räknas ut automatiskt i kassan.</p>" } },
        "f-16": { "type": "faq", "settings": { "category": "Returer & garanti", "question": "Kan jag returnera produkten om jag ångrar mig?", "answer": "<p>Självklart. Du har 14 dagar från det att du tagit emot produkten att ångra ditt köp. Produkten ska vara i samma skick som när du fick den: oanvänd, komplett med etiketter och i originalförpackning. Kontakta oss på info@pumpportable.com så hjälper vi dig!</p>" } },
        "f-17": { "type": "faq", "settings": { "category": "Returer & garanti", "question": "Hur fungerar garantin?", "answer": "<p>Vi erbjuder 1 års garanti på alla våra produkter mot tillverkningsfel. Om något är fel med duschen, hör av dig så löser vi det, med en reparation, en reservdel eller en ersättningsprodukt.</p>" } },
        "f-18": { "type": "faq", "settings": { "category": "Returer & garanti", "question": "Vad händer om något går sönder efter garantin?", "answer": "<p>Vi vill att våra produkter ska hålla länge. Kontakta oss på info@pumpportable.com även efter garantitiden så försöker vi hjälpa till, ibland räcker det med en enkel reservdel.</p>" } },
        "f-19": { "type": "faq", "settings": { "category": "Företag & kontakt", "question": "Vilka står bakom varumärket?", "answer": "<p>Vi är ett svenskt team bakom varumärket pump, som står för Portable Utilities Made Perfect. Vi brinner för smarta, portabla produkter som gör livet enklare och har fler lösningar på väg. Alla produkter testas noggrant innan vi säljer dem.</p>" } },
        "f-20": { "type": "faq", "settings": { "category": "Företag & kontakt", "question": "Erbjuder ni samarbeten eller återförsäljning?", "answer": "<p>Ja! Hör gärna av dig på info@pumpportable.com om du är influencer, återförsäljare eller vill samarbeta. Vi är alltid öppna för nya idéer.</p>" } },
        "f-21": { "type": "faq", "settings": { "category": "Företag & kontakt", "question": "Har ni sociala medier?", "answer": "<p>Ja, följ gärna vår resa på Instagram @pumpportable_ och på Facebook för uppdateringar, tips och behind-the-scenes!</p>" } }
